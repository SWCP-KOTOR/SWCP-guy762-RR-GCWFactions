	<ThingDef ParentName="guy762_jetpackMakeable">
		<defName>guy762_Jetpack_Z6launcher</defName>
		<label>jetpack, Z-6</label>
		<description>This jetpack comes equipped with a missile launcher that can be loaded with a variety of different missiles.</description>
		<graphicData>
		  <texPath>SWApparel/Mandalorian/Z6jetpack/Z6jetpack_item</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <shaderType>CutoutMultiMask</shaderType>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(230,185,45)</colorTwo> republic yellow -->
		</graphicData>
		<soundInteract>kotorsound_select_other</soundInteract>
		<statBases>
		  <Mass>12</Mass>
		  <MarketValue>7500</MarketValue>
		  <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
		  <ArmorRating_Blunt>0.2</ArmorRating_Blunt>
		  <ArmorRating_Heat>0.2</ArmorRating_Heat>
		  <AccuracyTouch>0.50</AccuracyTouch>
		  <AccuracyShort>0.40</AccuracyShort>
		  <AccuracyMedium>0.20</AccuracyMedium>
		  <AccuracyLong>0.10</AccuracyLong>
		  <RangedWeapon_Cooldown>5</RangedWeapon_Cooldown>
		  <JumpRange>30</JumpRange>
		  
		  <WorkToMake>40000</WorkToMake>
		</statBases>
		
		<recipeMaker>
		  <researchPrerequisites>
			<li>KOTOR_Research_plasmaApplications</li>
			<li>guy762_ResearchKotOR_mando</li>
		  </researchPrerequisites>
		  <skillRequirements>
			<Crafting>16</Crafting>
		  </skillRequirements>
		</recipeMaker>
		<costList>
			<ComponentIndustrial>16</ComponentIndustrial>
			<KOTOR_PlasmaCartridge>10</KOTOR_PlasmaCartridge>
			<ComponentSpacer>4</ComponentSpacer>
			<KOTOR_AlloyDurasteel>60</KOTOR_AlloyDurasteel>
		</costList>
		
		<descriptionHyperlinks>
			<ThingDef>guy762_KotORWorkbench</ThingDef>
		</descriptionHyperlinks>
		<apparel>
		  <tags>
			<li>SWGCWSpecificGadgetItem_Z6Jetpack</li>
		  </tags>
		  <wornGraphicPath>SWApparel/Mandalorian/Z6jetpack/Z6jetpack</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  
		  <wornGraphicData Inherit="False">
			<renderUtilityAsPack>true</renderUtilityAsPack>
			<east>
			  <offset>(-0.35,-0.05)</offset>
			  <thin><offset>(0.05,0)</offset></thin>
			  <hulk><offset>(-0.1,0)</offset></hulk>
			  <fat><offset>(-0.15,0)</offset></fat>
			</east>
			<west>
			  <offset>(0.35,-0.05)</offset>
			  <thin><offset>(-0.05,0)</offset></thin>
			  <hulk><offset>(0.1,0)</offset></hulk>
			  <fat><offset>(0.15,0)</offset></fat>
			</west>
			<male>  <scale>(0.85,0.85)</scale></male>
			<female><scale>(0.85,0.85)</scale></female>
			<thin>  <scale>(0.8,0.8)</scale></thin>
			<!-- <hulk>  <scale>(0.9,0.9)</scale></hulk> -->
			<!-- <fat>   <scale>(0.9,0.9)</scale></fat> -->
		  </wornGraphicData>
		  
		</apparel>
		<colorGenerator Class="ColorGenerator_Options">
		  <options>
			<li>
				<weight>100</weight>
				<only>(70,90,125)</only>       <!--K1 blue-->
			</li>
		  </options>
		</colorGenerator>
		<tradeTags>
		  <li>guy762TT_KotORElite</li>
		  <li>guy762TT_MNCArmor</li>
		</tradeTags>
		<verbs>
		  <li>
			<verbClass>Verb_Jump</verbClass>
			<label>jump</label>
			<violent>false</violent>
			<hasStandardCommand>true</hasStandardCommand>
			<onlyManualCast>True</onlyManualCast>
			<forceNormalTimeSpeed>false</forceNormalTimeSpeed>
			<warmupTime>0.5</warmupTime>
			<warmupEffecter>JumpWarmupEffect</warmupEffecter>
			<requireLineOfSight>true</requireLineOfSight>
			<flightEffecterDef>JumpFlightEffect</flightEffecterDef>
			<soundLanding>JumpPackLand</soundLanding>
			<targetParams>
			  <canTargetLocations>true</canTargetLocations>
			  <canTargetPawns>false</canTargetPawns>
			  <canTargetBuildings>false</canTargetBuildings>
			</targetParams>

		  </li>
		  
		  <li Class="VerbShootVehicle.VerbPropertiesAntiVehicle">
				<label>homing AA/AV missile</label>
				<commandIcon>UI/targetlock</commandIcon>
				<verbClass>VerbShootVehicle.Verb_ShootAntiVehicle</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>SWProj_SAAVProtonMissile_light</defaultProjectile>
				<warmupTime>4</warmupTime>
				<defaultCooldownTime>12</defaultCooldownTime>
				<range>40</range>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_JKrocket_alt</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>14</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				
				<forcedMissRadius>0.5</forcedMissRadius>
				<onlyManualCast>true</onlyManualCast>
				<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
				<ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
				
				<targetParams>
                    <canTargetLocations>false</canTargetLocations>
                </targetParams>
                <onlyTargetVehicle>True</onlyTargetVehicle>
                <onlyTargetFleshType>False</onlyTargetFleshType>
                <!-- <fleshTypeDef>FleshTypeDef</fleshTypeDef> -->
			</li>
			
			
		</verbs>
		<comps>
		  <!-- <li Class="ModularWeapons.CompProperties_ModularParts"> -->
			<!-- <compClass>ModularWeapons.CompModularParts</compClass> -->
			<!-- <partKinds> -->
