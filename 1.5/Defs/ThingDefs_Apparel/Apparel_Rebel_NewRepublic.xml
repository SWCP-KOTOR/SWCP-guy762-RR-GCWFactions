	  <ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_NewRepublicHelmet</defName>
		<label>New Republic marine helmet</label>
		<techLevel>Spacer</techLevel>
		<description>.</description>
		<graphicData>
			<texPath>Apparel/NewRepublic/helmet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<colorTwo>(70,90,125)</colorTwo>       <!--K1 blue-->
		</graphicData>
		<thingCategories>
		  <li>ArmorHeadgear</li>
		</thingCategories>
		<statBases>
			<Mass>3.5</Mass>
			<MarketValue>300</MarketValue>
			<MaxHitPoints>115</MaxHitPoints>
      		<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ShootingAccuracyPawn>0.1</ShootingAccuracyPawn>
			<AimingDelayFactor>-0.1</AimingDelayFactor>
		</equippedStatOffsets>
		
		<apparel Inherit="False">
			<tags>
				<li>NewRepublic_trooper</li>
				<li>SWGCWSpecificApparelItem_NewRepublicMarineHelmet</li>
			</tags>
			<wornGraphicPath>Apparel/NewRepublic/helmet</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
				<li>Overhead</li>
				<li>EyeCover</li>
			</layers>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<useDeflectMetalEffect>true</useDeflectMetalEffect>
		</apparel>
		<tradeTags>
			<li>guy762TT_NewRepublicArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>10</weight>
					<only>(250,250,250)</only>  <!-- white -->
				</li>
			</options>
		</colorGenerator>
	</ThingDef>
	
	
