<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="guy762_clothingbase">
		<defName>guy762_NewRepUniform_bigbelt</defName>
		<label>New Republic uniform, guard's</label>
		<description>These are simple garments that protect little more than the modesty of the wearer.</description>
		<graphicData>
		  <texPath>Apparel/NewRepublicOfficer/bigbelt/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <shaderType>CutoutComplex</shaderType>
		  <colorTwo>(250,250,250)</colorTwo> <!-- white -->
		</graphicData>
		<statBases>
			<Mass>4</Mass>
			<MarketValue>170</MarketValue>
			<MaxHitPoints>100</MaxHitPoints>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Heat>0.2</ArmorRating_Heat>
			<Insulation_Cold>15</Insulation_Cold>
			<EquipDelay>3</EquipDelay>
			
			<WorkToMake>5000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
		  <VEF_MassCarryCapacity>5</VEF_MassCarryCapacity>
		</equippedStatOffsets>
		
		<recipeMaker>
			<researchPrerequisite>guy762_ResearchKotOR_sith</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
		  <Synthread>75</Synthread>
		  <Plasteel>15</Plasteel>
		</costList>
		
		<apparel>
		  <tags Inherit="False">
			<li>NewRepublic_guard</li>
			<li>SWGCWSpecificApparelItem_BigBeltNewRepublicOfficerUniform</li>
		  </tags>
		  <layers Inherit="False">
			<li>Middle</li>
			<li>OnSkin</li>
		  </layers>
		  
		  <wornGraphicPath>Apparel/NewRepublicOfficer/bigbelt/Apparel</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  <defaultOutfitTags Inherit="False">
			<li>Worker</li>
		  </defaultOutfitTags>
		</apparel>
		<tradeTags>
			<li>guy762TT_SEArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(70,90,125)</only>       <!--K1 blue-->
				</li>
			</options>
		</colorGenerator>
	  </ThingDef>
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  

	  
	  
