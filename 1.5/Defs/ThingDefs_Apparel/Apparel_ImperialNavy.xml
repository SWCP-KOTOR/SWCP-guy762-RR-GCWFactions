	<ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_ImpNavyCommandoArmor</defName>
		<label>navy commando armor</label>
		<description>.</description>
		<graphicData>
		  <texPath>SWApparel/ImpNavyCommando/Apparel</texPath>
