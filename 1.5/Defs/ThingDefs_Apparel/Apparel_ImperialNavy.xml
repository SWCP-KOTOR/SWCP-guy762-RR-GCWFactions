<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- combat suit stat level -->
	
  <ThingDef ParentName="KotORArmorModdable_hard">
	<defName>guy762_TIEpilotArmor</defName>
	<label>TIE pilot flight armor</label>
	<description>This combat-ready flight vest provides additional protection against vacuum for limited periods. Its many models appeal to a wide range of users, from military pilots and mercenaries to fringe explorers and space pirates. Built-in grav thrusters also assist with movement in open space.</description>
	<graphicData>
	  <texPath>SWApparel/TIEPilot/Apparel</texPath>
	  <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
	</graphicData>
	<statBases>
		<Mass>3</Mass>
		<MarketValue>500</MarketValue>
		
		<MaxHitPoints>225</MaxHitPoints>
		<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
		<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
		<ArmorRating_Heat>0.55</ArmorRating_Heat>
		<Insulation_Cold>100</Insulation_Cold>
		<Insulation_Heat>100</Insulation_Heat>
		<EquipDelay>5</EquipDelay>
	</statBases>
	<equippedStatOffsets>
		<IncomingDamageFactor>-0.05</IncomingDamageFactor>
		<VacuumSpeedMultiplier MayRequire="kentington.saveourship2">2</VacuumSpeedMultiplier>
		<DecompressionResistance MayRequire="kentington.saveourship2">0.125</DecompressionResistance>
		
		<PilotingAbility MayRequire="Ludeon.RimWorld.Odyssey">0.2</PilotingAbility>
	</equippedStatOffsets>
	
	<apparel>
	  <tags Inherit="False">
		<li>RemnantEmpire_TIEpilot</li>
		<li>SWGCWSpecificApparelItem_ImperialTIEPilotArmor</li>
	  </tags>
	  <wornGraphicPath>SWApparel/TIEPilot/Apparel</wornGraphicPath>
	  <useWornGraphicMask>true</useWornGraphicMask>
	  <defaultOutfitTags Inherit="False">
		<li>Worker</li>
	  </defaultOutfitTags>
	  <layers Inherit="False">
		<li>Middle</li>
	  </layers>
	  <bodyPartGroups Inherit="False">
		<li>Torso</li>
	  </bodyPartGroups>
	</apparel>
	<tradeTags>
		<li>guy762TT_KotORArmor</li>
		<li>guy762TT_KotORArmor_space</li>
		<li>guy762TT_KotORArmor_powered</li>
	</tradeTags>
	<colorGenerator Class="ColorGenerator_Options" Inherit="False">
		<options>
			<li>
				<weight>15</weight>
				<only>(40,40,40)</only>
			</li>
		</options>
	</colorGenerator>
  </ThingDef>
	  
	  
	
	
