<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	
	
	
	
	
	<HediffDef MayRequire="Ludeon.RimWorld.Royalty" Name="SWCP_StealthMode">
		<defName>SWCP_StealthMode</defName>
		<label>stealth field</label>
		<description>A camouflage field that hides the user. Combat is disabled while this is active, but performing mundane tasks are not. Movement speed is also reduced while active.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Invisibility">
				<visibleToPlayer>true</visibleToPlayer>
			</li>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDef>SWCP_ExitStealthModeWithSneakAttack</abilityDef>
			</li>
			
			<li Class="HediffCompProperties_RemoveIfApparelDropped" />
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
		</comps>
		<stages>
			<li>
				<label>active</label>
				<minSeverity>0</minSeverity>
				<becomeVisible>true</becomeVisible>
				<disabledWorkTags>Violent</disabledWorkTags>
				<statFactors>
					<MoveSpeed>0.5</MoveSpeed>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	<AbilityDef>
		<defName>SWCP_ExitStealthModeWithSneakAttack</defName>
		<label>sneak attack (exit stealth)</label>
		<description>Deactivate an active stealth field or Force camouflage ability.</description>
		<iconPath>UI/SneakAttack</iconPath>
		<!--hotKey>Misc12</hotKey-->
		<writeCombatLog>True</writeCombatLog>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<aiCanUse>true</aiCanUse>
		<targetRequired>false</targetRequired>
		<statBases>
			<Ability_Duration>2</Ability_Duration> <!-- this is in seconds, not ticks -->
		</statBases>
		<verbProperties>
		  <verbClass>Verb_CastAbility</verbClass>
		  <range>-1</range>
		  <drawAimPie>false</drawAimPie>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWCP_SneakAttack</hediffDef>
				<onlyApplyToSelf>True</onlyApplyToSelf>
				<replaceExisting>true</replaceExisting>
				<!-- <applicableToMechs>True</applicableToMechs> -->
				<!-- <durationMultiplier>HuntingStealth</durationMultiplier> -->
			</li>
			
			<li Class="EBSGFramework.CompProperties_AbilityRemoveMultipleHediffs">
				<compClass>EBSGFramework.CompAbilityEffect_RemoveMultipleHediffs</compClass>
				<hediffs>
					<li>SWCP_StealthMode</li>
					
					<li>SWPotF_TacticAbilityHediff_AmbushWaiting</li>
					
					<!-- <li>SWPotF_hediff_ForceCloak</li> -->
					<!-- <li>SWPotF_hediff_KnightCloak</li> -->
					<!-- <li>SWPotF_hediff_MstCloak</li> -->
					
					<!-- <li>guy762_StealthField</li> -->
					<!-- <li>guy762_StealthField_sixty</li> -->
					<!-- <li>guy762_StealthField_twomin</li> -->
					<!-- <li>guy762_StealthField_threemin</li> -->
					<!-- <li>guy762_StealthField_fourmin</li> -->
					
					<!-- <li>guy762_StealthField_defel</li> -->
				</hediffs>
				<recursiveChecks>3</recursiveChecks> <!--No reason to have this, but maybe I'm paranoid-->
			</li>
			
			<li Class="CompProperties_AbilityFleckOnTarget">
				<sound>kotorsound_cloak</sound>
			</li>
		</comps>
	</AbilityDef>
	
	
	<HediffDef>
        <defName>SWCP_SneakAttack</defName>
        <label>Sneak Attack</label>
        <description>This pawn is attacking from a hidden position.</description>
		<defaultLabelColor>(255,255,135)</defaultLabelColor> <!-- soft yellow -->
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <stages>
            <li>
				<becomeVisible>true</becomeVisible>
				<statFactors>
					<MeleeHitChance>10</MeleeHitChance>
					<MeleeDamageFactor>3</MeleeDamageFactor>
					
					<ShootingAccuracyPawn>10</ShootingAccuracyPawn>
					<AimingDelayFactor>0.1</AimingDelayFactor>
				</statFactors>
				<!-- <statOffsets> -->
				<!-- </statOffsets> -->
			</li>
        </stages>
        <comps>
			<li Class="SWCP_Misc.HediffCompProperties_DisappearsOnDowned"/>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
            <li Class="HediffCompProperties_Disappears">
                <!-- <disappearsAfterTicks>60000</disappearsAfterTicks> -->
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
    </HediffDef>
	  
	 

</Defs>