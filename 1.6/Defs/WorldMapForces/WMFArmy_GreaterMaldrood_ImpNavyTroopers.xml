<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<RoyalTitlePermitDef>
		<defName>SWGCWPermit_GreaterMaldrood_SummonImpNavyTrooperForce</defName>
		<label>establish Imperial Navy trooper detachment</label>
		<description>Establish a detachment of Imperial Navy troopers on the world map.</description>
		<workerClass>ForcesMod.RoyalTitlePermitWorker_SpawnWorldObject</workerClass>
		
		<faction>guy762_SWWarlordsFaction_GreaterMaldrood</faction>
		<minTitle>SWGCWTitle_generic_lowflagofficer</minTitle>
		
		<permitPointCost>10</permitPointCost>
		<cooldownDays>40</cooldownDays>
		<usableOnWorldMap>true</usableOnWorldMap>
		<uiPosition>(9,7)</uiPosition>
		<royalAid>
			<favorCost>8</favorCost>
			<targetingRequireLOS>false</targetingRequireLOS>
		</royalAid>
		<layerBlacklist> <!-- orbitals and other planets don't work *yet* -->
			<li MayRequire="Ludeon.RimWorld.Odyssey">Orbit</li>
			<li MayRequire="MrHydralisk.LayeredAtmosphereOrbit">LAO_Surface_Luna</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Tatooine</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_TatooineOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OrdMantell</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OrdMantellOrbit</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_RhenVar</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_RhenVarOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Nevarro</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_NevarroOrbit</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Onderon</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OnderonOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Dxun</li>
		</layerBlacklist>
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<permitSpawnsWorldObject>SWCPArmyForce_GreaterMaldrood_ImpNavyTroopers</permitSpawnsWorldObject>
			</li>
			<li Class="SWCP_FlyingSloth_Misc.PermitExtension_SingleUse"><singleUse>true</singleUse></li>
		</modExtensions>
	</RoyalTitlePermitDef>
	
	
	
	
	
	
	
	<WorldObjectDef>
		<defName>SWCPArmyForce_GreaterMaldrood_ImpNavyTroopers</defName>
		<label>Imperial Navy trooper detachment</label>
		<description>A mobilized detachment of Imperial Navy troopers.\n\nThis gathering of armed forces is fully self-sufficient and requires no input from the player to support itself. This unit has its own supply officers and recruiters capable of keeping its supplies stocked and its number of battle-ready soldiers high. It can send forth a full deployment of NPC troops to assist you in battle every 10 days, and can also contribute small reinforcement squads and strike teams for your direct control every 1-3 days.\n\nImperial Navy troopers are an auxiliary fighting force meant to guard key naval installations and provide assistance to Imperial Army or Stormtrooper deployments only if absolutely necessary. These are not units trained for front-line deployment, though with the fracturing of the Empire after the Battle of Endor, they have been pressed into such service by the Greater Maldrood in order to make up for their shortage of Imperial Army personnel. Imperial Navy troopers are armed with light infantry armor and E-11 carbines, making them adequate at slowing down infantry assaults and pursuing minor objectives. However, their lack of heavy weapons leaves them utterly useless against any kind of armored target. These units are therefore best utilized as a defensive force that is positioned to be able to react to enemy assaults, or left as a supplemental force sent to clean up the aftermath of large sieges.</description>
		
		<texture>UI/WorldMapForceIcons_Armies/RotatedForSomeAnnoyingReason/WMFIcon_ImpNavyTrooper</texture><!--  for some dumbass reason the game rotates this texture 90 degrees clockwise -->
		<expandingIconTexture>UI/WorldMapForceIcons_Armies/WMFIcon_ImpNavyTrooper</expandingIconTexture>
		<fullyExpandedInSpace>true</fullyExpandedInSpace>
		<expandingIcon>true</expandingIcon>
		<expandingIconPriority>10</expandingIconPriority>
		<expandMore>true</expandMore>
		<useDynamicDrawer>true</useDynamicDrawer>
		<rotateGraphicWhenTraveling>false</rotateGraphicWhenTraveling>
		
		<worldObjectClass>ForcesMod.WorldObject_Force</worldObjectClass>
		<nameMaker>SWCPNameMaker_WorldMapForce_ImpNavyPlatoon_GreaterMaldrood</nameMaker>
		
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<abilityRange>8</abilityRange>
				<forceNameString>SWCPWorldMapForceNameString_ImpNavyPlatoon</forceNameString>
				<movementSpeedPerDay>36</movementSpeedPerDay>
				<abilities>
					<li>SWCPWMFAbility_GreaterMaldrood_SummonNPCRaid_ImpNavyTroopers_full</li>
					<li>SWCPWMFAbility_GreaterMaldrood_SummonPlayerUnits_ImpNavyTroopers_small</li>
					<li>SWCPWMFAbility_GreaterMaldrood_SummonPlayerUnits_ImpNavyTroopers_big</li>
					
					<li>SWCPWMFAbility_ArtilleryBombardment_antiVehicle</li>
					<li>SWCPWMFAbility_DestroySettlement</li>
				</abilities>
			</li>
		</modExtensions>
	</WorldObjectDef>
	
	
	
	
	
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_GreaterMaldrood_SummonNPCRaid_ImpNavyTroopers_full</defName>
		<label>deploy full detachment (NPC)</label>
		<description>Deploy the full detachment as friendly NPCs.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/GreaterMaldrood_ImpNavyTrooper_NPC</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 600,000 = 10 in-game days -->
		<cooldownTicks>600000</cooldownTicks>
		
		<faction>guy762_SWWarlordsFaction_GreaterMaldrood</faction>
		<relevantPawnKinds>
			<xSWMaldrood_NavyTrooper_26x>26</xSWMaldrood_NavyTrooper_26x>
			<xSWMaldrood_ArmyMedic_2x>2</xSWMaldrood_ArmyMedic_2x>
			<xSWMaldrood_ArmyLieutenant_2x>2</xSWMaldrood_ArmyLieutenant_2x>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_GreaterMaldrood_SummonPlayerUnits_ImpNavyTroopers_small</defName>
		<label>deploy reinforcement squad (Player)</label>
		<description>Deploy a player-controlled 6-man reinforcement squad.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/GreaterMaldrood_ImpNavyTrooper_PlayerSmall</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 60,000 = 1 in-game day -->
		<cooldownTicks>60000</cooldownTicks>
		
		<!-- <faction>PlayerColony</faction> -->
		<faction>guy762_GCWPlayerFaction_Invids</faction>
		<relevantPawnKinds>
			<xpSWMaldrood_NavyTrooper_playable>6</xpSWMaldrood_NavyTrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_GreaterMaldrood_SummonPlayerUnits_ImpNavyTroopers_big</defName>
		<label>deploy strike team (Player)</label>
		<description>Deploy a player-controlled 12-man strike team.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/GreaterMaldrood_ImpNavyTrooper_PlayerLarge</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 180,000 = 3 in-game days -->
		<cooldownTicks>180000</cooldownTicks>
		
		<!-- <faction>PlayerColony</faction> -->
		<faction>guy762_GCWPlayerFaction_Invids</faction>
		<relevantPawnKinds>
			<xpSWMaldrood_NavyTrooper_playable>12</xpSWMaldrood_NavyTrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	
	
	
	






	
	
	
