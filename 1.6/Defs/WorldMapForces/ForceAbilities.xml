<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<ForcesMod.ForceAbilityDef>
		<defName>GUY_DestroySettlement</defName>
		<label>destroy settlement</label>
		<description>Order a settlement be destroyed.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_DestroySettlement</workerClass>
