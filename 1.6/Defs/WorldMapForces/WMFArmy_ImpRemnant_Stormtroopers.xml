<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<RoyalTitlePermitDef>
		<defName>SWGCWPermit_ImpRemnant_SummonStormtrooperForce</defName>
		<label>establish Stormtrooper platoon</label>
		<description>Establish a platoon of Imperial Stormtroopers on the world map.</description>
		<workerClass>ForcesMod.RoyalTitlePermitWorker_SpawnWorldObject</workerClass>
		
		<faction>guy762_SWWarlordsFaction_ImpRemnant</faction>
		<minTitle>SWGCWTitle_generic_highflagofficer</minTitle>
		
		<permitPointCost>10</permitPointCost>
		<cooldownDays>40</cooldownDays>
		<usableOnWorldMap>true</usableOnWorldMap>
		<uiPosition>(9,9)</uiPosition>
		<royalAid>
			<favorCost>8</favorCost>
			<targetingRequireLOS>false</targetingRequireLOS>
		</royalAid>
		<layerBlacklist> <!-- orbitals and other planets don't work *yet* -->
			<li MayRequire="Ludeon.RimWorld.Odyssey">Orbit</li>
			<li MayRequire="MrHydralisk.LayeredAtmosphereOrbit">LAO_Surface_Luna</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Tatooine</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_TatooineOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OrdMantell</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OrdMantellOrbit</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_RhenVar</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_RhenVarOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Nevarro</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_NevarroOrbit</li>
			
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Onderon</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_OnderonOrbit</li>
			<li MayRequire="SWCP.guy762.Taran.SWGalaxy.gbp">SWCPPlanetLayer_Dxun</li>
		</layerBlacklist>
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<permitSpawnsWorldObject>SWCPArmyForce_ImpRemnant_Stormtroopers</permitSpawnsWorldObject>
			</li>
			<li Class="SWCP_FlyingSloth_Misc.PermitExtension_SingleUse"><singleUse>true</singleUse></li>
		</modExtensions>
	</RoyalTitlePermitDef>
	
	
	
	
	
	
	
	<WorldObjectDef>
		<defName>SWCPArmyForce_ImpRemnant_Stormtroopers</defName>
		<label>Stormtrooper Platoon</label>
		<description>A deployed platoon of Imperial Stormtroopers.\n\nThis gathering of armed forces is fully self-sufficient and requires no input from the player to support itself. This unit has its own supply officers and recruiters capable of keeping its supplies stocked and its number of battle-ready soldiers high. It can send forth a full deployment of NPC troops to assist you in battle every 10 days, and can also contribute small reinforcement squads and strike teams for your direct control every 1-3 days.\n\nStormtroopers are the Empire's infamous elite infantry unit. Originally intended as a second-wave infantry force that can destroy key components of an enemy's defense, the skill and reputation of the Stormtrooper Corps has caused their duties on the battlefield to swell and replace most traditional Imperial Army units. Stormtroopers are now also employed as a first-wave vanguard, third-wave objective-pursuing commandos, and even as general security units, much to the chagrin of the other branches of Imperial government. Stormtroopers themselves are rigorously brainwashed to have complete unflinching loyalty to the Emperor, and as a result are usually a local Moff's priority choice for leading ground assaults that will gain favor from the Emperor when the after-action report is sent to Imperial Center. Equipped with a wide variety of heavy anti-infantry and anti-vehicle weapons, Stormtroopers are a versatile force that can efficiently deal with any threat. Their hyper-specialized blaster-resistant Plastoid medium armor offers them high protection against heat-based weapons equivalent to that of many heavy armors, though as a substantial drawback the armor is left quite vulnerable to blunt and piercing attacks. Thus, Stormtroopers are a prime general-purpose infantry unit, though special care should be taken when deploying them against opponents armed with slugthrowers or primatives with kinetic-based weapons.</description>
		
		<texture>UI/WorldMapForceIcons_Armies/RotatedForSomeAnnoyingReason/WMFIcon_Stormtrooper</texture><!--  for some dumbass reason the game rotates this texture 90 degrees clockwise -->
		<expandingIconTexture>UI/WorldMapForceIcons_Armies/WMFIcon_Stormtrooper</expandingIconTexture>
		<fullyExpandedInSpace>true</fullyExpandedInSpace>
		<expandingIcon>true</expandingIcon>
		<expandingIconPriority>10</expandingIconPriority>
		<expandMore>true</expandMore>
		<useDynamicDrawer>true</useDynamicDrawer>
		<rotateGraphicWhenTraveling>false</rotateGraphicWhenTraveling>
		
		<worldObjectClass>ForcesMod.WorldObject_Force</worldObjectClass>
		<nameMaker>SWCPNameMaker_WorldMapForce_StormtrooperPlatoon_ImpRemnant</nameMaker>
		
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<abilityRange>8</abilityRange>
				<forceNameString>SWCPWorldMapForceNameString_StormtrooperPlatoon</forceNameString>
				<movementSpeedPerDay>24</movementSpeedPerDay>
				<abilities>
					<li>SWCPWMFAbility_ImpRemnant_SummonNPCRaid_Stormtroopers_full</li>
					<li>SWCPWMFAbility_ImpRemnant_SummonPlayerUnits_Stormtroopers_small</li>
					<li>SWCPWMFAbility_ImpRemnant_SummonPlayerUnits_Stormtroopers_big</li>
					
					<li>SWCPWMFAbility_ArtilleryBombardment_antiVehicle</li>
					<li>SWCPWMFAbility_DestroySettlement</li>
				</abilities>
			</li>
		</modExtensions>
	</WorldObjectDef>
	
	
	
	
	
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_ImpRemnant_SummonNPCRaid_Stormtroopers_full</defName>
		<label>deploy full platoon (NPC)</label>
		<description>Deploy the full platoon as friendly NPCs.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_Stormtrooper_NPC</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 600,000 = 10 in-game days -->
		<cooldownTicks>600000</cooldownTicks>
		
		<faction>guy762_SWWarlordsFaction_ImpRemnant</faction>
		<relevantPawnKinds>
			<xSWImpRemnant_Stormtrooper_24x>24</xSWImpRemnant_Stormtrooper_24x>
			<xSWImpRemnant_StormtrooperSniper_4x>4</xSWImpRemnant_StormtrooperSniper_4x>
			<xSWImpRemnant_StormtrooperLightRepeater_6x>6</xSWImpRemnant_StormtrooperLightRepeater_6x>
			<xSWImpRemnant_StormtrooperHeavyRepeater_2x>2</xSWImpRemnant_StormtrooperHeavyRepeater_2x>
			<xSWImpRemnant_StormtrooperMissile_8x>8</xSWImpRemnant_StormtrooperMissile_8x>
			<xSWImpRemnant_StormtrooperOfficer_2x>2</xSWImpRemnant_StormtrooperOfficer_2x>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_ImpRemnant_SummonPlayerUnits_Stormtroopers_small</defName>
		<label>deploy reinforcement squad (Player)</label>
		<description>Deploy a player-controlled 6-man reinforcement squad.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_Stormtrooper_PlayerSmall</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 60,000 = 1 in-game day -->
		<cooldownTicks>60000</cooldownTicks>
		
		<faction>PlayerColony</faction>
		<relevantPawnKinds>
			<xpSWImpRemnant_Stormtrooper_playable>6</xpSWImpRemnant_Stormtrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWMFAbility_ImpRemnant_SummonPlayerUnits_Stormtroopers_big</defName>
		<label>deploy strike team (Player)</label>
		<description>Deploy a player-controlled 12-man strike team.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_Stormtrooper_PlayerLarge</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 180,000 = 3 in-game days -->
		<cooldownTicks>180000</cooldownTicks>
		
		<faction>PlayerColony</faction>
		<relevantPawnKinds>
			<xpSWImpRemnant_Stormtrooper_playable>12</xpSWImpRemnant_Stormtrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	
	
	
	






	
	
	
