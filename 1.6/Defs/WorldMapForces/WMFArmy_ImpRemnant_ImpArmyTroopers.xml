<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<RoyalTitlePermitDef>
		<defName>SWGCWPermit_ImpRemnant_SummonImpArmyForce</defName>
		<label>establish Imperial Army platoon</label>
		<description>Establish a platoon of Imperial Army troopers on the world map.</description>
		<workerClass>ForcesMod.RoyalTitlePermitWorker_SpawnWorldObject</workerClass>
		
		<faction>guy762_SWWarlordsFaction_ImpRemnant</faction>
		<minTitle>SWGCWTitle_generic_lowflagofficer</minTitle>
		
		<permitPointCost>1</permitPointCost>
		<cooldownDays>40</cooldownDays>
		<usableOnWorldMap>true</usableOnWorldMap>
		<uiPosition>(9,9)</uiPosition>
		<royalAid>
			<favorCost>8</favorCost>
			<targetingRequireLOS>false</targetingRequireLOS>
		</royalAid>
		<layerBlacklist>
			<li MayRequire="Ludeon.RimWorld.Odyssey">Orbit</li>
		</layerBlacklist>
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<permitSpawnsWorldObject>SWCPWorldMapForce_ImpArmyTroopers_ImpRemnant</permitSpawnsWorldObject>
			</li>
			<li Class="SWCP_FlyingSloth_Misc.PermitExtension_SingleUse"><singleUse>true</singleUse></li>
		</modExtensions>
	</RoyalTitlePermitDef>
	
	
	
	
	
	
	
	<WorldObjectDef>
		<defName>SWCPWorldMapForce_ImpArmyTroopers_ImpRemnant</defName>
		<label>Imperial Army Platoon</label>
		<description>A deployed platoon of Imperial Army troopers.</description>
		<worldObjectClass>ForcesMod.WorldObject_Force</worldObjectClass>
		<texture>UI/WorldMapForceIcons_Armies/WMFIcon_ImpArmyTrooper</texture>
		<nameMaker>SWCPNameMaker_WorldMapForce_ImpArmyPlatoon</nameMaker>
		<useDynamicDrawer>true</useDynamicDrawer>
		<modExtensions>
			<li Class="ForcesMod.ForceAbilitiesModExtension">
				<abilityRange>8</abilityRange>
				<forceNameString>SWCPWorldMapForceNameString_ImpArmyPlatoon</forceNameString>
				<movementSpeedPerDay>12</movementSpeedPerDay>
				<abilities>
					<li>SWCPWorldMapForceAbility_SummonNPCRaid_ImpArmyTroopers_full</li>
					<li>SWCPWorldMapForceAbility_SummonPlayerUnits_ImpArmyTroopers_small</li>
					<li>SWCPWorldMapForceAbility_SummonPlayerUnits_ImpArmyTroopers_big</li>
					
					<li>GUY_Bombardment</li>
					<li>GUY_DestroySettlement</li>
				</abilities>
			</li>
		</modExtensions>
	</WorldObjectDef>
	
	
	
	
	
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWorldMapForceAbility_SummonNPCRaid_ImpArmyTroopers_full</defName>
		<label>deploy full platoon (NPC)</label>
		<description>Deploy the full platoon as friendly NPCs.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_ImpArmyTrooper_NPC</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 600,000 = 10 in-game days -->
		<cooldownTicks>600000</cooldownTicks>
		
		<faction>guy762_SWWarlordsFaction_ImpRemnant</faction>
		<relevantPawnKinds>
			<xSWImpRemnant_ArmyTrooper_40x>40</xSWImpRemnant_ArmyTrooper_40x>
			<xSWImpRemnant_ArmyGrenadier_4x>4</xSWImpRemnant_ArmyGrenadier_4x>
			<xSWImpRemnant_ArmyIon_1x>1</xSWImpRemnant_ArmyIon_1x>
			<xSWImpRemnant_ArmyMedic_2x>2</xSWImpRemnant_ArmyMedic_2x>
			<xSWImpRemnant_ArmyLieutenant_2x>2</xSWImpRemnant_ArmyLieutenant_2x>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWorldMapForceAbility_SummonPlayerUnits_ImpArmyTroopers_small</defName>
		<label>deploy reinforcement squad (Player)</label>
		<description>Deploy a player-controlled 6-man reinforcement squad.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_ImpArmyTrooper_PlayerSmall</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 60,000 = 1 in-game day? -->
		<cooldownTicks>60000</cooldownTicks>
		
		<faction>PlayerColony</faction>
		<relevantPawnKinds>
			<xpSWImpRemnant_ArmyTrooper_playable>6</xpSWImpRemnant_ArmyTrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	<ForcesMod.ForceAbilityDef>
		<defName>SWCPWorldMapForceAbility_SummonPlayerUnits_ImpArmyTroopers_big</defName>
		<label>deploy strike team (Player)</label>
		<description>Deploy a player-controlled 12-man strike team.</description>
		<workerClass>ForcesMod.ForceAbilityWorker_SpawnRaid</workerClass>
		
		<iconPath>UI/WorldMapForceIcons_Deployments/ImpRemnant_ImpArmyTrooper_PlayerLarge</iconPath>
		<requiresTarget>true</requiresTarget>
		
		<!-- 180,000 = 3 in-game days? -->
		<cooldownTicks>180000</cooldownTicks>
		
		<faction>PlayerColony</faction>
		<relevantPawnKinds>
			<xpSWImpRemnant_ArmyTrooper_playable>12</xpSWImpRemnant_ArmyTrooper_playable>
		</relevantPawnKinds>
	</ForcesMod.ForceAbilityDef>
	
	
	
	
	






	
	
	
	<RulePackDef>
		<defName>SWCPNameMaker_WorldMapForce_ImpArmyPlatoon</defName>
		<!-- <rulePack> -->
			<!-- <rulesStrings> -->
				<!-- <li>r_name-&gt;force 1</li> -->
			<!-- </rulesStrings> -->
		<!-- </rulePack> -->
		<include>
			<li>guy762_NamerFactionFiles_GenericFleetName</li>
			<li>guy762_NamerFactionFiles_ImpRemnantPlanets</li>
		</include>
		<rulePack>
		  <rulesStrings>
			<li>r_name(p=12)->[SWFN_BigFleetNumber] [SWIRFN_AnyPlanet] [army]</li>
			
			<li>army->Army</li>
		  </rulesStrings>
		</rulePack>
	</RulePackDef>

	
</Defs>