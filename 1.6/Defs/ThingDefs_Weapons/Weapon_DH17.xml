<Defs>

	
	<ThingDef ParentName="KotORRangedModdable_OffHand">
		<defName>guy762_DH17pistol</defName>
		<label>DH-17 blaster pistol</label>
		<description>The DH-17 pistol is favored by many private security and planetary defense forces throughout the galaxy for its ability to be used as both a close-quarters repeater and as a precision targeting pistol. It is an effective weapon in staving off pirate boarding parties in tight starship hallways as well as taking potshots at suspected hostiles in more open environments. This versatility has made it an ideal sidearm for most New Republic personnel, where pilots, security officers, and clandestine agents alike employ these blaster pistols to combat elements of the Imperial Remnant.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/DH17Pistol</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>kotorsound_select_pistol</soundInteract>
		<statBases>
			<MarketValue>550</MarketValue>
			<Mass>1</Mass>
			<AccuracyTouch>0.85</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.55</AccuracyMedium>
			<AccuracyLong>0.45</AccuracyLong>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>0.7</RangedWeapon_DamageMultiplier>
		</statBases>
		
		<weaponTags>
			<li>SWRanged_DH17pistol</li>
			<li>SWRanged_AnyCommonPistol</li>
			<li>SWRanged_AnyRepeaterPistol</li>
			<li>SWRanged_RebelAgentPistolMix</li>
			<li>SWKotORWeaponCategoryTag_pistol</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>0.5</warmupTime>
				<defaultCooldownTime>2</defaultCooldownTime>
				<range>20</range>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
				<soundCast>kotorsound_RebelBlaster_mix</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
			<li>
				<label>sniper shot</label>
				<!--description>Fire a single bolt with increased range and armor penetration.</description>
				<iconPath>UI/Sniper_Shot</iconPath-->
				<commandIcon>UI/Sniper_Shot</commandIcon>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_sniper</defaultProjectile>
				<warmupTime>2</warmupTime>
				<defaultCooldownTime>1</defaultCooldownTime>
				<range>30</range>
				<accuracyMedium>0.95</accuracyMedium>
				<accuracyLong>0.90</accuracyLong>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_RebelBlaster</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				<bodypartTagTarget>ConsciousnessSource</bodypartTagTarget>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
