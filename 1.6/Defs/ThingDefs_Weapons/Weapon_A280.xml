<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	
	
	
	<ThingDef ParentName="SWCPRangedMakeableNoQuality_TwoHand">
		<defName>guy762_A280_c</defName>
		<label>A280-C blaster rifle</label>
		<description>Widely considered one of the Rebel Alliance's finest pieces of equipment, the A280-C offers Rebel soldiers everything the E-11 can't: range, precision, and power.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/A280C</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedAngleOffset>45</equippedAngleOffset>
		<soundInteract>kotorsound_select_carbine</soundInteract>
		<statBases>
			<MarketValue>1800</MarketValue>
			<Mass>5</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
			<AccuracyMedium>0.90</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>1.3</RangedWeapon_DamageMultiplier>
		</statBases>
		<equippedStatOffsets>
			<SWCPStat_InfantryWeaponClass_longrange>1</SWCPStat_InfantryWeaponClass_longrange>
		</equippedStatOffsets>
		
		<weaponTags>
			<li>SWRanged_A280Crifle</li>
			<li>SWRanged_AnyCommonRifle</li>
			<li>SWKotORWeaponCategoryTag_rifle</li>
			
			<li>SWCPWeaponCategoryTag_InfantryRifle</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
			<li>guy762TT_GCWWeapon_Illegal</li>
			<li>guy762TT_GCWWeapon_PDFsurplus</li>
			<li>guy762TT_GCWWeapon_RebelSurplus</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>0.75</warmupTime>
				<defaultCooldownTime>0.5</defaultCooldownTime>
				<range>30</range>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_RebelBlaster</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
			<li>
				<label>rapid shot</label>
				<!--description>Fire extra bolts with reduced accuracy.</description>
				<iconPath>UI/Rapid_Shot</iconPath-->
				<commandIcon>UI/Rapid_Shot</commandIcon>
				<!-- <verbClass>Verb_Shoot</verbClass> -->
				<verbClass>SWCP_Misc.Verb_SuppressingFire</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>3</warmupTime>
				<defaultCooldownTime>3.5</defaultCooldownTime>
				<range>25</range>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<burstShotCount>6</burstShotCount>
				<forcedMissRadius>1.75</forcedMissRadius>
				<soundCast>kotorsound_RebelBlaster</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>

		<equippedDistanceOffset >0.25</equippedDistanceOffset >
		<comps>
            <li Class="FCP.Core.CompProperties_PositionAttributes">
                <HeldDrawOffset>(0.125, -0.125)</HeldDrawOffset>
            </li>
        </comps>
		<modExtensions>
			<li Class="IgnoreConfigErrors.Ignore_ForcedMissRadius" />
			<li Class="SWCP_Misc.VerbProperties_SuppressingFire" >
				<hediffDef>SWCPHediff_Suppression</hediffDef>
				<severityToAdd>1</severityToAdd>
			</li>
		</modExtensions>
	</ThingDef>
	

	
	
	

</Defs>