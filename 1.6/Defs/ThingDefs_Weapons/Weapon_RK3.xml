<Defs>

	
	<ThingDef ParentName="SWCPRangedMakeableNoQuality_OffHand">
		<defName>guy762_RK3pistol</defName>
		<label>RK-3 blaster pistol</label>
		<description>The Merr-Sonn RK-3 pistol was designed as an accurate, general-purpose sidearm to be issued to all Imperial military officers regardless of branch. While other pistols employed by the Empire (like the SE-14 or DH-17) were designed to fill a specific combat role if necessary, the RK-3 was designed as a simple self-defense weapon capable of achieving above holdout-level performace.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/RK3</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>kotorsound_select_pistol</soundInteract>
		<statBases>
			<MarketValue>650</MarketValue>
			<Mass>1</Mass>
			<AccuracyTouch>0.90</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.60</AccuracyMedium>
			<AccuracyLong>0.50</AccuracyLong>
			<RangedWeapon_Cooldown>0.5</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>0.9</RangedWeapon_DamageMultiplier>
		</statBases>
		<equippedStatOffsets>
			<SWCPStat_InfantryWeaponClass_shortrange>1</SWCPStat_InfantryWeaponClass_shortrange>
		</equippedStatOffsets>
		
		<weaponTags>
			<li>SWRanged_RK3pistol</li>
			<li>SWRanged_AnyRarePistol</li>
			<li>SWKotORWeaponCategoryTag_pistol</li>
			<li>SWGCWBaseLoot_ImperialWeapons_common</li>
			
			<li>SWCPWeaponCategoryTag_LightPistol</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
			<li>guy762TT_GCWWeapon_CivLegal</li>
			<li>guy762TT_GCWWeapon_ImpSurplus</li>
		</tradeTags>
