<Defs>

	
	
	<ThingDef ParentName="KotORRangedModdable_TwoHand">
		<defName>guy762_E10rifle</defName>
		<label>E-10 blaster rifle</label>
		<description>A precursor to the popular E-11, the E-10 was designed as a cheap, expendable infantry rifle similar to the Separatists' E-5. The E-10 offers improved damage and range over the E-5, and though its performance may pale in comparison to nearly any other blaster rifle, this inadequacy is considered a moot point when legions of Imperial Army conscripts can pelt a target with a torrent of blaster fire with these weapons and achieve largely the same results.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/E10</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedAngleOffset>45</equippedAngleOffset>
		<soundInteract>kotorsound_select_slug</soundInteract>
		<statBases>
			<MarketValue>300</MarketValue>
			<Mass>3.5</Mass>
			<AccuracyTouch>0.30</AccuracyTouch>
			<AccuracyShort>0.40</AccuracyShort>
			<AccuracyMedium>0.70</AccuracyMedium>
			<AccuracyLong>0.60</AccuracyLong>
			<RangedWeapon_Cooldown>0.75</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>1</RangedWeapon_DamageMultiplier>
		</statBases>
		
		<weaponTags>
			<li>SWRanged_E10rifle</li>
			<li>SWRanged_AnyCommonRifle</li>
			<li>SWKotORWeaponCategoryTag_rifle</li>
			<li>SWGCWBaseLoot_ImperialWeapons_common</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>0.5</warmupTime>
				<range>30</range>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_E11carbine</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
