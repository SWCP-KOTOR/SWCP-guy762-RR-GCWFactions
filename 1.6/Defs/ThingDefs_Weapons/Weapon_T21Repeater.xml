<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	
	
	
	<ThingDef ParentName="KotORRangedModdable_TwoHand">
		<defName>guy762_T21repeater</defName>
		<label>T-21 heavy repeating blaster</label>
		<description>Seeking to further prove the versatility of Stormtrooper infantry doctrine, the Imperial Stormtrooper corps commissioned BlasTech to design a heavy blaster capable of functioning both as an anti-tank rifle and as a squad automatic weapon to effectively counter a wider variety of targets. The result was the T-21, a cumbersome but powerful weapon used to great effect in counter-insurgency operations.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<!-- <texPath>Weapons/T21_wood</texPath> -->
			<texPath>Weapons/T21</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<equippedAngleOffset>45</equippedAngleOffset>
		<soundInteract>kotorsound_select_hvyrep</soundInteract>
		<statBases>
			<MarketValue>2000</MarketValue>
			<Mass>10</Mass>
			<AccuracyTouch>0.50</AccuracyTouch>
			<AccuracyShort>0.60</AccuracyShort>
			<AccuracyMedium>0.70</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>1.4</RangedWeapon_DamageMultiplier>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.2</MoveSpeed>
		</equippedStatOffsets>
		
		<weaponTags>
			<li>SWRanged_T21repeater</li>
			<li>SWRanged_AnyHeavyRifle</li>
			<li>SWRanged_AnyAntiVehicleRifle</li>
			<li>SWKotORWeaponCategoryTag_heavyranged</li>
			<li>SWGCWBaseLoot_ImperialWeapons_uncommon</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
			<li>guy762TT_GCWWeapon_Illegal</li>
			<li>guy762TT_GCWWeapon_ImpSurplus</li>
		</tradeTags>
		<verbs>
			<li>
				<label>master power blast</label>
				<!-- <description>Fire a single overcharged bolt.</description> -->
				<!-- <iconPath>UI/Master_Power_Blast</iconPath> -->
				<commandIcon>UI/Master_Power_Blast</commandIcon>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_mstheavy</defaultProjectile>
				<warmupTime>5</warmupTime>
				<defaultCooldownTime>7.5</defaultCooldownTime>
				<range>40</range>
				<ticksBetweenBurstShots>18</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<!--soundAiming>kotorsound_powercharge</soundAiming-->
				<soundCast>kotorsound_EaWturbolaser</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
			</li>
			<li>
				<label>adv. rapid shot</label>
				<!-- <description>Fire extra bolts with reduced accuracy.</description> -->
				<!-- <iconPath>UI/Improved_Rapid_Shot</iconPath> -->
				<commandIcon>UI/Improved_Rapid_Shot</commandIcon>
				<!-- <verbClass>Verb_Shoot</verbClass> -->
				<verbClass>SWCP_Misc.Verb_SuppressingFire</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>4</warmupTime>
				<defaultCooldownTime>4</defaultCooldownTime>
				<range>30</range>
				<ticksBetweenBurstShots>8</ticksBetweenBurstShots>
				<burstShotCount>12</burstShotCount>
				<forcedMissRadius>2</forcedMissRadius>
				<soundCast>kotorsound_T21repeater</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>

		<equippedDistanceOffset >0.125</equippedDistanceOffset >
		<!-- <comps> -->
            <!-- <li Class="SWCP.Core.CompProperties_PositionAttributes"> -->
                <!-- <HeldDrawOffset>(0.125, -0.125)</HeldDrawOffset> -->
            <!-- </li> -->
        <!-- </comps> -->
		<modExtensions>
			<li Class="IgnoreConfigErrors.Ignore_ForcedMissRadius" />
			<li Class="SWCP_Misc.VerbProperties_SuppressingFire" >
				<hediffDef>SWCPHediff_Suppression</hediffDef>
				<severityToAdd>2</severityToAdd>
			</li>
		</modExtensions>
	</ThingDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	<ThingDef ParentName="KotORRangedModdable_TwoHand">
		<defName>guy762_T21Bheavyrifle</defName>
		<label>T-21B heavy blaster</label>
		<description>A more role-specific variation on the T-21 platform, the T-21B is a powerful anti-armor rifle inspired by the B2-HA Super Battle Droid's integrated blaster cannon arm. It is designed to be used alongside lighter repeating blasters such as the TL-50 or E-22, a combination capable of responding to both vehicle and infantry threats far quicker than units armed with the original T-21.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/T21_B</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<equippedAngleOffset>45</equippedAngleOffset>
		<soundInteract>kotorsound_select_hvyrep</soundInteract>
		<statBases>
			<MarketValue>5000</MarketValue>
			<Mass>10</Mass>
			<AccuracyTouch>0.50</AccuracyTouch>
			<AccuracyShort>0.60</AccuracyShort>
			<AccuracyMedium>0.70</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>6.5</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>1.6</RangedWeapon_DamageMultiplier>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.2</MoveSpeed>
		</equippedStatOffsets>
		
		<weaponTags>
			<li>SWRanged_T21Bheavy</li>
			<li>SWRanged_AnyHeavyRifle</li>
			<li>SWRanged_AnyAntiVehicleRifle</li>
			<li>SWKotORWeaponCategoryTag_heavyranged</li>
			<li>SWGCWBaseLoot_ImperialWeapons_rare</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
			<li>guy762TT_GCWWeapon_ExoticIllegal</li>
			<li>guy762TT_GCWWeapon_ImpSurplus</li>
		</tradeTags>
		<verbs>
			<li>
				<label>power burst</label>
				<!-- <description>Fire a single overcharged bolt.</description> -->
				<!-- <iconPath>UI/Power_Blast</iconPath> -->
				<commandIcon>UI/Burst_Power_Blast</commandIcon>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_heavy</defaultProjectile>
				<warmupTime>5.5</warmupTime>
				<defaultCooldownTime>6</defaultCooldownTime>
				<range>30</range>
				<ticksBetweenBurstShots>40</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
				<!--soundAiming>kotorsound_powercharge</soundAiming-->
				<soundCast>kotorsound_B2SBD_heavygun</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>

		<equippedDistanceOffset >0.125</equippedDistanceOffset >
