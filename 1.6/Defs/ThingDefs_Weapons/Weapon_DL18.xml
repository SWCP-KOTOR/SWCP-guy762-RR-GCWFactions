<Defs>

	
	<ThingDef ParentName="KotORRangedModdable_OffHand">
		<defName>guy762_DL18pistol</defName>
		<label>DL-18 blaster pistol</label>
		<description>First designed more than a century ago, the DL-18 is still favored today by many "underworld-types" as a cheap sidearm capable of reasonable levels of precision targeting.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/DL18</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>kotorsound_select_pistol</soundInteract>
		<statBases>
			<MarketValue>100</MarketValue>
			<Mass>1</Mass>
			<AccuracyTouch>0.75</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.45</AccuracyMedium>
			<AccuracyLong>0.35</AccuracyLong>
			<RangedWeapon_Cooldown>0.5</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>0.7</RangedWeapon_DamageMultiplier>
		</statBases>
		
		<weaponTags>
			<li>SWRanged_DL18pistol</li>
			<li>SWRanged_AnyCommonPistol</li>
			<li>SWKotORWeaponCategoryTag_pistol</li>
		</weaponTags>
		<tradeTags>
			<li>guy762TT_GCWRanged</li>
			<li>guy762TT_GCWWeapon_CivLegal</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_default</defaultProjectile>
				<warmupTime>0.5</warmupTime>
				<range>20</range>
				<ticksBetweenBurstShots>12</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_DL18pistol</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
			<li>
				<label>sniper shot</label>
				<!--description>Fire a single bolt with increased range and armor penetration.</description>
				<iconPath>UI/Sniper_Shot</iconPath-->
				<commandIcon>UI/Sniper_Shot</commandIcon>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORBlasterBolt_sniper</defaultProjectile>
				<warmupTime>2</warmupTime>
				<range>30</range>
				<accuracyMedium>0.95</accuracyMedium>
				<accuracyLong>0.90</accuracyLong>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<soundCast>kotorsound_DL18pistol_snipe</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				<bodypartTagTarget>ConsciousnessSource</bodypartTagTarget>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
