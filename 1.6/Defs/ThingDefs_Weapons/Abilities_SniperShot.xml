<Defs>
	
	<AbilityDef Name="guy762_AbilityWeapon_snipershot">
		<defName>guy762_AbilityWeapon_snipershot</defName>
		<label>sniper shot</label>
		<description>Fire a single bolt with increased armor penetration, range, and perfect accuracy (unless the target successfully dodges).</description>
		<iconPath>UI/Sniper_Shot</iconPath>
		<aiCanUse>true</aiCanUse>
		<showOnCharacterCard>false</showOnCharacterCard>
		<cooldownTicksRange>300</cooldownTicksRange>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>40</range>
			<warmupTime>4</warmupTime>
			<soundCast>kotorsound_impsniper</soundCast>
			<!-- <targetParams> -->
				<!-- <canTargetLocations>true</canTargetLocations> -->
			<!-- </targetParams> -->
			<bodypartTagTarget>ConsciousnessSource</bodypartTagTarget>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityLaunchProjectile">
				<projectileDef>SWProj_BlasterBoltSniper</projectileDef>
			</li>
		</comps>
	</AbilityDef>
	
	
	
