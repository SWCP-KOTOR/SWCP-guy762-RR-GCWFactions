	<ThingDef ParentName="KotORRangedModdable_TwoHand">
		<defName>guy762_TL50repeater</defName>
		<label>TL-50 repeating blaster</label>
		<description>Now considered the standard model of the TL-50 platform, this version of the popular repeater actually entered production much later than the earlier concussion-launcher-equipped model. This variant was designed to meet the needs of various Imperial special forces groups who felt the weak energy projectiles of original lacked "killing potential". The integrated concussion launcher has been removed in favor of a standard blaster firing chamber, offering per-shot damage similar to many contemporary blasters at the impressively high fire rate the TL-50 platform has become known for.</description>
		<techLevel>Spacer</techLevel>
		<thingClass>ThingWithComps</thingClass>
		<graphicData>
			<texPath>Weapons/TL50_black</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<!-- <graphicClass>ModularWeapons.Graphic_Modular</graphicClass> -->
		</graphicData>
		<soundInteract>kotorsound_select_carbine</soundInteract>
		<statBases>
			<MarketValue>1800</MarketValue>
			<Mass>6.5</Mass>
			<AccuracyTouch>0.55</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.50</AccuracyMedium>
			<AccuracyLong>0.40</AccuracyLong>
			<RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
			<RangedWeapon_DamageMultiplier>1</RangedWeapon_DamageMultiplier>
		</statBases>
		<weaponTags>
			<li>SWRanged_TL50blaster</li>
			<li>SWRanged_AnyRareRifle</li>
			<li>SWKotORWeaponCategoryTag_rifle</li>
