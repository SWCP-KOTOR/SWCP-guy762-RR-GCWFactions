		<verbs>
			<li>
				<label>sniper shot</label>
				<!-- <description>Fire a single bolt with increased range and armor penetration.</description> -->
				<!-- <iconPath>UI/Sniper_Shot</iconPath> -->
				<commandIcon>UI/Disruptor_Sniper_Shot</commandIcon>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>KotORDisruptorBolt_sniper</defaultProjectile>
				<warmupTime>2.5</warmupTime>
				<defaultCooldownTime>3</defaultCooldownTime>
				<range>30</range>
				<accuracyMedium>0.95</accuracyMedium>
				<accuracyLong>0.90</accuracyLong>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>1</burstShotCount>
				<!-- <soundCast>kotorsound_rebelsniper</soundCast> -->
				<soundCast>kotorsound_JKdisruptor</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<ai_IsWeapon>true</ai_IsWeapon>
				<onlyManualCast>false</onlyManualCast>
				<bodypartTagTarget>ConsciousnessSource</bodypartTagTarget>
			</li>
			<li>
				<label>disintegration beam</label>
				<commandIcon>UI/Disruptor_Beam</commandIcon>
				<!-- <verbClass>AthenaPort.Verb_ShootRunningBeam</verbClass> -->
				<verbClass>Verb_ShootBeam</verbClass>
				<showBurstShotStats>false</showBurstShotStats>
				<beamWidth>0.25</beamWidth>
				<beamMaxDeviation>0.1</beamMaxDeviation>
				<beamCurvature>0.1</beamCurvature>

				<hasStandardCommand>true</hasStandardCommand>
				<warmupTime>3</warmupTime>
				<defaultCooldownTime>8</defaultCooldownTime>
				
				<range>60</range>
				<minRange>1.5</minRange>
				
				<stopBurstWithoutLos>true</stopBurstWithoutLos>
				<ticksBetweenBurstShots>5</ticksBetweenBurstShots>
				<burstShotCount>8</burstShotCount>
				
				<beamDamageDef>guy762_BeamDamage_disruptor</beamDamageDef>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<soundCastBeam>kotorsound_disbeam</soundCastBeam>
				<beamGroundFleckDef>Fleck_BeamBurn</beamGroundFleckDef>
				<beamFleckChancePerTick>0.32</beamFleckChancePerTick>
				<beamMoteDef>guy762_Mote_DisruptorBeam</beamMoteDef>
				<beamEndEffecterDef>GraserBeam_End</beamEndEffecterDef>
				<beamChanceToStartFire>0</beamChanceToStartFire>
				<beamChanceToAttachFire>0</beamChanceToAttachFire>
				<beamLineFleckDef>Fleck_BeamSpark</beamLineFleckDef>
				<beamStartOffset>0.5</beamStartOffset>
				<beamLineFleckChanceCurve>
				<points>
					<li>(0, 0)</li>
					<li>(0.65, 0.4)</li>
					<li>(1, 0.75)</li>
				</points>
				</beamLineFleckChanceCurve>
				
				<!-- <ai_IsWeapon>false</ai_IsWeapon> -->
				<onlyManualCast>true</onlyManualCast>
			</li>
