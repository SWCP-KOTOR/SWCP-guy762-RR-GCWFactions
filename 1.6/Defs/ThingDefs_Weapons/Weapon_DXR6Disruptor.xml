			<MarketValue>6200</MarketValue>
			<Mass>5</Mass>
			<AccuracyTouch>0.50</AccuracyTouch>
			<AccuracyShort>0.60</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.85</AccuracyLong>
