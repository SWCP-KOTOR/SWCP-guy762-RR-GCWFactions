<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<DamageDef>
		<defName>guy762_ExplosiveDamage_Suppression</defName>
		<label>psychological suppression</label>
		<hasForcefulImpact>false</hasForcefulImpact>
		<makesBlood>false</makesBlood>
		<canInterruptJobs>false</canInterruptJobs>
		
		<isExplosive>true</isExplosive>
		<defaultDamage>1</defaultDamage>
		<additionalHediffs>
		  <li>
			<hediff>SWCPHediff_Suppression</hediff>
			<severityPerDamageDealt>1</severityPerDamageDealt>
		  </li>
		</additionalHediffs>
		
		<explosionCellFleck>PsycastAreaEffect</explosionCellFleck>
		<explosionColorEdge>(1, 0, 0, 0)</explosionColorEdge>
		<!-- <harmsHealth>false</harmsHealth> -->
		<soundExplosion>kotorsound_blastspecial_quieter</soundExplosion>
		
		<buildingDamageFactorImpassable>0</buildingDamageFactorImpassable>
		<buildingDamageFactorPassable>0</buildingDamageFactorPassable>
		<plantDamageFactor>0</plantDamageFactor>
		<corpseDamageFactor>0</corpseDamageFactor>
	</DamageDef>
	
	
	<ThingDef ParentName="guy762_BaseBullet_VehicleDamageReducer">
		<defName>SWProj_BlasterBolt_suppressive</defName>
		<label>blaster bolt (suppression)</label>
		<graphicData>
			<!-- <texPath>Weapons/Projectiles/blaster_red</texPath> -->
			<texPath>Weapons/Projectiles/blaster_purple</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile>
			<damageDef>guy762_ExplosiveDamage_Suppression</damageDef>
			<damageAmountBase>1</damageAmountBase>
			<armorPenetrationBase>1</armorPenetrationBase>
			<stoppingPower>10</stoppingPower>
			<speed>50</speed>
			<explosionRadius>2.5</explosionRadius>
		</projectile>
		<thingClass>Projectile_Explosive</thingClass>
	</ThingDef>
	
	
	
	
	
	<HediffDef>
		<defName>SWCPHediff_Suppression</defName>
		<label>Suppressed</label>
		<description>Negative psychological effects from being under suppressing blaster fire. Has a chance to give a mental break while active. Last for half an in-game hour.</description>
		<defaultLabelColor>(255,7,48)</defaultLabelColor> <!-- red -->
		<hediffClass>HediffWithComps</hediffClass>
		<maxSeverity>1.0</maxSeverity>
		<isBad>true</isBad>
		<stages>
		  <li>
			<statOffsets>
				<PainShockThreshold>-0.2</PainShockThreshold>
				<MentalBreakThreshold>0.5</MentalBreakThreshold>
			</statOffsets>
			<mentalStateGivers>
			  <li>
				<mentalState>PanicFlee</mentalState>
				<mtbDays>0.5</mtbDays>
			  </li>
			  <li>
				<mentalState>Wander_Psychotic</mentalState>
				<mtbDays>0.25</mtbDays>
			  </li>
			</mentalStateGivers>
		  </li>
		</stages>
		<comps>
		  <!--2,500 ticks per hour in game-->
		  <li Class="HediffCompProperties_Disappears">
			<disappearsAfterTicks>1250</disappearsAfterTicks>
			<showRemainingTime>True</showRemainingTime>
		  </li>
		  <li Class="HediffCompProperties_DisappearsOnDeath"/>
		  <!-- <li Class="HediffCompProperties_RemoveIfOtherHediff"> -->
			<!-- <hediffs> -->
				<!-- <li>SWPotF_hediff_ForceValor</li> -->
				<!-- <li>SWPotF_hediff_KnightValor</li> -->
				<!-- <li>SWPotF_hediff_MstValor</li> -->
			<!-- </hediffs> -->
		  <!-- </li> -->
		</comps>
	  </HediffDef>
	  
	  <ThoughtDef>
		<defName>guy762_ThoughtDef_Suppression</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>SWCPHediff_Suppression</hediff>
		<validWhileDespawned>false</validWhileDespawned>
		<developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
		<stages>
		  <li>
			<label>under suppressing fire</label>
			<description>I am about to die.</description>
			<baseMoodEffect>-100</baseMoodEffect>
		  </li>
		</stages>
		<lerpMoodToZero>true</lerpMoodToZero>
		<stackLimit>5</stackLimit>
	  </ThoughtDef>

	

</Defs>