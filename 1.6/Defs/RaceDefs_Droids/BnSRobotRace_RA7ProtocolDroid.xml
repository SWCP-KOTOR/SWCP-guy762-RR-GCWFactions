<?xml version="1.0" encoding="utf-8"?>
<Defs>

	
	<BackstoryDef>
		<defName>guy762_Backstory_RA7ProtocolDroid</defName>
		<title>RA-7 series protocol droid</title>
		<titleShort>protocol droid</titleShort>
		<description>This is an standard protocol droid, capable of many social tasks.</description>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>guy762BSC_Droid_RA7ProtocolDroid</li>
			<li>guy762BSC_Droid_all</li>
		</spawnCategories>
		<forcedTraits>
		  <Asexual>0</Asexual>
		  <Abrasive>0</Abrasive>
		</forcedTraits>
	</BackstoryDef>
	

	
	
	
	<ThingDef Name="SWCP_BnSDroidRace_RA7ProtocolDroid" ParentName="SWCP_BnSDroidRace_BASE">
		<defName>SWCP_BnSDroidRace_RA7ProtocolDroid</defName>
		<label>RA-7 series protocol droid</label>
		<description>.\n\nBy default, this droid is capable of the following work types:\n\n-Social\n-Intellectual\n-Hauling\n-Cleaning\n-Firefighting</description>

		<statBases>
			<MarketValue>1200</MarketValue>
			<RoyalFavorValue>1</RoyalFavorValue>
			
			<MoveSpeed>2</MoveSpeed>
			<VacuumSpeedMultiplier MayRequire="kentington.saveourship2">1</VacuumSpeedMultiplier>
			<ComfyTemperatureMin>-125</ComfyTemperatureMin>
			<ComfyTemperatureMax>125</ComfyTemperatureMax>
			
			<CarryingCapacity>100</CarryingCapacity>
			<VEF_MassCarryCapacity MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">100</VEF_MassCarryCapacity>
			<!-- <GlobalLearningFactor>0.5</GlobalLearningFactor> -->
			<WorkSpeedGlobal>1</WorkSpeedGlobal>
			
			<ArmorRating_Sharp>0.15</ArmorRating_Sharp>
			<ArmorRating_Blunt>0</ArmorRating_Blunt>
            <ArmorRating_Heat>0.25</ArmorRating_Heat>
            <InjuryHealingFactor>1</InjuryHealingFactor>
            <IncomingDamageFactor>0.95</IncomingDamageFactor>
			
            <BS_BatteryCharging>0.25</BS_BatteryCharging>
			<MaxNutrition>1.35</MaxNutrition>
			
            <StaggerDurationFactor MayRequire="Ludeon.RimWorld.Biotech">0.8</StaggerDurationFactor>
            <!-- <EMPResistance MayRequire="Ludeon.RimWorld.Biotech">0.9</EMPResistance> -->
			
			<Mass>135</Mass>
		</statBases>
		
		
		
		<race>
			<body>SWCP_BnSDroidBody_Protocol_AllTechSlots</body>

			<soundCallIntervalRange>1000~2000</soundCallIntervalRange>
			<lifeStageAges Inherit="False">
				<!-- We're not using custom defs because some Rimworld stuff is hardcoded to look for certain defs.
				 Better from a compatibility standpoint to simply make the stages exist but not be active. -->
				<li>
				  <def>HumanlikeBaby</def>
				  <minAge>0</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeChild</def>
				  <minAge>3</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li MayRequire="Ludeon.RimWorld.Biotech">
				  <def>HumanlikePreTeenager</def>
				  <minAge>9</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeTeenager</def>
				  <minAge>13</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeAdult</def>
				  <minAge>18</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				  
				  <!-- <soundAmbience>kotorsound_TsUD_ambient</soundAmbience> -->
				  <!-- <soundAngry>kotorsound_TsUD_angry</soundAngry> -->
				</li>
			</lifeStageAges>

		</race>

		<modExtensions>
		  <li Class="BigAndSmall.RaceExtension">
			<raceHediff>SWCP_DroidHediff_RA7ProtocolDroid</raceHediff>
		  </li>
		</modExtensions>
		
		<tools Inherit="False">
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<power>8.2</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<surpriseAttack>
				  <extraMeleeDamages>
					<li>
					  <def>Stun</def>
					  <amount>7</amount>
					</li>
				  </extraMeleeDamages>
				</surpriseAttack>
			  </li>
			  <li>
				<label>right fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<power>8.2</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<surpriseAttack>
				  <extraMeleeDamages>
					<li>
					  <def>Stun</def>
					  <amount>7</amount>
					</li>
				  </extraMeleeDamages>
				</surpriseAttack>
			</li>
		</tools>
		
		<butcherProducts>
            <KOTOR_AlloyDurasteel>20</KOTOR_AlloyDurasteel>
			<Plasteel>20</Plasteel>
			<ComponentIndustrial>8</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
			<TechprofSubpersonaCore>1</TechprofSubpersonaCore>
		</butcherProducts>
		<tradeTags>
            <li>SWCPTT_GCWDroids_protocol</li>
		</tradeTags>
	</ThingDef>
	
	
	
	
	
	
	
	<!-- <HediffDef ParentName="SWCP_DroidHediff_BASE"> -->
	<HediffDef>
		<defName>SWCP_DroidHediff_RA7ProtocolDroid</defName>
		<label>RA-7 series protocol droid</label>
		<description>.</description>
		
		<hediffClass>BigAndSmall.RaceTracker</hediffClass>
		
		<abilities>
			<!-- <li MayRequire="Ludeon.RimWorld.Ideology">ImmunityDrive</li> -->
		</abilities>
		
		<comps Inherit="False">
		  <li Class="BigAndSmall.CompProperties_Race">
			<!-- Cosmetic -->
			<bodyDefOverride>Male</bodyDefOverride>
			<bodyDefOverride_Female>Male</bodyDefOverride_Female>
			<disableHair>true</disableHair>
			<disableBeards>true</disableBeards>
			<canSwapAwayFrom>false</canSwapAwayFrom>
		  </li>
		</comps>

		<modExtensions>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100001</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_NoPassion</li></exclusionTags>
				<canHavePassions>false</canHavePassions>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100001</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_Asexual</li></exclusionTags>
				<traitFilters>
					<whitelist>
						<li>Asexual</li>
					</whitelist>
				</traitFilters>
				
				<romanceTags/> <!-- No tags at all by default. -->
				<noFamilyRelations>true</noFamilyRelations>
				
				<!-- <romanceTags> -->
					<!-- <Android>0</Android> -->
					<!-- <Robot>0</Robot> -->
					<!-- <Humanlike>0</Humanlike> -->
					<!-- <Mechanoid>0</Mechanoid> -->
				<!-- </romanceTags> -->
			</li>
			
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_ConstructionDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Construction</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CookingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Cooking</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_HuntingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Hunting</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_FishingDisabled</li></exclusionTags>
				<disabledWorkTypes><li MayRequire="Ludeon.RimWorld.Odyssey">Fishing</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_SmithingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Smithing</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_TailoringDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Tailoring</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CraftingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Crafting</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_DoctorDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Doctor</li></disabledWorkTypes>
			</li>
			
			
			<li Class="BigAndSmall.PawnExtension">
				<frequentUpdate>false</frequentUpdate>
				
				<clampedSkills>
					<li><skill>Shooting</skill><range>0</range></li>
					<li><skill>Melee</skill><range>0</range></li>
					<li><skill>Construction</skill><range>0</range></li>
					<li><skill>Mining</skill><range>0</range></li>
					<li><skill>Cooking</skill><range>0</range></li>
					<li><skill>Plants</skill><range>0</range></li>
					<li><skill>Animals</skill><range>0</range></li>
					<li><skill>Crafting</skill><range>0</range></li>
					<li><skill>Artistic</skill><range>0</range></li>
					<li><skill>Medicine</skill><range>0</range></li>
					<li><skill>Social</skill><range>5</range></li>
					<li><skill>Intellectual</skill><range>5</range></li>
				</clampedSkills>
				
				<forcedHediffs> <!-- will force anything on this list and replace them immediately if something tries to remove them -->
					<li>SWCP_DroidHediff_NonSapientDroid</li>
					
					<li>SWCPWorkTypeDisablerHediff_Mining</li>
					<li>SWCPWorkTypeDisablerHediff_PlantWork</li>
					<li>SWCPWorkTypeDisablerHediff_Animals</li>
					<li>SWCPWorkTypeDisablerHediff_Artistic</li>
				</forcedHediffs>
				<disabledWorkTypes>
				</disabledWorkTypes>
				
				<traitFilters>
					<whitelist>
						<li>Abrasive</li>
					</whitelist>
				</traitFilters>
				
				<babyStartAge>20</babyStartAge>
				<pawnDiet>SWCP_DroidDiet</pawnDiet>
				
				<apparelRestrictions>
					<absolutelyNothing>false</absolutelyNothing>
					<tags>
						<allowlist>
							<li>SWCPDroidApparelRestrictionTag_TorsoAccessory</li>
							<li>SWCPDroidApparelRestrictionTag_Backpacks</li>
							<li>SWCPDroidApparelRestrictionTag_GrenadeDetpackBelts</li>
							
							<li>SWCPDroidApparelRestrictionTag_MediumArmor</li>
							<li>SWCPDroidApparelRestrictionTag_ShieldSlot</li>
							
							<li>SWCPDroidApparelRestrictionTag_SoftwareTechSlot</li>
							<li>SWCPDroidApparelRestrictionTag_HardwareTechSlot</li>
							<li>SWCPDroidApparelRestrictionTag_SensorTechSlot</li>
						</allowlist>
					</tags>
				</apparelRestrictions>
				<!-- <unarmedOnly>false</unarmedOnly> -->
				
				<forcedEndogenes>
					<li MayRequire="Ludeon.Rimworld.Biotech">Body_Standard</li>
					<!-- <li MayRequire="Ludeon.Rimworld.Biotech">guy762_DebugHead_nullForDroids</li> -->
				</forcedEndogenes>
				
				
				<forceFemaleBody>false</forceFemaleBody>
				
				<!-- this block prevents the base human textures from being used -->
				<bodyPaths>
				  <!-- <Body_Female>Droid/RA7ProtocolDroid/RA7ProtocolDroid_body</Body_Female> -->
				  <!-- <Body_Male>Droid/RA7ProtocolDroid/RA7ProtocolDroid_body</Body_Male> -->
				  <Female>512blank</Female>
				  <Male>512blank</Male>
				</bodyPaths>
				
				<bodyMaterial>
				  <shader>BS_CutoutThreeColor</shader>
				  <overrideDesiccated>true</overrideDesiccated>
				  <colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
				  <colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				  <colorC><altDefs><li>BS_CustomGlobalC</li></altDefs></colorC>
				</bodyMaterial>
				<headPaths>
				  <!-- <Female>Droid/RA7ProtocolDroid/RA7ProtocolDroid_head</Female> -->
				  <!-- <Male>Droid/RA7ProtocolDroid/RA7ProtocolDroid_head</Male> -->
				  <Female>512blank</Female>
				  <Male>512blank</Male>
				</headPaths>
				<headMaterial>
				  <shader>BS_CutoutThreeColor</shader>
				  <overrideDesiccated>true</overrideDesiccated>
				  <colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
				  <colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				  <colorC><altDefs><li>BS_CustomGlobalC</li></altDefs></colorC>
				</headMaterial>
				<!-- this block prevents the base human textures from being used -->				
			</li>
		</modExtensions>
		
