		<defName>SWCPDroidXenotype_RA7ProtocolDroid</defName>
		<label>RA-7 series protocol droid</label>
		<description>.</description>
		<iconPath>UI/DroidIcons/Icon_RA7ProtocolDroid</iconPath>
		<!-- <combatPowerFactor>1</combatPowerFactor> -->
		<inheritable>true</inheritable>
		<factionlessGenerationWeight>0</factionlessGenerationWeight>
		<genes>
