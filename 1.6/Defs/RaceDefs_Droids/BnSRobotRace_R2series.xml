			<disableBeards>true</disableBeards>
			<canSwapAwayFrom>false</canSwapAwayFrom>
		  </li>
		</comps>
		<stages>
			<li>
				<statFactors><SM_FlirtChance>0</SM_FlirtChance></statFactors>
				<!-- <disabledWorkTags> -->
					<!-- <li>Animals</li> -->
					<!-- <li>Caring</li> -->
					<!-- <li>Artistic</li> -->
					<!-- <li>Cooking</li> -->
					<!-- <li>PlantWork</li> -->
