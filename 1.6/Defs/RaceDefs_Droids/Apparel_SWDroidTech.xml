<Defs>
  
	<ThingDef ParentName="guy762_DroidTech">
		<defName>SWCP_DroidSoftwareUpgrade_mining</defName>
		<label>droid mining software</label>
		<description>.</description>
		<descriptionHyperlinks>
			<HediffDef>SWCP_SoftwareHediff_mining</HediffDef>
		</descriptionHyperlinks>
		<graphicData>
		  <texPath>Items/droidtech/droidsoftware_L</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
		  <Mass>2</Mass>
		  <MarketValue>1100</MarketValue>
		</statBases>
		<equippedStatOffsets>
			<!-- <IncomingDamageFactor>-0.2</IncomingDamageFactor> -->
		</equippedStatOffsets>
		<apparel>
		  <tags>
			<li>SWCPSpecificDroidTech_</li>
