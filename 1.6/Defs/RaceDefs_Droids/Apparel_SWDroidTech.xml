		  </tags>
		  <bodyPartGroups>
			<li>guy762BG_Droid_Tech_software</li>
		  </bodyPartGroups>
		</apparel>
		<tradeTags>
		  <li>guy762TT_DroidEquipment</li>
		  <li>guy762TT_DroidUpgrades</li>
		</tradeTags>
		<comps>
		  <li Class="CompProperties_CauseHediff_Apparel">
			<hediff>SWCP_SoftwareHediff_mining</hediff>
		  </li>
		</comps>
	</ThingDef>
	
	<HediffDef>
		<defName>SWCP_SoftwareHediff_mining</defName>
		<label>droid mining software</label>
		<description>.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="EBSGFramework.HediffCompProperties_TemporarySkillChange">
				<skillChanges>
					<li>
						<skill>Mining</skill>
						<skillChange>6</skillChange>
					</li>
				</skillChanges>
			</li>
			<li Class="HediffCompProperties_RemoveIfApparelDropped" />
		</comps>
		<isBad>false</isBad>
		
		<modExtensions>
			<li Class="BigAndSmall.PawnExtension">
				<priority>0</priority>
				<exclusionTags>
					<li>SWCPDroidRaceHediffExclusionTag_MiningDisabled</li>
				</exclusionTags>
				<disabledWorkTypes />
			</li>
		</modExtensions>		
	</HediffDef>
	
	
	
	
	
	
