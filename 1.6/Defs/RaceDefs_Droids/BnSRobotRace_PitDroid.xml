	<ThingDef Name="SWCP_BnSDroidRace_PitDroid" ParentName="SWCP_BnSDroidRace_BASE">
		<defName>SWCP_BnSDroidRace_PitDroid</defName>
		<label>DUM-series pit droid</label>
		<description>.\n\nBy default, this droid is capable of the following work types:\n-Constructing\n-Hauling\n-Firefighting</description>

		<statBases>
			<MarketValue>450</MarketValue>
			<RoyalFavorValue>0</RoyalFavorValue>
			
			<MoveSpeed>5</MoveSpeed>
			<VacuumSpeedMultiplier MayRequire="kentington.saveourship2">1</VacuumSpeedMultiplier>
			<ComfyTemperatureMin>-125</ComfyTemperatureMin>
			<ComfyTemperatureMax>125</ComfyTemperatureMax>
			
			<CarryingCapacity>70</CarryingCapacity> <!-- ant-like, can carry twice its own weight -->
			<VEF_MassCarryCapacity MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">70</VEF_MassCarryCapacity>
			<!-- <GlobalLearningFactor>0.5</GlobalLearningFactor> -->
			<WorkSpeedGlobal>2</WorkSpeedGlobal>
			<SM_FlirtChance>0</SM_FlirtChance>
			
			<ArmorRating_Sharp>0.15</ArmorRating_Sharp>
			<ArmorRating_Blunt>0</ArmorRating_Blunt>
            <ArmorRating_Heat>0.25</ArmorRating_Heat>
            <InjuryHealingFactor>2</InjuryHealingFactor>
            <IncomingDamageFactor>1.25</IncomingDamageFactor>
			
			<BS_BatteryCharging>0.5</BS_BatteryCharging>
			<MaxNutrition>1.35</MaxNutrition>			
			
            <!-- <StaggerDurationFactor MayRequire="Ludeon.RimWorld.Biotech">0.8</StaggerDurationFactor> -->
            <!-- <EMPResistance MayRequire="Ludeon.RimWorld.Biotech">0.9</EMPResistance> -->
			
			<Mass>35</Mass>
		</statBases>
		
		
		
		<race>
			<body>SWCP_BnSDroidBody_CyclopsThreeDigitedBiped_NoSlots</body>

			<soundCallIntervalRange>1000~2000</soundCallIntervalRange>
			<lifeStageAges Inherit="False">
				<!-- We're not using custom defs because some Rimworld stuff is hardcoded to look for certain defs.
				 Better from a compatibility standpoint to simply make the stages exist but not be active. -->
				<li>
				  <def>HumanlikeBaby</def>
				  <minAge>0</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeChild</def>
				  <minAge>3</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li MayRequire="Ludeon.RimWorld.Biotech">
				  <def>HumanlikePreTeenager</def>
				  <minAge>9</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeTeenager</def>
				  <minAge>13</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeAdult</def>
				  <minAge>18</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				  
				  <!-- <soundAmbience>kotorsound_TsUD_ambient</soundAmbience> -->
				  <!-- <soundAngry>kotorsound_TsUD_angry</soundAngry> -->
				</li>
			</lifeStageAges>

		</race>

		<modExtensions>
		  <li Class="BigAndSmall.RaceExtension">
			<raceHediff>SWCP_DroidHediff_PitDroid</raceHediff>
		  </li>
		</modExtensions>
		
		<tools Inherit="False">
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<!-- <power>8.2</power> -->
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<!-- <surpriseAttack> -->
				  <!-- <extraMeleeDamages> -->
					<!-- <li> -->
					  <!-- <def>Stun</def> -->
					  <!-- <amount>14</amount> -->
					<!-- </li> -->
				  <!-- </extraMeleeDamages> -->
				<!-- </surpriseAttack> -->
			  </li>
			  <li>
				<label>right fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<!-- <power>8.2</power> -->
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<!-- <surpriseAttack> -->
				  <!-- <extraMeleeDamages> -->
					<!-- <li> -->
					  <!-- <def>Stun</def> -->
					  <!-- <amount>14</amount> -->
					<!-- </li> -->
				  <!-- </extraMeleeDamages> -->
				<!-- </surpriseAttack> -->
			</li>
		</tools>
		
		<butcherProducts>
            <KOTOR_AlloyDurasteel>20</KOTOR_AlloyDurasteel>
			<Plasteel>20</Plasteel>
			<ComponentIndustrial>8</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
			<TechprofSubpersonaCore>1</TechprofSubpersonaCore>
		</butcherProducts>
		<tradeTags>
            <li>SWCPTT_AnyEraDroids_utilitycommon</li>
		</tradeTags>
	</ThingDef>
	
	
	
	
	
	
	
	<!-- <HediffDef ParentName="SWCP_DroidHediff_BASE"> -->
	<HediffDef>
		<defName>SWCP_DroidHediff_PitDroid</defName>
		<label>DUM-series pit droid</label>
		<description>.</description>
		
		<hediffClass>BigAndSmall.RaceTracker</hediffClass>
		
		<abilities></abilities>
		
		<comps Inherit="False">
		  <li Class="BigAndSmall.CompProperties_Race">
			<!-- Cosmetic -->
			<bodyDefOverride>Female</bodyDefOverride>
			<bodyDefOverride_Female>Female</bodyDefOverride_Female>
			<disableHair>true</disableHair>
			<disableBeards>true</disableBeards>
			<canSwapAwayFrom>false</canSwapAwayFrom>
		  </li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<SM_Cosmetic_BodySizeOffset>-0.3</SM_Cosmetic_BodySizeOffset>
				</statOffsets>
				<statFactors>
					<SM_FlirtChance>0</SM_FlirtChance>
				</statFactors>
			</li>
		</stages>

		<modExtensions>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100001</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_NoPassion</li></exclusionTags>
				<canHavePassions>false</canHavePassions>
			</li>
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CleaningDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Cleaning</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_MiningDisabled</li></exclusionTags>
				<disabledWorkTypes>
					<li>Mining</li>
					<li MayRequire="Ogliss.TheWhiteCrayon.Quarry">QuarryMining</li>
				</disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_SmithingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Smithing</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_TailoringDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Tailoring</li></disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CraftingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Crafting</li></disabledWorkTypes>
			</li>
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<frequentUpdate>false</frequentUpdate>
				<romanceTags/> <!-- No tags at all by default. -->
				<noFamilyRelations>true</noFamilyRelations>
				
				<clampedSkills>
					<li><skill>Shooting</skill><range>0</range></li>
					<li><skill>Melee</skill><range>0</range></li>
					<li><skill>Construction</skill><range>5</range></li>
					<li><skill>Mining</skill><range>0</range></li>
					<li><skill>Cooking</skill><range>0</range></li>
					<li><skill>Plants</skill><range>0</range></li>
					<li><skill>Animals</skill><range>0</range></li>
					<li><skill>Crafting</skill><range>0</range></li>
					<li><skill>Artistic</skill><range>0</range></li>
					<li><skill>Medicine</skill><range>0</range></li>
					<li><skill>Social</skill><range>0</range></li>
					<li><skill>Intellectual</skill><range>0</range></li>
				</clampedSkills>
				
				<!-- will force anything on this list and replace them immediately if something tries to remove them - good for things that should be perma-disabled -->
				<forcedHediffs>
					<li>SWCP_DroidHediff_NonSapientDroid</li>
					
					<li>SWCPWorkTypeDisablerHediff_Hunting</li>
					<li>SWCPWorkTypeDisablerHediff_Cooking</li>
					<li>SWCPWorkTypeDisablerHediff_PlantWork</li>
					<li>SWCPWorkTypeDisablerHediff_Animals</li>
					<li>SWCPWorkTypeDisablerHediff_Artistic</li>
					<li>SWCPWorkTypeDisablerHediff_Caring</li>
					<li>SWCPWorkTypeDisablerHediff_Social</li>
					<li>SWCPWorkTypeDisablerHediff_Intellectual</li>
				</forcedHediffs>
				
				<traitFilters>
					<whitelist>
						<li>Asexual</li>
					</whitelist>
				</traitFilters>
				
				<babyStartAge>20</babyStartAge>
				<pawnDiet>SWCP_DroidDiet</pawnDiet>
				
				<apparelRestrictions>
					<absolutelyNothing>True</absolutelyNothing>
					<tags>
						<allowlist>
							<li>SWCPDroidApparelRestrictionTag_LightArmor</li>
						</allowlist>
					</tags>
				</apparelRestrictions>
				<!-- <unarmedOnly>false</unarmedOnly> -->
				
				<forcedEndogenes>
					<li MayRequire="Ludeon.Rimworld.Biotech">Body_Standard</li>
					<li MayRequire="Ludeon.Rimworld.Biotech">guy762_DebugHead_nullForDroids</li>
				</forcedEndogenes>
				
				
				
				
				
				<forceFemaleBody>true</forceFemaleBody>
				<!-- this block prevents the base human textures from being used -->
				<bodyPaths>
				  <Female>512blank</Female>
				  <Male>512blank</Male>
				</bodyPaths>
				<bodyMaterial>
					<shader>BS_CutoutThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				</bodyMaterial>
				<headPaths>
					<Female>512blank</Female>
					<Male>512blank</Male>
				</headPaths>
				<headMaterial>
					<shader>BS_CutoutThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				</headMaterial>
				<!-- this block prevents the base human textures from being used -->
			</li>
		</modExtensions>
		
		<renderNodeProperties>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Head</parentTagDef>
				<shader>BS_CutoutThreeColor</shader>
				<baseLayer>70</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>512blank</li></texturePaths>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultHead</li><li>guy762_LOMProtocolDroidCustomization_4LOMHead</li></altDefs> -->
				</conditionalGraphics>
			</li>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Body</parentTagDef>
				<shader>BS_CutoutThreeColor</shader>
				<baseLayer>20</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>Droid/PitDroid/PitDroid</li></texturePaths>
					<colorA>
						<!-- <color>(125,90,45)</color> -->
						<colorOptions>
							<!-- typical brown -->
							<li>(125,90,45)</li>
							<!-- HK-47's Rust -->
							<!-- <li>(200,100,50)</li> -->
							<!-- Bespin Beige -->
							<li>(175,150,120)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalA</li></altDefs>
					</colorA>
					<colorB>
						<colorOptions>
							<!-- brown that is slightly more orange than the previously used typical brown -->
							<li>(160,115,60)</li>
							<!-- off-white -->
							<li>(255,245,235)</li>
							<!-- Juhani's Cyan -->
							<li>(150,200,200)</li>
							<!-- Trade Federation Beige -->
							<li>(190,165,125)</li>
							<!-- Geonosis Sand Red -->
							<li>(185,125,115)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalB</li></altDefs>
					</colorB>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultBody</li><li>guy762_LOMProtocolDroidCustomization_4LOMBody</li></altDefs> -->
				</conditionalGraphics>
			</li>
		</renderNodeProperties>
		
	</HediffDef>
	
	
	
	
	
	
