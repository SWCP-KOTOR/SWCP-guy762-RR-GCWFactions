	<XenotypeDef>
		<defName>SWCPDroidXenotype_PitDroid</defName>
		<label>DUM-series pit droid</label>
		<description>.</description>
		<iconPath>UI/DroidIcons/Icon_PitDroid</iconPath>
		<!-- <combatPowerFactor>1</combatPowerFactor> -->
