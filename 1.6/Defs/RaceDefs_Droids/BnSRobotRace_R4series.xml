	<ThingDef Name="SWCP_BnSDroidRace_R4series" ParentName="SWCP_BnSDroidRace_BASE">
		<defName>SWCP_BnSDroidRace_R4series</defName>
		<label>R4-series astromech droid</label>
		<description>.\n\nBy default, this droid is capable of the following work types:\n\n-Combat\n-Hauling\n-Constructing\n-Intellectual\n-Firefighting\n-Cleaning</description>

		<statBases>
			<MarketValue>2840</MarketValue>
			<RoyalFavorValue>1</RoyalFavorValue>
			
			<MoveSpeed>3</MoveSpeed>
			<VacuumSpeedMultiplier MayRequire="kentington.saveourship2">4</VacuumSpeedMultiplier>
			<ComfyTemperatureMin>-125</ComfyTemperatureMin>
			<ComfyTemperatureMax>125</ComfyTemperatureMax>
			
			<CarryingCapacity>35</CarryingCapacity>
			<VEF_MassCarryCapacity MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">35</VEF_MassCarryCapacity>
			<!-- <GlobalLearningFactor>1</GlobalLearningFactor> -->
			<WorkSpeedGlobal>1.5</WorkSpeedGlobal>
			<SM_FlirtChance>0</SM_FlirtChance>
			
			<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
            <ArmorRating_Heat>0.35</ArmorRating_Heat>
            <InjuryHealingFactor>1.5</InjuryHealingFactor>
            <IncomingDamageFactor>0.95</IncomingDamageFactor>
			
			<BS_BatteryCharging>0.2</BS_BatteryCharging>
			<MaxNutrition>1.35</MaxNutrition>
			
            <!-- <StaggerDurationFactor MayRequire="Ludeon.RimWorld.Biotech">0.8</StaggerDurationFactor> -->
            <!-- <EMPResistance MayRequire="Ludeon.RimWorld.Biotech">0.9</EMPResistance> -->
			
			<Mass>64</Mass>
		</statBases>
		
		
		
		<race>
			<body>SWCP_BnSDroidBody_GenericAstromech</body>

			<soundCallIntervalRange>1000~2000</soundCallIntervalRange>
			<lifeStageAges Inherit="False">
				<!-- We're not using custom defs because some Rimworld stuff is hardcoded to look for certain defs.
				 Better from a compatibility standpoint to simply make the stages exist but not be active. -->
				<li>
				  <def>HumanlikeBaby</def>
				  <minAge>0</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeChild</def>
				  <minAge>3</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li MayRequire="Ludeon.RimWorld.Biotech">
				  <def>HumanlikePreTeenager</def>
				  <minAge>9</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeTeenager</def>
				  <minAge>13</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeAdult</def>
				  <minAge>18</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				  
				  <!-- <soundAmbience>kotorsound_TsUD_ambient</soundAmbience> -->
				  <!-- <soundAngry>kotorsound_TsUD_angry</soundAngry> -->
				</li>
			</lifeStageAges>

		</race>

		<modExtensions>
		  <li Class="BigAndSmall.RaceExtension">
			<raceHediff>SWCP_DroidHediff_R4Astromech</raceHediff>
		  </li>
		</modExtensions>
		
		<tools Inherit="False">
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
		<butcherProducts>
            <KOTOR_AlloyDurasteel>20</KOTOR_AlloyDurasteel>
			<Plasteel>20</Plasteel>
			<ComponentIndustrial>8</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
			<TechprofSubpersonaCore>1</TechprofSubpersonaCore>
		</butcherProducts>
		<tradeTags>
            <li>SWCPTT_AnyEraDroids_techcommon</li>
		</tradeTags>
	</ThingDef>
	
	
	
	
	
	
	
	<!-- <HediffDef ParentName="SWCP_DroidHediff_BASE"> -->
	<HediffDef>
		<defName>SWCP_DroidHediff_R4Astromech</defName>
		<label>R4-series Astromech</label>
		<description>.</description>
		
		<hediffClass>BigAndSmall.RaceTracker</hediffClass>
		
		<abilities></abilities>
		
		<comps Inherit="False">
		  <li Class="BigAndSmall.CompProperties_Race">
			<!-- Cosmetic -->
			<bodyDefOverride>Female</bodyDefOverride>
			<bodyDefOverride_Female>Female</bodyDefOverride_Female>
			<disableHair>true</disableHair>
			<disableBeards>true</disableBeards>
			<canSwapAwayFrom>false</canSwapAwayFrom>
		  </li>
		</comps>
		
		<stages>
			<li><statFactors><SM_FlirtChance>0</SM_FlirtChance></statFactors></li>
		</stages>

		<modExtensions>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100001</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_NoPassion</li></exclusionTags>
				<canHavePassions>false</canHavePassions>
			</li>
			
			
			
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_MiningDisabled</li></exclusionTags>
				<disabledWorkTypes>
					<li>Mining</li>
					<li MayRequire="Ogliss.TheWhiteCrayon.Quarry">QuarryMining</li>
				</disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_PlantWorkDisabled</li></exclusionTags>
				<disabledWorkTypes>
					<li>Growing</li>
					<li>PlantCutting</li>
				</disabledWorkTypes>
			</li>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CraftingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Crafting</li></disabledWorkTypes>
			</li>
			
			
			
			
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<frequentUpdate>false</frequentUpdate>
				<romanceTags/> <!-- No tags at all by default. -->
				<noFamilyRelations>true</noFamilyRelations>
			  
				<clampedSkills>
					<li><skill>Shooting</skill><range>0</range></li>
					<li><skill>Melee</skill><range>0</range></li>
					<li><skill>Construction</skill><range>5</range></li>
					<li><skill>Mining</skill><range>0</range></li>
					<li><skill>Cooking</skill><range>0</range></li>
					<li><skill>Plants</skill><range>0</range></li>
					<li><skill>Animals</skill><range>0</range></li>
					<li><skill>Crafting</skill><range>0</range></li>
					<li><skill>Artistic</skill><range>0</range></li>
					<li><skill>Medicine</skill><range>0</range></li>
					<li><skill>Social</skill><range>0</range></li>
					<li><skill>Intellectual</skill><range>5</range></li>
				</clampedSkills>
				
				<!-- will force anything on this list and replace them immediately if something tries to remove them - good for things that should be perma-disabled -->
				<forcedHediffs>
					<li>SWCP_DroidHediff_NonSapientDroid</li>
					
					<li>SWCPWorkTypeDisablerHediff_Hunting</li>
					<li>SWCPWorkTypeDisablerHediff_Cooking</li>
					<li>SWCPWorkTypeDisablerHediff_Animals</li>
					<li>SWCPWorkTypeDisablerHediff_Artistic</li>
					<li>SWCPWorkTypeDisablerHediff_Caring</li>
					<li>SWCPWorkTypeDisablerHediff_Social</li>
				</forcedHediffs>
				<disabledWorkTypes>
					<li>Smithing</li>
					<li>Tailoring</li>
					<!-- <li>Handling</li> -->
					<!-- <li MayRequire="Ludeon.RimWorld.Odyssey">Fishing</li> -->
				</disabledWorkTypes>
				
				<traitFilters>
				  <whitelist>
					<li>Asexual</li>
				  </whitelist>
				</traitFilters>
				
				<babyStartAge>20</babyStartAge>
				<pawnDiet>SWCP_DroidDiet</pawnDiet>
				
				<apparelRestrictions>
					<absolutelyNothing>True</absolutelyNothing>
					<tags>
						<allowlist>
							<li>SWCPDroidApparelRestrictionTag_LightArmor</li>

							<li>SWCPDroidApparelRestrictionTag_SoftwareTechSlot</li>
							<li>SWCPDroidApparelRestrictionTag_HardwareTechSlot</li>
							
							<li>SWCPDroidApparelRestrictionTag_GadgetWeaponSlot</li>
						</allowlist>
					</tags>
				</apparelRestrictions>
				<unarmedOnly>true</unarmedOnly>
				<forceUnarmed>true</forceUnarmed>
				<canWieldThings>false</canWieldThings>
				
				<forcedEndogenes>
					<li MayRequire="Ludeon.Rimworld.Biotech">Body_Standard</li>
					<li MayRequire="Ludeon.Rimworld.Biotech">guy762_DebugHead_nullForDroids</li>
				</forcedEndogenes>
				
				<forceFemaleBody>true</forceFemaleBody>
				<!-- this block prevents the base human textures from being used -->
				<bodyPaths>
				  <Female>512blank</Female>
				  <Male>512blank</Male>
				</bodyPaths>
				<bodyMaterial>
					<shader>BS_CutoutThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
					<colorC><altDefs><li>BS_CustomGlobalC</li></altDefs></colorC>
				</bodyMaterial>
				<headPaths>
					<Female>512blank</Female>
					<Male>512blank</Male>
				</headPaths>
				<headMaterial>
					<shader>BS_CutoutThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
					<colorC><altDefs><li>BS_CustomGlobalC</li></altDefs></colorC>
				</headMaterial>
				<!-- this block prevents the base human textures from being used -->
			</li>
		</modExtensions>
		
		<renderNodeProperties>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Head</parentTagDef>
				<shader>BS_CutoutThreeColor</shader>
				<baseLayer>70</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>512blank</li></texturePaths>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
					<colorC><altDefs><li>BS_CustomGlobalC</li></altDefs></colorC>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultHead</li><li>guy762_LOMProtocolDroidCustomization_4LOMHead</li></altDefs> -->
				</conditionalGraphics>
			</li>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Body</parentTagDef>
				<shader>BS_CutoutThreeColor</shader>
				<baseLayer>20</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>Droid/R4Astromech/R4</li></texturePaths>
					<colorA>
						<!-- <favoriteColor>true</favoriteColor> -->
						<colorOptions>
							<!-- Jedi Sentinel Blue -->
							<li>(70,90,125)</li>
							<!-- Old Republic Yellow -->
							<li>(230,185,45)</li>
							<!-- Galactic Marine Burgundy -->
							<li>(120,55,75)</li>
							<!-- Imperial Remnant Green -->
							<li>(25,110,30)</li>
							<!-- Pentastar Blue -->
							<li>(65,70,190)</li>
							<!-- Maldrood Crimson -->
							<li>(205,15,40)</li>
							<!-- New Republic Orange -->
							<li>(205,125,20)</li>
							<!-- New Republic Azure -->
							<li>(70,135,190)</li>
							<!-- Rebel Red -->
							<li>(125,50,50)</li>
							<!-- Mandalorian Protector Green -->
							<li>(90,120,85)</li>
							<!-- Black Sun Violet -->
							<li>(85,65,150)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalA</li></altDefs>
					</colorA>
					<colorB>
						<color>250,250,250</color>
						<altDefs><li>BS_CustomGlobalB</li></altDefs>
					</colorB>
					<colorC>
						<color>250,250,250</color>
						<altDefs><li>BS_CustomGlobalC</li></altDefs>
					</colorC>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultBody</li><li>guy762_LOMProtocolDroidCustomization_4LOMBody</li></altDefs> -->
				</conditionalGraphics>
			</li>
		</renderNodeProperties>
		
	</HediffDef>
	
	
	
	
	
	
	<GeneDef ParentName="SWCPDroidBodyGene_chassisBASE">
		<defName>SWCPDroidBodyGene_R4Series</defName>
		<label>R4-series Astromech Chassis</label>
		
		<skinColorOverride>(250, 250, 250)</skinColorOverride>
		
		<iconPath>UI/DroidIcons/Icon_R4</iconPath>
	</GeneDef>
	
	<XenotypeDef>
		<defName>SWCPDroidXenotype_R4Series</defName>
		<label>R4-series Astromech</label>
		<description>.</description>
		<iconPath>UI/DroidIcons/Icon_R4</iconPath>
		<!-- <combatPowerFactor>1</combatPowerFactor> -->
		<inheritable>true</inheritable>
		<factionlessGenerationWeight>0</factionlessGenerationWeight>
		<genes>
		  <li>SWCPDroidBodyGene_R4Series</li>
		  <li>Beard_NoBeardOnly</li>
		  <li>Hair_BaldOnly</li>
		  <li>guy762_DebugHead_nullForDroids</li>
		  <li MayRequire="RedMattis.BigSmall.Core">BS_AcidResistanceMid</li>
		</genes>
		<modExtensions>
		  <li Class="BigAndSmall.XenotypeExtension">
			<setRace>SWCP_BnSDroidRace_R4series</setRace>
			<forceRace>true</forceRace>
		  </li>
		</modExtensions>
	</XenotypeDef>
	
	
	
	
	
	
	
	
	
	

	
	
	
	
	
	
	
	
	<PawnKindDef Name="SWCPDroidColonistBnS_R4AstDrd" ParentName="guy762_BnSDroidPawnKindBase">
		<defName>SWCPDroidColonistBnS_R4AstDrd</defName>
		<label>astromech</label>
		<nameMaker>SWCP_DroidNamer_R4AD</nameMaker>
		
		<race>SWCP_BnSDroidRace_R4series</race>
		<useFactionXenotypes>false</useFactionXenotypes>
		<xenotypeSet Inherit="False">
		  <xenotypeChances>
			<SWCPDroidXenotype_R4Series MayRequire="Ludeon.Rimworld.Biotech">999</SWCPDroidXenotype_R4Series>
		  </xenotypeChances>
		</xenotypeSet>
		
        <combatPower>50</combatPower>
		<forcedTraits>
			<Asexual>0</Asexual>
			<!-- <TooSmart>0</TooSmart> -->
		</forcedTraits>
		<backstoryFiltersOverride>
		  <li>
			<categories>
			  <li>guy762BSC_Droid_R4AstDrd</li>
			</categories>
		  </li>
		</backstoryFiltersOverride>
	</PawnKindDef>
	

</Defs>