		</genes>
		<modExtensions>
		  <li Class="BigAndSmall.XenotypeExtension">
			<setRace>SWCP_BnSDroidRace_ASP7LaborDroid</setRace>
			<forceRace>true</forceRace>
		  </li>
		</modExtensions>
	</XenotypeDef>
	
	
	
	
	
	
	
	
	
	

	
	
	
	
	
	
	
	
	<PawnKindDef Name="SWCPDroidColonistBnS_ASP7LaborDroid" ParentName="guy762_BnSDroidPawnKindBase">
		<defName>SWCPDroidColonistBnS_ASP7LaborDroid</defName>
		<label>labor droid</label>
		<nameMaker>SWCP_DroidNamer_ASP7LaborDroid</nameMaker>
		
		<race>SWCP_BnSDroidRace_ASP7LaborDroid</race>
		<useFactionXenotypes>false</useFactionXenotypes>
