		  </xenotypeChances>
		</xenotypeSet>
		
        <combatPower>50</combatPower>
		
		<forcedTraits>
			<Asexual>0</Asexual>
			<!-- <TooSmart>0</TooSmart> -->
		</forcedTraits>
		<backstoryFiltersOverride>
		  <li>
			<categories>
			  <li>guy762BSC_Droid_ASP7LaborDroid</li>
			</categories>
		  </li>
		</backstoryFiltersOverride>
	</PawnKindDef>
	

</Defs>