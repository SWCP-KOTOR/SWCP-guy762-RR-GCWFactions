<?xml version="1.0" encoding="utf-8"?>
<Defs>

	
	<BackstoryDef>
		<defName>guy762_Backstory_21BMedDroid</defName>
		<title>2-1B-series medical droid</title>
		<titleShort>medical droid</titleShort>
		<description>This is an advanced medical droid, capable of many medicinal-related tasks.</description>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>guy762BSC_Droid_21BMedDroid</li>
			<li>guy762BSC_Droid_all</li>
		</spawnCategories>
		<forcedTraits>
		  <Asexual>0</Asexual>
		</forcedTraits>
	</BackstoryDef>
	

	
	
	
	<ThingDef Name="SWCP_BnSDroidRace_21BMedDroid" ParentName="SWCP_BnSDroidRace_BASE">
		<defName>SWCP_BnSDroidRace_21BMedDroid</defName>
		<label>2-1B-series medical droid</label>
		<description>.\n\nBy default, this droid is capable of the following work types:\n\n-Medical\n-Intellectual\n-Crafting (basic only)</description>

		<statBases>
			<MarketValue>4300</MarketValue>
			<RoyalFavorValue>2</RoyalFavorValue>
			
			<MoveSpeed>2</MoveSpeed>
			<VacuumSpeedMultiplier MayRequire="kentington.saveourship2">1</VacuumSpeedMultiplier>
			<ComfyTemperatureMin>-125</ComfyTemperatureMin>
			<ComfyTemperatureMax>125</ComfyTemperatureMax>
			
			<CarryingCapacity>20</CarryingCapacity>
			<VEF_MassCarryCapacity MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">20</VEF_MassCarryCapacity>
			<!-- <GlobalLearningFactor>0.5</GlobalLearningFactor> -->
			<WorkSpeedGlobal>1</WorkSpeedGlobal>
			<SM_FlirtChance>0</SM_FlirtChance>
			
			<ArmorRating_Sharp>0.15</ArmorRating_Sharp>
			<ArmorRating_Blunt>0</ArmorRating_Blunt>
            <ArmorRating_Heat>0.25</ArmorRating_Heat>
            <InjuryHealingFactor>1</InjuryHealingFactor>
            <IncomingDamageFactor>1</IncomingDamageFactor>
			
            <BS_BatteryCharging>0.1</BS_BatteryCharging>
			<MaxNutrition>1.35</MaxNutrition>
			
            <!-- <StaggerDurationFactor MayRequire="Ludeon.RimWorld.Biotech">0.8</StaggerDurationFactor> -->
            <!-- <EMPResistance MayRequire="Ludeon.RimWorld.Biotech">0.9</EMPResistance> -->
			
			<Mass>85</Mass>
		</statBases>
		
		
		
		<race>
			<body>SWCP_BnSDroidBody_ThreeDigitBiped_SoftwareSlot</body>

			<soundCallIntervalRange>1000~2000</soundCallIntervalRange>
			<lifeStageAges Inherit="False">
				<!-- We're not using custom defs because some Rimworld stuff is hardcoded to look for certain defs.
				 Better from a compatibility standpoint to simply make the stages exist but not be active. -->
				<li>
				  <def>HumanlikeBaby</def>
				  <minAge>0</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeChild</def>
				  <minAge>3</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li MayRequire="Ludeon.RimWorld.Biotech">
				  <def>HumanlikePreTeenager</def>
				  <minAge>9</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeTeenager</def>
				  <minAge>13</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				</li>
				<li>
				  <def>HumanlikeAdult</def>
				  <minAge>18</minAge>
				  <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
				  <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
				  <soundCall>Pawn_Mech_Scyther_Call</soundCall>
				  
				  <!-- <soundAmbience>kotorsound_TsUD_ambient</soundAmbience> -->
				  <!-- <soundAngry>kotorsound_TsUD_angry</soundAngry> -->
				</li>
			</lifeStageAges>

		</race>

		<modExtensions>
		  <li Class="BigAndSmall.RaceExtension">
			<raceHediff>SWCP_DroidHediff_21BMedDroid</raceHediff>
		  </li>
		</modExtensions>
		
		<tools Inherit="False">
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<!-- <power>8.2</power> -->
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<surpriseAttack>
				  <extraMeleeDamages>
					<li>
					  <def>Stun</def>
					  <amount>7</amount>
					</li>
				  </extraMeleeDamages>
				</surpriseAttack>
			  </li>
			  <li>
				<label>right fist</label>
				<labelNoLocation>fist</labelNoLocation>
				<capacities>
				  <li>Blunt</li>
				</capacities>
				<!-- <power>8.2</power> -->
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<surpriseAttack>
				  <extraMeleeDamages>
					<li>
					  <def>Stun</def>
					  <amount>7</amount>
					</li>
				  </extraMeleeDamages>
				</surpriseAttack>
			</li>
		</tools>
		
		<butcherProducts>
            <KOTOR_AlloyDurasteel>20</KOTOR_AlloyDurasteel>
			<Plasteel>20</Plasteel>
			<ComponentIndustrial>8</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
			<TechprofSubpersonaCore>1</TechprofSubpersonaCore>
		</butcherProducts>
		<tradeTags>
            <li>SWCPTT_AnyEraDroids_medical</li>
		</tradeTags>
	</ThingDef>
	
	
	
	
	
	
	
	<!-- <HediffDef ParentName="SWCP_DroidHediff_BASE"> -->
	<HediffDef>
		<defName>SWCP_DroidHediff_21BMedDroid</defName>
		<label>2-1B-series medical droid</label>
		<description>.</description>
		
		<hediffClass>BigAndSmall.RaceTracker</hediffClass>
		
		<abilities>
			<li MayRequire="Ludeon.RimWorld.Ideology">ImmunityDrive</li>
		</abilities>
		
		<comps Inherit="False">
		  <li Class="BigAndSmall.CompProperties_Race">
			<!-- Cosmetic -->
			<bodyDefOverride>Female</bodyDefOverride>
			<bodyDefOverride_Female>Female</bodyDefOverride_Female>
			<disableHair>true</disableHair>
			<disableBeards>true</disableBeards>
			<canSwapAwayFrom>false</canSwapAwayFrom>
		  </li>
		</comps>
		
		<stages>
			<li><statFactors><SM_FlirtChance>0</SM_FlirtChance></statFactors></li>
		</stages>

		<modExtensions>
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100001</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_NoPassion</li></exclusionTags>
				<canHavePassions>false</canHavePassions>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CookingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Cooking</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_CleaningDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Cleaning</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_HaulingDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Hauling</li></disabledWorkTypes>
			</li>
			
			<li Class="BigAndSmall.PawnExtension">
				<priority>-100000</priority>
				<exclusionTags><li>SWCPDroidRaceHediffExclusionTag_FirefighterDisabled</li></exclusionTags>
				<disabledWorkTypes><li>Firefighter</li></disabledWorkTypes>
			</li>
			
			
			
			<li Class="BigAndSmall.PawnExtension">
				<frequentUpdate>false</frequentUpdate>
				<romanceTags/> <!-- No tags at all by default. -->
				<noFamilyRelations>true</noFamilyRelations>
				
				<clampedSkills>
					<li><skill>Shooting</skill><range>0</range></li>
					<li><skill>Melee</skill><range>0</range></li>
					<li><skill>Construction</skill><range>0</range></li>
					<li><skill>Mining</skill><range>0</range></li>
					<li><skill>Cooking</skill><range>0</range></li>
					<li><skill>Plants</skill><range>0</range></li>
					<li><skill>Animals</skill><range>0</range></li>
					<li><skill>Crafting</skill><range>10</range></li>
					<li><skill>Artistic</skill><range>0</range></li>
					<li><skill>Medicine</skill><range>15</range></li>
					<li><skill>Social</skill><range>0</range></li>
					<li><skill>Intellectual</skill><range>10</range></li>
				</clampedSkills>
				
				<forcedHediffs> <!-- will force anything on this list and replace them immediately if something tries to remove them -->
					<li>SWCP_DroidHediff_NonSapientDroid</li>
					
					<li>SWCPWorkTypeDisablerHediff_Hunting</li>
					<li>SWCPWorkTypeDisablerHediff_Constructing</li>
					<li>SWCPWorkTypeDisablerHediff_Mining</li>
					<li>SWCPWorkTypeDisablerHediff_PlantWork</li>
					<li>SWCPWorkTypeDisablerHediff_Animals</li>
					<li>SWCPWorkTypeDisablerHediff_Artistic</li>
					<li>SWCPWorkTypeDisablerHediff_Social</li>
				</forcedHediffs>
				<disabledWorkTypes>
					<li>Smithing</li>
					<li>Tailoring</li>
				</disabledWorkTypes>
				
				<traitFilters>
					<whitelist>
						<li>Asexual</li>
					</whitelist>
				</traitFilters>
				
				<babyStartAge>20</babyStartAge>
				<pawnDiet>SWCP_DroidDiet</pawnDiet>
				
				<apparelRestrictions>
					<absolutelyNothing>True</absolutelyNothing>
					<tags>
						<allowlist>
							<li>SWCPDroidApparelRestrictionTag_LightArmor</li>
							
							<li>SWCPDroidApparelRestrictionTag_SoftwareTechSlot</li>
							<li>SWCPDroidApparelRestrictionTag_SensorTechSlot</li>
						</allowlist>
					</tags>
				</apparelRestrictions>
				<!-- <unarmedOnly>false</unarmedOnly> -->

				<forcedEndogenes>
					<li MayRequire="Ludeon.Rimworld.Biotech">Body_Standard</li>
					<!-- <li MayRequire="Ludeon.Rimworld.Biotech">guy762_DebugHead_nullForDroids</li> -->
				</forcedEndogenes>	
				
				
				
				<forceFemaleBody>true</forceFemaleBody>
				<!-- this block prevents the base human textures from being used -->
				<bodyPaths>
				  <Female>512blank</Female>
				  <Male>512blank</Male>
				</bodyPaths>
				<bodyMaterial>
					<shader>BS_TransparentThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				</bodyMaterial>
				<headPaths>
					<Female>512blank</Female>
					<Male>512blank</Male>
				</headPaths>
				<headMaterial>
					<shader>BS_TransparentThreeColor</shader>
					<overrideDesiccated>true</overrideDesiccated>
					<colorA><altDefs><li>BS_CustomGlobalA</li></altDefs></colorA>
					<colorB><altDefs><li>BS_CustomGlobalB</li></altDefs></colorB>
				</headMaterial>
				<!-- this block prevents the base human textures from being used -->
			</li>
		</modExtensions>
		
		<renderNodeProperties>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Head</parentTagDef>
				<shader>BS_TransparentThreeColor</shader>
				<baseLayer>70</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>Droid/21BMedDroid/21BMedDroid_head</li></texturePaths>
					<colorA>
						<colorOptions>
							<!-- Kenner Teal -->
							<li>(90,175,195)</li>
							<!-- Sith Uniform Slate -->
							<li>(170,170,190)</li>
							<!-- T3-M4's Silver -->
							<li>(235,255,255)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalA</li></altDefs>
					</colorA>
					<colorB>
						<colorOptions>
							<!-- white -->
							<li>(250,250,250)</li>
							<!-- off-white -->
							<li>(255,245,235)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalB</li></altDefs>
					</colorB>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultHead</li><li>guy762_LOMProtocolDroidCustomization_4LOMHead</li></altDefs> -->
				</conditionalGraphics>
			</li>
			<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
				<nodeClass>BigAndSmall.PawnRenderNode_Ultimate</nodeClass>
				<workerClass>BigAndSmall.UltimateRenderNodeWorker</workerClass>
				<parentTagDef>Body</parentTagDef>
				<shader>BS_TransparentThreeColor</shader>
				<baseLayer>20</baseLayer>
				<conditionalGraphics>
					<texturePaths><li>Droid/21BMedDroid/21BMedDroid_body</li></texturePaths>
					<colorA>
						<colorOptions>
							<!-- Kenner Teal -->
							<li>(90,175,195)</li>
							<!-- Sith Uniform Slate -->
							<li>(170,170,190)</li>
							<!-- T3-M4's Silver -->
							<li>(235,255,255)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalA</li></altDefs>
					</colorA>
					<colorB>
						<colorOptions>
							<!-- white -->
							<li>(250,250,250)</li>
							<!-- off-white -->
							<li>(255,245,235)</li>
						</colorOptions>
						<altDefs><li>BS_CustomGlobalB</li></altDefs>
					</colorB>
					<!-- <altDefs><li>guy762_LOMProtocolDroidCustomization_defaultBody</li><li>guy762_LOMProtocolDroidCustomization_4LOMBody</li></altDefs> -->
				</conditionalGraphics>
			</li>
		</renderNodeProperties>
	</HediffDef>
	
	
	
	
	
	
	<GeneDef ParentName="SWCPDroidBodyGene_chassisBASE">
		<defName>SWCPDroidBodyGene_21BMedDroid</defName>
		<label>2-1B-series medical droid</label>
		
		<!-- <skinColorOverride>(125,90,45)</skinColorOverride> -->
		
		<iconPath>UI/DroidIcons/Icon_21BMedDroid</iconPath>

	</GeneDef>
	
	<XenotypeDef>
		<defName>SWCPDroidXenotype_21BMedDroid</defName>
		<label>2-1B-series medical droid</label>
		<description>.</description>
		<iconPath>UI/DroidIcons/Icon_21BMedDroid</iconPath>
		<!-- <combatPowerFactor>1</combatPowerFactor> -->
		<inheritable>true</inheritable>
		<factionlessGenerationWeight>0</factionlessGenerationWeight>
		<genes>
		  <li>SWCPDroidBodyGene_21BMedDroid</li>
		  <li>Beard_NoBeardOnly</li>
		  <li>Hair_BaldOnly</li>
		  <!-- <li>guy762_DebugHead_nullForDroids</li> -->
		  <li MayRequire="RedMattis.BigSmall.Core">BS_AcidResistanceMid</li>
		</genes>
		<modExtensions>
		  <li Class="BigAndSmall.XenotypeExtension">
			<setRace>SWCP_BnSDroidRace_21BMedDroid</setRace>
			<forceRace>true</forceRace>
		  </li>
		</modExtensions>
	</XenotypeDef>
	
	
	
	
	
	
	
	
	
	

	
	
	
	
	
	
	
	
	<PawnKindDef Name="SWCPDroidColonistBnS_21BMedDroid" ParentName="guy762_BnSDroidPawnKindBase">
		<defName>SWCPDroidColonistBnS_21BMedDroid</defName>
		<label>medical droid</label>
		<nameMaker>SWCP_DroidNamer_21BMedDroid</nameMaker>
		
		<race>SWCP_BnSDroidRace_21BMedDroid</race>
		<useFactionXenotypes>false</useFactionXenotypes>
		<xenotypeSet Inherit="False">
		  <xenotypeChances>
			<SWCPDroidXenotype_21BMedDroid MayRequire="Ludeon.Rimworld.Biotech">999</SWCPDroidXenotype_21BMedDroid>
		  </xenotypeChances>
		</xenotypeSet>
		
        <combatPower>30</combatPower>
		
		<forcedTraits>
			<Asexual>0</Asexual>
			<!-- <TooSmart>0</TooSmart> -->
		</forcedTraits>
		<backstoryFiltersOverride>
		  <li>
			<categories>
			  <li>guy762BSC_Droid_21BMedDroid</li>
			</categories>
		  </li>
		</backstoryFiltersOverride>
	</PawnKindDef>
	

</Defs>