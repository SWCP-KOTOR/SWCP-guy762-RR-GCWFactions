<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<ThingDef Name="SWCPItemLootBoxBASE" ParentName="ResourceBase" Abstract="True">
        <resourceReadoutPriority>Middle</resourceReadoutPriority>
        <soundInteract>Metal_Drop</soundInteract>
        <soundDrop>Metal_Drop</soundDrop>
		<stackLimit>1</stackLimit>
        <useHitPoints>true</useHitPoints>
        <thingCategories>
            <li>ItemsMisc</li>
        </thingCategories>
        <drawGUIOverlay>false</drawGUIOverlay>
        <!-- <tradeability>Sellable</tradeability> -->
        <tradeability>All</tradeability>
        <techLevel>Spacer</techLevel>
        <comps>
			<li Class="CompProperties_Usable">
                <useJob>UseItem</useJob>
                <useLabel>Open {0}</useLabel>
            </li>
			<li Class="CompProperties_UseEffectDestroySelf"/>
			<li Class="CompProperties_Forbiddable"/>
        </comps>
		
		<thingSetMakerTags>
			<li>RewardStandardCore</li>
			<li>SWCPSetMakerTag_SupplyWarehouseLoot</li>
		</thingSetMakerTags>
    </ThingDef>
	
	
	
	

    <ThingDef ParentName="SWCPItemLootBoxBASE">
        <defName>SWCPItemLootBox_FoodMeds</defName> <!-- THIS DEFNAME REFERENCED BY SWCP_LevelDesignStuff.dll -->
        <label>supplies shipment</label>
        <description>A supply container containing a random assortment of food and medical supplies. Each crate should be enough to last a squad one week.</description>
        <graphicData>
            <texPath>Buildings/SotE_singlecrate_blue</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1.5</drawSize>
        </graphicData>
        <size>(1,1)</size>
        <statBases>
            <MarketValue>1000</MarketValue>
            <MaxHitPoints>100</MaxHitPoints>
            <Mass>10</Mass>
            <Flammability>0.2</Flammability>
        </statBases>
        <comps>
            <li Class="FCP.Core.CompProperties_UseEffectItemBox">
                <numWeightedDrops>2</numWeightedDrops>
                <guaranteedDrops>
                    <li>
                        <thingDef>MealSurvivalPack</thingDef>
                        <countRange>15~20</countRange>
                    </li>
					<li>
                        <thingDef>KOTOR_SpacerMedKit</thingDef>
                        <countRange>3~5</countRange>
                    </li>
                </guaranteedDrops>
                <weightedDrops>
                    <li>
                        <thingDef>Chocolate</thingDef>
                        <countRange>10</countRange>
                        <weight>0.5</weight>
                    </li>
                    <li>
                        <thingDef>KOTOR_kolto</thingDef>
                        <countRange>5</countRange>
                        <weight>0.1</weight>
                    </li>
					<li>
                        <thingDef>guy762_medpac</thingDef>
                        <countRange>5</countRange>
                        <weight>1</weight>
                    </li>
					<li>
                        <thingDef>guy762_medpac_adv</thingDef>
                        <countRange>5</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_medpac_life</thingDef>
                        <countRange>5</countRange>
                        <weight>0.1</weight>
                    </li>
                </weightedDrops>
            </li>
			<li Class="CompProperties_UseEffectPlaySound">
				<soundOnUsed>kotorsound_scrappile_open</soundOnUsed>
			</li>
        </comps>
    </ThingDef>
	
	
	
	
	
	
	
	
