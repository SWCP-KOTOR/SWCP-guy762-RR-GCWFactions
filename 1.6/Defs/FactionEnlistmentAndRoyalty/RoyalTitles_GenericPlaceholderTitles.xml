<Defs>

<!--
					THE HIERARCHY OF IMPERIAL RANKS
	

	SENIORITY VALUES:
	0X: left open for misc titles ////////////////////////////
	- 
	
	1X: NCO/low ranks ////////////////////////////
	- 11 - subaltern (operations)
	- 12 - corporal (army)
	- 13 - cadet (navy)
	- 14 - attendant/agent (ISB/IMI)
	
	- 1X - sergeant (army)
	- 1X - ensign (navy)
	
	2X: low junior officer ranks ////////////////////////////
	- 21 - lieutenant (operations)
	- 22 - lieutenant (army)
	- 23 - lieutenant (navy)
	- 24 - lieutenant/supervisor (ISB/IMI)
	
	
	3X: high junior officer ranks ////////////////////////////
	- 31 - captain (operations)
	- 32 - captain (army)
	- 33 - lt. commander (navy)
	- 34 - captain (ISB/IMI)
	
	- 37 - detachment CO (special)
	
	- 39 - acolyte (dark side)
	
	4X: low senior officer ranks ////////////////////////////
	- 41 - major (operations)
	- 42 - major (army)
	- 43 - commander (navy)
	- 44 - major (ISB/IMI)
	
	- 45 - baron/count (imperial court honorific)
	- 46 - administrator (politiburo)
	- 47 - task squadron CO (special)
	
	- 49 - imperial royal guard (dark side)
	
	5X: high senior officer ranks ////////////////////////////
	- 51 - commander (operations)
	- 52 - commandant (army)
	- 53 - captain (navy)
	- 54 - commander (ISB/IMI)
	
	- 55 - prince/king (imperial court honorific)
	
	- 57 - task division CO (special)
	- 58 - inquisitor (inquisitorus)
	
	6X: low flag officer ranks ////////////////////////////
	- 61 - commodore (operations)
	- 62 - colonel (army)
	- 63 - vice admiral (navy)
	- 64 - colonel (ISB/IMI)
	
	- 66 - viceroy (politiburo)
	- 67 - task force CO (special)
	
	- 68 - high inquisitor (inquisitorus)
	- 69 - shadow hand (dark side)
	
	7X: high flag officer ranks ////////////////////////////
	- 71 - general (operations)
	- 72 - general (army)
	- 73 - admiral (navy)
	- 74 - admiral (ISB/IMI)
	
	- 75 - vizier (imperial court)
	- 76 - moff (politiburo)
	
	- 78 - grand inquisitor (inquisitorus)
	- 79 - emperor's hand (dark side)
	
	8X: special appointment ranks & self-appointed titles ////////////////////////////
	- 81 - project director (operations)
	- 82 - field marshal (army)
	- 83 - fleet admiral (navy)
	- 84 - agency director (ISB/IMI)
	
	- 85 - grand general (army & operations)
	
	- 8X - high admiral
	- 8X - superior general
	- 8X - warlord
	- 8X - supreme commander
	
	9X+: oversector administrators & emperor's inner circle	////////////////////////////
	- 91 - grand admiral (army & navy)
	- 92 - grand moff (politiburo)
	- 93 - grand vizier (imperial court)
	
	- 98 - military executor
	- 99 - apprenticed Darth 

	100: emperor	////////////////////////////
	
-->











