				<checkGender>True</checkGender>
			</li>
		</modExtensions>

		<disallowedTraits>
			<li>Wimp</li>
		</disallowedTraits>
	</PawnKindDef>
	
	

	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
