	<PawnKindDef Name="SWEriadu_TrooperBase" ParentName="SWEriadu_Base" Abstract="True">
		<modExtensions>
			<li Class="BodyTypeForPawnKind.ModExtension_BodyTypesOfPawnKind">
				<whitelist>
					<li>Male</li>
					<li>Female</li>
					<li>Hulk</li>
					<li>Thin</li>
				</whitelist>
				<blacklist>
					<li>Fat</li>
					<li>Baby</li>
					<li>Child</li>
				</blacklist>
				<priority>
					<!--When violates the black/whitelist, selected from these-->
				</priority>
