	<PawnKindDef Name="SWEriadu_Base" Abstract="True">
		<defaultFactionType>guy762_SWWarlordsFaction_EriaduAuthority</defaultFactionType>
		<race>Human</race>

		<backstoryCryptosleepCommonality>0.08</backstoryCryptosleepCommonality>
