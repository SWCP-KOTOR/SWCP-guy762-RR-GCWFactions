		<maxGenerationAge>55</maxGenerationAge>
		
		
		<xenotypeSet Inherit ="False">
			  <xenotypeChances>
				<Baseliner MayRequire="Ludeon.RimWorld.Biotech">0.80</Baseliner>
				<guy762_xenotype_devaronian MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_devaronian>
				<guy762_xenotype_iridonian MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_iridonian>
				<guy762_xenotype_rodian MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_rodian>
				<guy762_xenotype_togruta MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_togruta>
				<guy762_xenotype_twilek MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_twilek>
				<guy762_xenotype_zabrak MayRequire="guy762.StarWarsXenotypes">0.02</guy762_xenotype_zabrak>
				<guy762_xenotype_zabrakDathomiri MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_zabrakDathomiri>
			  </xenotypeChances>
		</xenotypeSet>
		<useFactionXenotypes>false</useFactionXenotypes>
		
		<itemQuality>Poor</itemQuality>
		<gearHealthRange>0.7~2.3</gearHealthRange>
		<apparelMoney>14000~17000</apparelMoney>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>
		<apparelTags>
			<li>KotORUtility_weakgrenade</li>
			<li>KotORUtility_utilitygrenade</li>
			<li>SWWarlordsAccessory_scumtrooper_poncho</li>
			<li>SWGCWSpecificApparelItem_NoRangefinderMandoHelmet</li>
			<li>SWGCWSpecificApparelItem_MandoArmor</li>
			<li>SWCPSpecificApparelItem_DyeableFatigues</li>
		</apparelTags>
		<apparelRequired Inherit="False">
			<li>guy762_MandoGCWHelmet</li>
			<li>guy762_MandoGCWArmor_battle</li>
			<li>guy762_Bodysuit_Dyeable</li>
		</apparelRequired>
		<specificApparelRequirements>
			<li>
				<apparelLayer>OnSkin</apparelLayer> <!-- TCW death watch blue -->
				<color>(70,100,165)</color>
			</li>
			<!-- <li> -->
				<!-- <apparelLayer>Middle</apparelLayer> -->
				<!-- <color>(90,120,85)</color> -->
			<!-- </li> -->
			<!-- <li> -->
				<!-- <apparelLayer>Overhead</apparelLayer> -->
				<!-- <color>(90,120,85)</color> -->
			<!-- </li> -->
		</specificApparelRequirements>
		
		<weaponMoney>2100</weaponMoney>
		<weaponTags>
			<li>SWRanged_GALAAR15carbine</li>
		</weaponTags>
		
		<techHediffsMoney>250~750</techHediffsMoney>
		<techHediffsChance>1</techHediffsChance>
		<techHediffsTags>
			<li>Spacer</li>
			<li>Advanced</li>
			<li>AdvancedWeapon</li>
		</techHediffsTags>
		
		<inventoryOptions>
			<skipChance>0.25</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>guy762_medpac</thingDef>
					<countRange>1~3</countRange>
				</li>
				<li>
				  <thingDef>guy762_stim_battle</thingDef>
				  <countRange>1~2</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
		<skills>
			<li>
				<skill>Shooting</skill>
				<range>7~11</range>
			</li>
			<li>
				<skill>Melee</skill>
				<range>4~7</range>
			</li>
		</skills>
		
		<initialWillRange>5~10</initialWillRange>
		<initialResistanceRange>10~20</initialResistanceRange>
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>
		
		<modExtensions Inherit="False">
			<li Class="BodyTypeForPawnKind.ModExtension_BodyTypesOfPawnKind">
			  <whitelist>
			  </whitelist>
			  <blacklist>
				<li>Fat</li>
				<li>Baby</li>
				<li>Child</li>
			  </blacklist>
			  <priority>
				<!--When violates the black/whitelist, selected from these-->
			  </priority>
			  <!--Align body gender to pawn's gender (default: True)-->
			  <checkGender>True</checkGender>
			</li>
		</modExtensions>
	</PawnKindDef>
	
	
	
	
	
	
	
	
