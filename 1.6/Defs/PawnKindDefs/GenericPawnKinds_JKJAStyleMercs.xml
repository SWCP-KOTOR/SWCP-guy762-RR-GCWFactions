<Defs>
	
	
	
	
	
	
	
	
  
	<!-- jedi outcast/academy-style goons -->
			
  <PawnKindDef Name="SWScum_JKRodian" ParentName="SWMercBase">
    <defName>SWScum_JKRodian</defName>
	<label>underworld thug</label>
    <combatPower>40</combatPower>
	
	<useFactionXenotypes>false</useFactionXenotypes>
	<xenotypeSet>
      <xenotypeChances>
		<guy762_xenotype_rodian MayRequire="guy762.StarWarsXenotypes">999</guy762_xenotype_rodian>
      </xenotypeChances>
    </xenotypeSet>

    <itemQuality>Poor</itemQuality>
    <apparelMoney>100~300</apparelMoney>
    <apparelAllowHeadgearChance>0.25</apparelAllowHeadgearChance>
    <apparelTags>
	  <li>KotOREquipment_basic</li>
	  <li>SWCPSpecificApparelItem_StripedFatigues</li>
    </apparelTags>
	<apparelRequired>
	   <li>guy762_Bodysuit_striped</li>
	</apparelRequired>
	<specificApparelRequirements>
		<li>
			<apparelLayer>OnSkin</apparelLayer>
			<color>(195,240,250)</color>
		</li>
	</specificApparelRequirements>
	
    <weaponMoney>250</weaponMoney>
    <weaponTags>
	  <li>SWRanged_DL18pistol</li>
	  <li>SWRanged_E5rifle</li>
    </weaponTags>
	<biocodeWeaponChance>0.1</biocodeWeaponChance>
	
	<skills>
		<li>
			<skill>Shooting</skill>
			<range>4~8</range>
		</li>
		<li>
			<skill>Melee</skill>
			<range>4~8</range>
		</li>
	</skills>
	
    <initialWillRange>0.2~1.6</initialWillRange>
    <initialResistanceRange>3~7</initialResistanceRange>
	<isFighter>true</isFighter>
	<apparelIgnoreSeasons>true</apparelIgnoreSeasons>
  </PawnKindDef>
  
  
  
  
  
