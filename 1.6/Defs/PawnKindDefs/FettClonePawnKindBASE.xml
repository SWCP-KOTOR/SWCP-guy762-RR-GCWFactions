	<PawnKindDef Name="SWCP_FettCloneBase_MaleBodyForTroopers" ParentName="SWCP_FettCloneBase" Abstract="True">
	
		<modExtensions>

			<li Class="BodyTypeForPawnKind.ModExtension_BodyTypesOfPawnKind">
				<whitelist>
					<li>Male</li>
				</whitelist>
				<blacklist>
				</blacklist>
				<priority>
					<!--When violates the black/whitelist, selected from these-->
					<li>Male</li>
				</priority>
				<!--Align body gender to pawn's gender (default: True)-->
				<checkGender>False</checkGender>
			</li>
		
		</modExtensions>
	</PawnKindDef>	
	
	<PawnKindDef Name="SWCP_FettCloneBase_HulkBodyForCommandos" ParentName="SWCP_FettCloneBase" Abstract="True">
	
