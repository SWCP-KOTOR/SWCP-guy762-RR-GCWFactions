		<initialWillRange>5~10</initialWillRange>
		<initialResistanceRange>0~0</initialResistanceRange>
		
		<disallowedTraits Inherit="False">
			<li>CreepyBreathing</li>
		</disallowedTraits>
		<disallowedTraitsWithDegree>
			<Beauty>-1</Beauty>
			<Beauty>-2</Beauty>
		</disallowedTraitsWithDegree>
		<humanPregnancyChance>0.25</humanPregnancyChance>
		
		<startingHediffs>
			<li><def>SWCPHediff_DoubleAgent</def><chance>1</chance></li>
			<li><def>SWCPNPCPackageHediff_needdisabler</def><chance>1</chance></li>
		</startingHediffs>
		<modExtensions>
			<li Class="EBSGFramework.ForceStartingHediffsExtension" />
			<li Class="BigAndSmall.PawnKindExtension">
				<skillRange>
					<li>
						<skill>Melee</skill>
						<range>4~6</range>
					</li>
					<li>
						<skill>Social</skill>
						<range>8~10</range>
					</li>
				</skillRange>
				<skillRangeApplyToBabies>false</skillRangeApplyToBabies>
			</li>
			<li Class="BodyTypeForPawnKind.ModExtension_BodyTypesOfPawnKind">
			  <whitelist>
				<li>Male</li>
				<li>Female</li>
				<li>Thin</li>
			  </whitelist>
			  <blacklist>
				<!-- <li>Thin</li> -->
				<!-- <li>Fat</li> -->
				<!-- <li>Baby</li> -->
				<!-- <li>Child</li> -->
			  </blacklist>
			  <priority>
				<!--When violates the black/whitelist, selected from these-->
			  </priority>
			  <!--Align body gender to pawn's gender (default: True)-->
			  <checkGender>True</checkGender>
			</li>
			<li Class="BodyTypeForPawnKind.ModExtension_ForcedStyleItem">
				<forcedBeard>NoBeard</forcedBeard>
			</li>
		</modExtensions>
	</PawnKindDef>
	
	
	
</Defs>
