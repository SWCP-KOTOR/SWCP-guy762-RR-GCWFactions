				<guy762_xenotype_mirialan MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_mirialan>
				<guy762_xenotype_nelvaanian MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_nelvaanian>
				<guy762_xenotype_pantoran MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_pantoran>
				<guy762_xenotype_quarren MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_quarren>
				<guy762_xenotype_rodian MayRequire="guy762.StarWarsXenotypes">0.05</guy762_xenotype_rodian>
				<guy762_xenotype_twilek MayRequire="guy762.StarWarsXenotypes">0.35</guy762_xenotype_twilek>
				<guy762_xenotype_umbaran MayRequire="guy762.StarWarsXenotypes">0.01</guy762_xenotype_umbaran>
				<guy762_xenotype_zabrak MayRequire="guy762.StarWarsXenotypes">0.10</guy762_xenotype_zabrak>
				<guy762_xenotype_zeltron MayRequire="guy762.StarWarsXenotypes">0.20</guy762_xenotype_zeltron>
			</xenotypeChances>
		</xenotypeSet>
		<useFactionXenotypes>false</useFactionXenotypes>

		<apparelMoney>1500~5500</apparelMoney>
		<apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
		<apparelTags>
			<li>SWCPSpecificGadgetItem_StealthBeltDefault</li>
			<li>SWCPSpecificApparelItem_KotOR2DancerOutfit</li>
		</apparelTags>
		<apparelRequired>
			<li>SWCP_stealthbelt_default</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Apparel_Collar</li>
			<li>guy762_SlaveOutfit_KotORII</li>
		</apparelRequired>
		<specificApparelRequirements>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<apparelLayer>Overhead</apparelLayer>
				<stuff>Gold</stuff>
			</li>
			<li>
				<apparelLayer>OnSkin</apparelLayer>
				<color>(125,50,50)</color> <!-- rebel red -->
			</li>
		</specificApparelRequirements>

		<!-- <biocodeWeaponChance>0</biocodeWeaponChance> -->
		<!-- <weaponMoney>200</weaponMoney> -->
		<!-- <weaponTags> -->
			<!-- <li>SWMelee_Vibrodagger</li> -->
		<!-- </weaponTags> -->

		<inventoryOptions>
			<skipChance>0</skipChance>
			<subOptionsTakeAll>
				<li>
					<thingDef>guy762_Vibrodagger</thingDef>
					<countRange>0~1</countRange>
				</li>
			</subOptionsTakeAll>
			<subOptionsChooseOne>
				<li>
					<thingDef>SWCP_FactionIntelDatapad_HuttCartels</thingDef>
					<countRange>0~1</countRange>
				</li>
				<li>
