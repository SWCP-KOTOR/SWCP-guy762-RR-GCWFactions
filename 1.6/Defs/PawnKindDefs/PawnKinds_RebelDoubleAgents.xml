	<PawnKindDef Name="SWRebel_DoubleAgentHuttSlave" ParentName="SWRebel_Base">
		<defName>SWRebel_DoubleAgentHuttSlave</defName>
		<label>double agent</label>
		<combatPower>40</combatPower>
		<minGenerationAge>18</minGenerationAge>
		<maxGenerationAge>25</maxGenerationAge>
		<itemQuality>Excellent</itemQuality>
		
		<fixedGender>Female</fixedGender>
		
		<xenotypeSet Inherit="False">
			<xenotypeChances>
				<Baseliner>0.15</Baseliner>			<!-- TOTAL: 0.99 -->
