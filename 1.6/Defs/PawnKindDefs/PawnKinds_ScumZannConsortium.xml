	<PawnKindDef Name="SWZannCon_Base" Abstract="True">
		<race>Human</race>
		<defaultFactionType>guy762_SWWarlordsFaction_ZannConsortium</defaultFactionType>
		<minGenerationAge>18</minGenerationAge>
		<maxGenerationAge>45</maxGenerationAge>
		
		<fleeHealthThresholdRange>0.5~0.6</fleeHealthThresholdRange>
		
		<chemicalAddictionChance>0.35</chemicalAddictionChance>
		<appearsRandomlyInCombatGroups>false</appearsRandomlyInCombatGroups>
		<backstoryCryptosleepCommonality>0.05</backstoryCryptosleepCommonality>
		<invNutrition>1</invNutrition>
		<invFoodDef>MealSurvivalPack</invFoodDef>
		<biocodeWeaponChance>0.95</biocodeWeaponChance>
		<ignoreIdeoApparelColors>true</ignoreIdeoApparelColors>
		<!--apparelTags>
		  <li>KotORHeadband_gasmask</li>
		</apparelTags-->
		
		<allowOldAgeInjuries>False</allowOldAgeInjuries>
		<isFighter>true</isFighter>
		<requiredWorkTags>
		  <li>Violent</li>
		  <li>Hauling</li>
		</requiredWorkTags>
		<disallowedTraits>
		  <li>Nudist</li>
		</disallowedTraits>

		<inventoryOptions>
		  <skipChance>0.5</skipChance>
		  <subOptionsTakeAll>
			<li>
			  <thingDef>KOTOR_Deathstick</thingDef>
			  <countRange>2~3</countRange>
			</li>
		  </subOptionsTakeAll>
		</inventoryOptions>
		
		<pawnGroupDevelopmentStage>Adult</pawnGroupDevelopmentStage>
	</PawnKindDef>
	
	
	
	
	
