	<PawnKindDef Name="SWMaldrood_Base" Abstract="True">
		<defaultFactionType>guy762_SWWarlordsFaction_GreaterMaldrood</defaultFactionType>
		<race>Human</race>

		<backstoryCryptosleepCommonality>0.08</backstoryCryptosleepCommonality>
		<!-- <backstoryFiltersOverride> -->
			<!-- <li> -->
				<!-- <categories> -->
					<!-- <li>Pirate</li> -->
					<!-- <li>Offworld</li> -->
					<!-- <li>Outlander</li> -->
					<!-- <li>ImperialFighter</li> -->
					<!-- <li>Madman</li> -->
				<!-- </categories> -->
			<!-- </li> -->
		<!-- </backstoryFiltersOverride> -->

		<chemicalAddictionChance>0.1</chemicalAddictionChance>
		<!--combatEnhancingDrugsChance>0.15</combatEnhancingDrugsChance>
		<combatEnhancingDrugsCount>0~2</combatEnhancingDrugsCount-->
		<invNutrition>1</invNutrition>
		<invFoodDef>MealNutrientPaste</invFoodDef>

		<apparelAllowHeadgearChance>0.5</apparelAllowHeadgearChance>
		<apparelMoney>4000~5000</apparelMoney>

		<techHediffsTags>
			<li>Spacer</li>
			<li>Advanced</li>
			<li>AdvancedWeapon</li>
		</techHediffsTags>
		
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>


		<disallowedTraits>
			<li>BodyPurist</li>
			<li>Nudist</li>
		</disallowedTraits>

		<isFighter>true</isFighter>
		<requiredWorkTags>
			<li>Violent</li>
			<li>Hauling</li>
		</requiredWorkTags>
		
		<pawnGroupDevelopmentStage>Adult</pawnGroupDevelopmentStage>
	</PawnKindDef>

	<PawnKindDef Name="SWMaldrood_TrooperBase" ParentName="SWMaldrood_Base" Abstract="True">
		<modExtensions>
			<li Class="BodyTypeForPawnKind.ModExtension_BodyTypesOfPawnKind">
				<whitelist>
					<li>Male</li>
					<li>Female</li>
					<li>Hulk</li>
					<li>Thin</li>
				</whitelist>
				<blacklist>
					<li>Fat</li>
					<li>Baby</li>
					<li>Child</li>
				</blacklist>
				<priority>
					<!--When violates the black/whitelist, selected from these-->
				</priority>
				<!--Align body gender to pawn's gender (default: True)-->
				<checkGender>True</checkGender>
			</li>
		</modExtensions>

		<disallowedTraits>
			<li>Wimp</li>
		</disallowedTraits>
	</PawnKindDef>
	
	

	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
