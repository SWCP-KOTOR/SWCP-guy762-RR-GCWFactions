<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<AbilityDef ParentName="SWPotF_TacticDelegationAbilityBASE">
		<defName>SWPotF_TacticDelegationAbility_takecover</defName>
		<label>delegate tactic: Take Cover</label>
		<description>Distribute temporary "Take Cover" tactical orders to a subordinate.</description>
		<descriptionHyperlinks>
			<AbilityDef>SWPotF_TacticAbility_TakeCover</AbilityDef>
		</descriptionHyperlinks>
		<iconPath>UI/EaWIcons/Delegation/Delegate_TakeCover</iconPath>
		
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWPotF_DelegatedTacticHediff_takecover</hediffDef>
				<onlyApplyToSelf>false</onlyApplyToSelf>
				<onlyBrain>True</onlyBrain>
				<replaceExisting>true</replaceExisting>
				<applicableToMechs>False</applicableToMechs>
			</li>
		</comps>
	</AbilityDef>
	
	
	

	<HediffDef ParentName="SWPotF_DelegatedTacticHediffBASE">
		<defName>SWPotF_DelegatedTacticHediff_takecover</defName>
		<label>temporary tactical orders: Take Cover</label>
		<description>.</description>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDef>SWPotF_TacticAbility_TakeCover</abilityDef>
			</li>
		</comps>
	</HediffDef>














  
	<AbilityDef ParentName="SWPotF_TacticAbilityValidatorBASE">
		<defName>SWPotF_TacticAbility_TakeCover</defName>
		<label>Take Cover</label>
		<description>Order your units to hunker down and brace for incoming enemy attacks, increasing their damage resistance but making them immobile and reducing their aiming speed.</description>
		<iconPath>UI/EaWIcons/TakeCover</iconPath>
		<warmupMoteSocialSymbol>UI/EaWIcons/TakeCover</warmupMoteSocialSymbol>
		<uiOrder>762</uiOrder>
		<hotKey>Misc10</hotKey>
		
		<aiCanUse>true</aiCanUse>
		<ai_IsOffensive>false</ai_IsOffensive>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<groupAbility>true</groupAbility>
		<ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
		<canUseAoeToGetTargets>true</canUseAoeToGetTargets>
		
		<cooldownTicksRange>2</cooldownTicksRange>
		<targetRequired>false</targetRequired>
		<statBases>
			<Ability_Duration>240</Ability_Duration>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<verbProperties>		
			<verbClass>Verb_CastAbility</verbClass>
			<violent>false</violent>
			<range>10</range>
			<requireLineOfSight>false</requireLineOfSight>
			<drawAimPie>False</drawAimPie>
			<warmupTime>0.5</warmupTime>
			<soundCast>kotorsound_EaWBunkerGarrison_in</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
				
				<neverTargetIncapacitated>true</neverTargetIncapacitated>
				<!-- <neverTargetHostileFaction>true</neverTargetHostileFaction> don't use this, it only means hostile to the player -->
			</targetParams>
		</verbProperties>
		
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWPotF_TacticAbilityHediff_TakeCover</hediffDef>
				<severity>1</severity>
				<applicableToMechs>False</applicableToMechs>
				<!-- <onlyBrain>True</onlyBrain> -->
				<!-- <onlyApplyToSelf>False</onlyApplyToSelf> -->
				<applyToSelf>true</applyToSelf>
				<applyToTarget>true</applyToTarget>
				<replaceExisting>true</replaceExisting>
			</li>
			<!-- <li Class="CompProperties_AbilityFleckOnTarget"> -->
				<!-- <fleckDef>PsycastPsychicEffect</fleckDef> -->
				<!-- <sound>kotorsound_force_JAteamheal</sound> -->
			<!-- </li> -->
		</comps>
	</AbilityDef>
	
	
	
	
	
	<HediffDef ParentName="SWPotF_TacticAbilityHediff_BreaksInMentalStateBASE">
        <defName>SWPotF_TacticAbilityHediff_TakeCover</defName>
        <label>Take Cover strategy</label>
        <description>This pawn is bracing for incoming enemy attacks.</description>
		<defaultLabelColor>(255,255,135)</defaultLabelColor> <!-- soft yellow -->
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <stages>
            <li>
				<minSeverity>1</minSeverity>
				<becomeVisible>true</becomeVisible>
				<statFactors>
					<MoveSpeed>0</MoveSpeed>
					<CrawlSpeed>0.25</CrawlSpeed>
					<StaggerDurationFactor>0</StaggerDurationFactor>
				</statFactors>
				<statOffsets>
					<IncomingDamageFactor>-0.5</IncomingDamageFactor>
					<PainShockThreshold>0.25</PainShockThreshold>
					<MentalBreakThreshold>-0.25</MentalBreakThreshold>
					
					<AimingDelayFactor>1</AimingDelayFactor>
				</statOffsets>
			</li>
        </stages>
        <comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDef>SWPotF_TacticAbility_TakeCoverCancel</abilityDef>
			</li>
			<li><compClass>SWCP_Lee_Misc.Hediffs.HediffComp_Prone</compClass></li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
            <li Class="HediffCompProperties_Disappears">
                <!-- <disappearsAfterTicks>60000</disappearsAfterTicks> -->
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
    </HediffDef>
	
	
	
	
	
  
  
    <AbilityDef>
		<defName>SWPotF_TacticAbility_TakeCoverCancel</defName>
		<label>cancel Take Cover</label>
		<description>Deactivate an active Take Cover ability.</description>
		<iconPath>UI/EaWIcons/Cancel_Generic</iconPath>
		<!--hotKey>Misc12</hotKey-->
		<writeCombatLog>True</writeCombatLog>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<aiCanUse>true</aiCanUse>
		<ai_IsOffensive>false</ai_IsOffensive>
		<!-- <aiCanUse>false</aiCanUse> -->
		
		<targetRequired>false</targetRequired>
		<statBases>
			<Ability_Duration>5</Ability_Duration>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<violent>false</violent>
			<range>10</range>
			<requireLineOfSight>false</requireLineOfSight>
			<drawAimPie>False</drawAimPie>
			<warmupTime>0.5</warmupTime>
			<soundCast>kotorsound_EaWBunkerGarrison_out</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
				
				<neverTargetHostileFaction>true</neverTargetHostileFaction>
			</targetParams>
		</verbProperties>
		<comps>
		  <li Class="EBSGFramework.CompProperties_AbilityRemoveMultipleHediffs">
				<compClass>EBSGFramework.CompAbilityEffect_RemoveMultipleHediffs</compClass>
				<hediffs>
					<li>SWPotF_TacticAbilityHediff_TakeCover</li>
				</hediffs>
				<applyToBoth>True</applyToBoth>
				<recursiveChecks>3</recursiveChecks> <!--No reason to have this, but maybe I'm paranoid-->
			</li>
		  <!-- <li Class="CompProperties_AbilityFleckOnTarget"> -->
			<!-- <sound>kotorsound_cloak</sound> -->
		  <!-- </li> -->
		</comps>
		<modExtensions>
			<li Class="CastableInUnconscious.ModExtension_CastableInUnconscious">
				<castableInUnconscious>false</castableInUnconscious>
				<castableInMentalbreak>true</castableInMentalbreak>
			</li>
		</modExtensions>
	</AbilityDef>

 

</Defs>