<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<AbilityDef ParentName="SWPotF_TacticDelegationAbilityBASE">
		<defName>SWPotF_TacticDelegationAbility_ambush</defName>
		<label>delegate tactic: Ambush</label>
		<description>Distribute temporary "Ambush" tactical orders to a subordinate.</description>
		<descriptionHyperlinks>
			<AbilityDef>SWPotF_TacticAbility_Ambush</AbilityDef>
		</descriptionHyperlinks>
		<iconPath>UI/EaWIcons/Delegation/Delegate_Ambush</iconPath>
		
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWPotF_DelegatedTacticHediff_ambush</hediffDef>
				<onlyApplyToSelf>false</onlyApplyToSelf>
				<onlyBrain>True</onlyBrain>
				<replaceExisting>true</replaceExisting>
				<applicableToMechs>False</applicableToMechs>
			</li>
		</comps>
	</AbilityDef>
	
	
	

	<HediffDef ParentName="SWPotF_DelegatedTacticHediffBASE">
		<defName>SWPotF_DelegatedTacticHediff_ambush</defName>
		<label>temporary tactical orders: Ambush</label>
		<description>.</description>
		<comps>
			<li Class="HediffCompProperties_GiveAbility">
				<abilityDef>SWPotF_TacticAbility_Ambush</abilityDef>
			</li>
		</comps>
	</HediffDef>














  
	<AbilityDef ParentName="SWPotF_TacticAbilityValidatorBASE">
		<defName>SWPotF_TacticAbility_Ambush</defName>
		<label>Ambush</label>
		<description>Position your units for a surprise attack against unsuspecting enemies. When activated, your units will become invisible but unable to attack or move (so be sure to position them correctly before activating).</description>
		<descriptionHyperlinks>
			<AbilityDef>SWPotF_TacticAbility_AmbushAttack</AbilityDef>
		</descriptionHyperlinks>
		<iconPath>UI/EaWIcons/Ambush</iconPath>
		<warmupMoteSocialSymbol>UI/EaWIcons/Ambush</warmupMoteSocialSymbol>
		<uiOrder>762</uiOrder>
		<hotKey>Misc10</hotKey>
		
		<aiCanUse>true</aiCanUse>
		<ai_IsOffensive>false</ai_IsOffensive>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<groupAbility>true</groupAbility>
		<ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
		<canUseAoeToGetTargets>true</canUseAoeToGetTargets>
		
		<cooldownTicksRange>12000</cooldownTicksRange>
		<targetRequired>false</targetRequired>
		<stunTargetWhileCasting>True</stunTargetWhileCasting>
		<statBases>
			<Ability_Duration>600</Ability_Duration>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<verbProperties>		
			<verbClass>Verb_CastAbility</verbClass>
			<violent>false</violent>
			<range>10</range>
			<requireLineOfSight>false</requireLineOfSight>
			<drawAimPie>True</drawAimPie>
			<warmupTime>10</warmupTime>
			<soundCast>kotorsound_EaWCloak_on</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
				
				<neverTargetIncapacitated>true</neverTargetIncapacitated>
				<!-- <neverTargetHostileFaction>true</neverTargetHostileFaction> don't use this, it checks for factions automatically -->
			</targetParams>
		</verbProperties>
		
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWPotF_TacticAbilityHediff_AmbushWaiting</hediffDef>
				<applicableToMechs>False</applicableToMechs>
				<severity>1</severity>
				<!-- <onlyBrain>True</onlyBrain> -->
				<!-- <onlyApplyToSelf>False</onlyApplyToSelf> -->
				<!-- <replaceExisting>true</replaceExisting> -->
			</li>
			<!-- <li Class="CompProperties_AbilityFleckOnTarget"> -->
				<!-- <fleckDef>PsycastPsychicEffect</fleckDef> -->
				<!-- <sound>kotorsound_force_JAteamheal</sound> -->
			<!-- </li> -->
		</comps>
	</AbilityDef>
	
	
	
	
	
	<HediffDef ParentName="SWPotF_TacticAbilityHediff_BreaksInMentalStateBASE">
        <defName>SWPotF_TacticAbilityHediff_AmbushWaiting</defName>
        <label>Ambush strategy (waiting)</label>
        <description>This pawn is lying in wait as part of an ambush.</description>
		<defaultLabelColor>(255,255,135)</defaultLabelColor> <!-- soft yellow -->
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <stages>
            <li>
				<minSeverity>1</minSeverity>
				<becomeVisible>true</becomeVisible>
				<disabledWorkTags>Violent</disabledWorkTags>
				<statFactors>
					<MoveSpeed>0</MoveSpeed>
					<CrawlSpeed>0</CrawlSpeed>
				</statFactors>
				<statOffsets>
					<MeleeDodgeChance>0</MeleeDodgeChance>
				</statOffsets>
			</li>
			<!-- <li><minSeverity>1</minSeverity></li> -->
			<!-- <li><minSeverity>2</minSeverity></li> -->
			<!-- <li><minSeverity>3</minSeverity></li> -->
			<!-- <li><minSeverity>4</minSeverity></li> -->
			<!-- <li><minSeverity>5</minSeverity></li> -->
			<!-- <li><minSeverity>6</minSeverity></li> -->
			<!-- <li><minSeverity>7</minSeverity></li> -->
			<!-- <li><minSeverity>8</minSeverity></li> -->
			<!-- <li><minSeverity>9</minSeverity></li> -->
			<!-- <li><minSeverity>10</minSeverity></li> -->
        </stages>
        <comps>
            <li Class="EBSGFramework.HediffCompProperties_SeverityByNearbyPawns">
                <onlyEnemies>True</onlyEnemies>
                <!-- <includeSelf>False</includeSelf> -->
                <range>15</range>
            </li>
			<li Class="EBSGFramework.HediffCompProperties_GiveAbilityAtSeverity">
                <abilitiesAtSeverities>
                    <li>
                        <abilityDef>SWPotF_TacticAbility_AmbushCancel</abilityDef>
                    </li>
					<li>
                        <abilityDef>SWPotF_TacticAbility_AmbushAttack</abilityDef>
                        <validSeverity>2~99999</validSeverity>
                    </li>
                </abilitiesAtSeverities>
            </li>
			
			<li><compClass>SWCP.Core.Hediffs.HediffComp_Prone</compClass></li>
			<li Class="HediffCompProperties_Invisibility">
				<visibleToPlayer>true</visibleToPlayer>
			</li>
			
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
            <li Class="HediffCompProperties_Disappears">
                <!-- <disappearsAfterTicks>60000</disappearsAfterTicks> -->
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
    </HediffDef>
	
	
	
	
	<AbilityDef>
		<defName>SWPotF_TacticAbility_AmbushAttack</defName>
		<label>Spring Ambush</label>
		<description>Call all hidden units to commence attacking nearby enemies. For 5 seconds, all affected pawns will remain immobile but will have greatly enhanced attack speeds and will take significantly reduced damage. After 5 seconds have passed, normal control will return to all affected pawns.\n\nActivating this will also deactivate any other invisibility effects (given through Stealth Field Generators or Force abilities) present on pawns within the radius.</description>
		<!-- <descriptionHyperlinks> -->
			<!-- <HediffDef>SWPotF_hediff_ForceHeal</HediffDef> -->
		<!-- </descriptionHyperlinks> -->
		<iconPath>UI/EaWIcons/Ambush_red</iconPath>
		<warmupMoteSocialSymbol>UI/EaWIcons/Ambush_red</warmupMoteSocialSymbol>
		<uiOrder>762</uiOrder>
		<hotKey>Misc10</hotKey>
		<writeCombatLog>True</writeCombatLog>
		
		<aiCanUse>true</aiCanUse>
		<ai_IsOffensive>false</ai_IsOffensive>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<!-- <groupAbility>true</groupAbility> -->
		
		<targetRequired>false</targetRequired>
		<statBases>
			<Ability_Duration>5</Ability_Duration>
			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<verbProperties>		
			<verbClass>Verb_CastAbility</verbClass>
			<violent>false</violent>
			<range>10</range>
			<soundCast>kotorsound_EaWCloak_off</soundCast>
			<requireLineOfSight>false</requireLineOfSight>
			<drawAimPie>False</drawAimPie>
			<warmupTime>0</warmupTime>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
				
				<neverTargetHostileFaction>true</neverTargetHostileFaction>
			</targetParams>
		</verbProperties>
		
		<comps>
			<li Class="EBSGFramework.CompProperties_AbilityRemoveMultipleHediffs">
                <compClass>EBSGFramework.CompAbilityEffect_RemoveMultipleHediffs</compClass>
                <hediffs>
                    <li>SWPotF_TacticAbilityHediff_AmbushWaiting</li>
					
                    <li>SWCP_StealthMode</li>
					
					<li>SWPotF_hediff_ForceCloak</li>
					<li>SWPotF_hediff_KnightCloak</li>
					<li>SWPotF_hediff_MstCloak</li>
					
					<li>guy762_StealthField</li>
					<li>guy762_StealthField_sixty</li>
					<li>guy762_StealthField_twomin</li>
					<li>guy762_StealthField_threemin</li>
					<li>guy762_StealthField_fourmin</li>
					
					<li>guy762_StealthField_defel</li>
                </hediffs>
                <recursiveChecks>3</recursiveChecks> <!--No reason to have this, but maybe I'm paranoid-->
            </li>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>SWPotF_TacticAbilityHediff_AmbushAttacking</hediffDef>
				<applicableToMechs>False</applicableToMechs>
			</li>
			<!-- <li Class="CompProperties_AbilityFleckOnTarget"> -->
				<!-- <fleckDef>PsycastPsychicEffect</fleckDef> -->
				<!-- <sound>kotorsound_force_JAteamheal</sound> -->
			<!-- </li> -->
		</comps>
	</AbilityDef>
  
  
  
  
  
  
  
	<HediffDef ParentName="SWPotF_TacticAbilityHediff_BreaksInMentalStateBASE">
        <defName>SWPotF_TacticAbilityHediff_AmbushAttacking</defName>
        <label>Ambush Strategy (attacking)</label>
        <description>This pawn is attacking as part of an ambush.</description>
		<defaultLabelColor>(255,255,135)</defaultLabelColor> <!-- soft yellow -->
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <stages>
            <li>
				<minSeverity>1</minSeverity>
				<becomeVisible>true</becomeVisible>
				<statFactors>
					<MoveSpeed>0</MoveSpeed>
				</statFactors>
				<statOffsets>
					<MeleeDodgeChance>0.5</MeleeDodgeChance>
					<IncomingDamageFactor>-0.5</IncomingDamageFactor>
					
					<MeleeCooldownFactor>-0.5</MeleeCooldownFactor>
					<RangedCooldownFactor>-0.5</RangedCooldownFactor>
					<AimingDelayFactor>-1</AimingDelayFactor>
				</statOffsets>
			</li>
        </stages>
        <comps>
			<li Class="SWCP_Misc.HediffCompProperties_DisappearsOnDowned"/>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
            <li Class="HediffCompProperties_Disappears">
                <!-- <disappearsAfterTicks>60000</disappearsAfterTicks> -->
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
    </HediffDef>
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
    <AbilityDef>
		<defName>SWPotF_TacticAbility_AmbushCancel</defName>
		<label>cancel Ambush</label>
		<description>Deactivate an active Ambush ability.</description>
		<iconPath>UI/EaWIcons/Cancel_Generic</iconPath>
		<!--hotKey>Misc12</hotKey-->
		<writeCombatLog>True</writeCombatLog>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<aiCanUse>false</aiCanUse>
		<targetRequired>false</targetRequired>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>10</range>
			<requireLineOfSight>false</requireLineOfSight>
			<drawAimPie>False</drawAimPie>
			<warmupTime>0.5</warmupTime>
			<soundCast>kotorsound_cloak</soundCast>
			<targetParams>
				<canTargetSelf>true</canTargetSelf>
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>false</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
				
				<neverTargetHostileFaction>true</neverTargetHostileFaction>
			</targetParams>
		</verbProperties>
		<comps>
		  <li Class="EBSGFramework.CompProperties_AbilityRemoveMultipleHediffs">
				<compClass>EBSGFramework.CompAbilityEffect_RemoveMultipleHediffs</compClass>
				<hediffs>
					<li>SWPotF_TacticAbilityHediff_AmbushWaiting</li>
				</hediffs>
				<applyToBoth>True</applyToBoth>
				<recursiveChecks>3</recursiveChecks> <!--No reason to have this, but maybe I'm paranoid-->
			</li>
		  <!-- <li Class="CompProperties_AbilityFleckOnTarget"> -->
			<!-- <sound>kotorsound_cloak</sound> -->
		  <!-- </li> -->
		</comps>
	</AbilityDef>

 

</Defs>