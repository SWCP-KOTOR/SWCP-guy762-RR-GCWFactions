		<nameMaker>NamerScarlands</nameMaker>
	</FeatureDef>
	
	<BiomeDef>
		<defName>SWCPBiome_Urban</defName>
		<label>urban</label>
		<description>Ruins of an ancient city which was destroyed by weapons of mass destruction. Water here is toxic and scaria runs rampant among the animals. Mechanoids lurk among the shattered buildings, waiting to awaken and kill again.</description>
		<settleWarning>Scarlands are inhabited by dangerous insects and rogue mechanoids. Water is toxic and scaria runs rampant among the animals.</settleWarning>
		
		<!-- <workerClass>BiomeWorker_TemperateSwamp</workerClass> -->
		<workerClass>BiomeWorker_Scarlands</workerClass>
		<!-- <workerClass>BiomesKit.UniversalBiomeWorker</workerClass> -->
		
		<animalDensity>4</animalDensity>
		<plantDensity>0.4</plantDensity>
		<wildAnimalScariaChance>0.1</wildAnimalScariaChance>
		
		<settlementSelectionWeight>1</settlementSelectionWeight>
		<movementDifficulty>1</movementDifficulty>
		<lakeBeachTerrain>Gravel</lakeBeachTerrain>
		<mudTerrain>MarshyTerrain</mudTerrain>
		<riverbankTerrain>MarshyTerrain</riverbankTerrain>
		<riverbankSizeRange>6~8</riverbankSizeRange>
		<texture>World/Biomes/Urban</texture>
		
		<forageability>0.25</forageability>
		<foragedFood>RawBerries</foragedFood>
		<wildPlantRegrowDays>20</wildPlantRegrowDays>
		<maxFishPopulation>0</maxFishPopulation>
		
		<diseaseMtbDays>50</diseaseMtbDays>
		<pollutionOffset>0.05</pollutionOffset>
		
		<waterShallowTerrain>ToxicWaterShallow</waterShallowTerrain>
		<waterDeepTerrain>ToxicWaterDeep</waterDeepTerrain>
		<oceanShallowTerrain>ToxicWaterOceanShallow</oceanShallowTerrain>
		<oceanDeepTerrain>ToxicWaterOceanDeep</oceanDeepTerrain>
		<waterMovingShallowTerrain>ToxicWaterMovingShallow</waterMovingShallowTerrain>
