				<SWCPCivilian_ugnaught>5</SWCPCivilian_ugnaught>
				<SWCPCivilian_spacer>1</SWCPCivilian_spacer>
				
				<SWCPDroidColonistBnS_PitDroid>3</SWCPDroidColonistBnS_PitDroid>
				<SWCPDroidColonistBnS_ASP7LaborDroid>2</SWCPDroidColonistBnS_ASP7LaborDroid>
				<SWCPDroidColonistBnS_R4AstDrd>1</SWCPDroidColonistBnS_R4AstDrd>
				<SWCPDroidColonistBnS_CLLM2BinaryLoadlifter>0.5</SWCPDroidColonistBnS_CLLM2BinaryLoadlifter>
