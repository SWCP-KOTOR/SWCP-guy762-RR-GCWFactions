<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	
	
	
	
	
	
	
	
	<!--
	  General order:
	  - 10-100:   Underlying grids (Elevation/Fertility/Caves)
	  - 200-300:  Natural terrain gen
	  - 400-500:  Critical large structures (quest locations, settlements, etc.)
	  - 600:      Reserve Gravship area
	  - 700-800:  Non-critical large structures (ruins, etc.) - these must take into account UsedRects
	  - 850:      Player start spot
	  - 900-1200: Non-critical gen (geysers, plants, animals, etc)
	  - 1500:     Fog
	  - 1600+:    Important buildings/features that need to be unfogged
	  - 1700:     Place gravship marker
	-->
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	<!-- HOW IT WORKS: a Harmony patch replaces each individually patched faction's settlement MapGenerator with a hardcoded DefOf (SWCPMapGenerator_x) -->
	
	<MapGeneratorDef ParentName="MapCommonBase">
		<defName>SWCPMapGenerator_FortressMilitia</defName>
		<genSteps>
			<li>RocksFromGrid</li>
			<li>SWCPMapGenStep_MilitiaStructure_FortressSettlement</li>
			<li>SWCPMapGenStep_MilitiaStructure_FortressSettlementPawns</li>
			
			<li>SWCPGenStep_FactionFortressGuards_Militia_WanderingPersonnel</li>

			<li>SWCPGenStep_FactionFortressGuards_MilitiaOrdMantell_BigCommandPostGuards</li>

			<li>SWCPGenStep_FactionFortressGuards_MilitiaOrdMantell_basecommaders</li>
			<li>SWCPGenStep_FactionFortressGuards_MilitiaOrdMantell_controlroomguards</li>
		</genSteps>
	</MapGeneratorDef>
	
	
	<GenStepDef>
		<defName>SWCPMapGenStep_MilitiaStructure_FortressSettlement</defName>
		<order>400</order>
		<!-- <genStep Class="GenStep_AncientRuins"> -->
		<genStep Class="SWCP_LevelDesignStuff.GenStep_FactionFortress">
			<layoutDef>SWCPMilitiaStructure_FortressSettlement</layoutDef>
		</genStep>
	</GenStepDef>
	
	<GenStepDef><!-- this one is still needed to spawn in the base Settlement pawngroup, the other pawn GenSteps are supplemental	-->
		<defName>SWCPMapGenStep_MilitiaStructure_FortressSettlementPawns</defName>
		<order>700</order>
		<genStep Class="SWCP_LevelDesignStuff.GenStep_FactionFortressPawns">
		  <factionDef>guy762_SWWarlordsFaction_PDF</factionDef>
		</genStep>
	</GenStepDef>
	
	
	
	
	<GenStepDef>
		<defName>SWCPGenStep_FactionFortressGuards_Militia_WanderingPersonnel</defName>
		<order>960</order>
		<genStep Class="SWCPBiomes.GenStep_WanderingCivilians">
			<factionDef>guy762_SWWarlordsFaction_PDF</factionDef>
			<initialCivilianCount>25~30</initialCivilianCount>
