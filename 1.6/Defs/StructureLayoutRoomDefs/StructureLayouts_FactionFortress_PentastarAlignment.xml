	<TileMutatorDef ParentName="AncientStructureMutBase">
		<defName>SWCPTileMutator_FactionFortress_PentastarAlignment</defName>
		<label>Zsinj's Dominion garrison</label>
		<description>warning: raptor crossing</description>
		<workerClass>TileMutatorWorker_AncientStructure</workerClass>
		
		<requiresFactionOfDef>guy762_SWWarlordsFaction_Pentastar</requiresFactionOfDef>
		<extraGenSteps>
			<li>SWCPMapGenStep_ImperialStructure_PentastarAlignmentBasePawns</li>
			
			<li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_WanderingPersonnel</li>

			<!-- <li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_turretguards</li> -->
			<li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_BigCommandPostGuards</li>
			<!-- <li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_TIEFightersDefendingAVTurret</li> -->
			<!-- <li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_ATPTsDefendingAATurret</li> -->

			<li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_basecommaders</li>
			<li>SWCPGenStep_FactionFortressGuards_PentastarAlignment_controlroomguards</li>
		</extraGenSteps>
		<categories Inherit="False" /> <!-- Remove the AncientStructure category so this isn't chosen for ancient mercenaries quest -->
		<!-- <biomeWhitelist Inherit="False"> -->
			<!-- <li MayRequire="MrHydralisk.LayeredAtmosphereOrbit">SWCPBiome_TatooineHighland</li> -->
		<!-- </biomeWhitelist> -->
		
		<structureGenParms>
		  <structureLayoutDef>SWCPImperialStructure_FactionFortress_PentastarAlignment</structureLayoutDef>
		  <structureSizeRange>75~100</structureSizeRange>
		  <scatteredPrefabs>
			<li>
			  <countPer10kCellsRange>1~1</countPer10kCellsRange>
			  <minSpacing>10</minSpacing>
			  <maxDistFromStructure>50</maxDistFromStructure>
			  <prefabs>
				<Exterior_AncientBunker>
				  <weight>1.0</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.2</filthChance>
				  <max>1</max>
				</Exterior_AncientBunker>
				<Exterior_AncientTankTraps>
				  <weight>0.5</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.2</filthChance>
				  <max>1</max>
				</Exterior_AncientTankTraps>
				<Exterior_AncientTankBlockade>
				  <weight>0.5</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.2</filthChance>
				  <max>1</max>
				</Exterior_AncientTankBlockade>
				<Exterior_MilitaryBlockade>
				  <weight>0.5</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.2</filthChance>
				  <max>2</max>
				</Exterior_MilitaryBlockade>
				<Exterior_AncientMegaCannonEmplacement>
				  <weight>3.0</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.2</filthChance>
				  <max>4</max>
				</Exterior_AncientMegaCannonEmplacement>
				<SWCPPrefabExterior_WalkerWreckageCluster>
				  <weight>3.0</weight>
				  <indoorRuin>false</indoorRuin>
				  <filthDef>Filth_MachineBits</filthDef>
				  <filthExpandBy>1</filthExpandBy>
				  <filthChance>0.4</filthChance>
				  <max>1</max>
				</SWCPPrefabExterior_WalkerWreckageCluster>
			  </prefabs>
			</li>
		  </scatteredPrefabs>
		  <perimeterWallDef>AncientRazorWire</perimeterWallDef>
		  <perimeterExpandBy>10</perimeterExpandBy>
		  <perimeterWallChance>0.9</perimeterWallChance>
		  <!-- <perimeterTerrainDef>AncientConcrete</perimeterTerrainDef> -->
		  <perimeterTerrainDef>Concrete</perimeterTerrainDef>

		  <perimeterScatteredThings>
			<AncientMortar>3</AncientMortar>
			<AncientBarrel>2</AncientBarrel>
			<AncientMilitaryBarrier>3</AncientMilitaryBarrier>
			<guy762_ShipChunk_ATST>1</guy762_ShipChunk_ATST>
		  </perimeterScatteredThings>
		</structureGenParms>
	</TileMutatorDef>
	
	
	<!--
	  General order:
	  - 10-100:   Underlying grids (Elevation/Fertility/Caves)
	  - 200-300:  Natural terrain gen
	  - 400-500:  Critical large structures (quest locations, settlements, etc.)
	  - 600:      Reserve Gravship area
	  - 700-800:  Non-critical large structures (ruins, etc.) - these must take into account UsedRects
	  - 850:      Player start spot
	  - 900-1200: Non-critical gen (geysers, plants, animals, etc)
	  - 1500:     Fog
	  - 1600+:    Important buildings/features that need to be unfogged
	  - 1700:     Place gravship marker
	-->
	
	
	
	
	
	
	
	
	
	
	
	
	
	
