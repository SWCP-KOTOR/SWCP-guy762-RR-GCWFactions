                    </li>
					<li>
                        <thingDef>guy762_SE14pistol</thingDef>
                        <countRange>1</countRange>
                        <weight>0.25</weight>
                    </li>
					<li>
                        <thingDef>guy762_EC17pistol</thingDef>
                        <countRange>1</countRange>
                        <weight>0.25</weight>
                    </li>
					<li>
                        <thingDef>guy762_E10rifle</thingDef>
                        <countRange>1</countRange>
                        <weight>0.75</weight>
                    </li>
					<li>
                        <thingDef>guy762_E11carbine</thingDef>
                        <countRange>1</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_ElectroBatonGCW</thingDef>
                        <countRange>1</countRange>
                        <weight>0.25</weight>
                    </li>
						<!-- armor -->
					<li>
                        <thingDef>guy762_ImpLightCombatArmor</thingDef>
                        <countRange>1</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_NavyTrooperHelmet</thingDef>
                        <countRange>1</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_ArmyTrooperGasMask</thingDef>
                        <countRange>1</countRange>
                        <weight>0.25</weight>
                    </li>
						<!-- consumables -->
					<li>
                        <thingDef>guy762_grenadebelt_frag</thingDef>
                        <countRange>1</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_grenadebelt_stun</thingDef>
                        <countRange>1</countRange>
                        <weight>0.75</weight>
                    </li>
					<li>
                        <thingDef>guy762_stim_battle</thingDef>
                        <countRange>5</countRange>
                        <weight>0.5</weight>
                    </li>
					<li>
                        <thingDef>guy762_stim_con</thingDef>
                        <countRange>5</countRange>
                        <weight>0.49</weight>
                    </li>
					<li>
                        <thingDef>guy762_stim_dex</thingDef>
                        <countRange>5</countRange>
                        <weight>0.48</weight>
                    </li>
					<li>
                        <thingDef>guy762_stim_str</thingDef>
                        <countRange>5</countRange>
                        <weight>0.47</weight>
                    </li>
                </weightedDrops>
            </li>
			<li Class="CompProperties_UseEffectPlaySound">
				<soundOnUsed>kotorsound_metalbox_open</soundOnUsed>
			</li>
            <!-- <li Class="CompProperties_UseEffectDestroySelf"/> -->
			<li Class="CompProperties_Forbiddable"/>
        </comps>
    </ThingDef>
	
	<PrefabDef>
		<defName>SWCPPrefabLootbox_ImpBaseCommon</defName>
		<size>(1,1)</size>
		<things>
			<SWCPBuildingLootBox_ImpBaseCommon>
				<chance>0.75</chance>
			</SWCPBuildingLootBox_ImpBaseCommon>
		</things>
	</PrefabDef>
    

</Defs>
