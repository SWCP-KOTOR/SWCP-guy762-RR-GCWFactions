            <li Class="FCP.Core.CompProperties_UseEffectItemBox">
                <numWeightedDrops>3</numWeightedDrops>
				<guaranteedDrops>
                </guaranteedDrops>
                <weightedDrops>
				
					<li>
                        <thingDef>SWCPItem_BF2AmmoSupplyPickup</thingDef>
