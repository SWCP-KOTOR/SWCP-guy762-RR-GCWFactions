<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Site Defs __________-->

    <!-- Site Pawn Rescue -->

    <SitePartDef>
        <defName>SWCP_Site_PawnRescue</defName>
        <label>prisoner camp</label>
        <description>A prisoner being held by enemies.</description>
        <workerClass>SWCP.RadiantQuests.SitePartWorker_PawnRescue</workerClass>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>World/WorldObjects/Expanding/Sites/Prisoner</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>6</forceExitAndRemoveMapCountdownDurationDays>
        <requiresFaction>true</requiresFaction>
        <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
        <tags>
            <li>SWCP_Site_PawnRescue</li>
        </tags>
    </SitePartDef>

    <GenStepDef>
        <defName>SWCP_Site_PawnRescue_Outpost</defName>
        <linkWithSite>SWCP_Site_PawnRescue</linkWithSite>
        <order>450</order>
        <genStep Class="GenStep_Outpost">
            <pawnGroupKindDef>Combat</pawnGroupKindDef>
        </genStep>
    </GenStepDef>

    <GenStepDef>
        <defName>SWCP_Site_PawnRescue_OutpostPower</defName>
        <linkWithSite>SWCP_Site_PawnRescue</linkWithSite>
        <order>451</order>
        <genStep Class="GenStep_Power"/>
    </GenStepDef>

    <GenStepDef>
        <defName>SWCP_Site_PawnRescue_PawnPrisoner</defName>
        <linkWithSite>SWCP_Site_PawnRescue</linkWithSite>
        <order>460</order>
        <genStep Class="SWCP.RadiantQuests.GenStep_PawnRescue">
            <count>1</count>
            <nearMapCenter>true</nearMapCenter>
        </genStep>
    </GenStepDef>
    
</Defs>
