            <li Class="SWCP.Core.ModExtension_FactionTaxCollectors">
                <factionDef>guy762_SWWarlordsFaction_ZsinjDominion</factionDef>
                <traderKindDef>SWCPTrader_TaxCollector_ZsinjDominion</traderKindDef>
            </li>
        </modExtensions>
    </IncidentDef>

    <TraderKindDef>
        <defName>SWCPTrader_TaxCollector_ZsinjDominion</defName>
