	<ThingDef Name="SWCP_FactionIntelDatapadBASE_adv" ParentName="guy762_NoCraft_upgradebase" Abstract="True">

		<description>A datapad containing critical information regarding a faction's ongoing military operations. This datapad could contain major battle plans, high-level memos, secret communiques, schematics for advanced technology, and more. The loss of this datapad is guaranteed to be a devastating blow to the faction it belongs to, and a major advantage to any faction that gets its hands on it.</description>
		<graphicData>
		  <graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!-- <stackLimit>10</stackLimit><drawGUIOverlay>true</drawGUIOverlay> -->
		<statBases>
		  <MarketValue>10000</MarketValue>
		  <Mass>1</Mass>
		</statBases>

