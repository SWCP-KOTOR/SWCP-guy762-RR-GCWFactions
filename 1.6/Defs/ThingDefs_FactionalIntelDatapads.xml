<Defs>


	<ThingDef Name="SWCP_FactionIntelDatapadBASE_basic" ParentName="guy762_NoCraft_upgradebase" Abstract="True">

		<description>A datapad containing some sensitive information regarding a faction's ongoing military operations. This datapad only has mundane information such as temporary access codes, ledgers, orders for low-ranking personnel, and reports. While not terribly exciting on the surface, the loss of this datapad can prove very disruptive if it falls into the hands of an enemy faction.</description>
		<graphicData>
		  <graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<stackLimit>10</stackLimit><drawGUIOverlay>true</drawGUIOverlay>
		<statBases>
		  <MarketValue>1000</MarketValue>
		  <Mass>1</Mass>
		</statBases>

		<thingSetMakerTags>
		  <!-- <li>RewardStandardMidFreq</li> -->
		</thingSetMakerTags>
		<tradeTags>
			<li>SWCPTT_FactionIntelDatapads_anyfaction</li>
		</tradeTags>
	</ThingDef>
	
	
	
