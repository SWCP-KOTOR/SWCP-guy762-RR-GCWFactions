  <!-- ============== outsider titles ============================= -->

  <RoyalTitleDef ParentName="SWGCWTitle_ZsinjPrivateer_base">
    <defName>SWGCWTitle_ZsinjPrivateer_contact</defName>
    <label>contact</label>
    <description>The "contact" status within Zsinj's information network signifies an outside individual who has been identified as being open to collaborating with Zsinj's military personnel when needed.</description>
    <seniority>0</seniority>
    <favorCost>1</favorCost>
    <changeHeirQuestPoints>1000</changeHeirQuestPoints>
    <allowDignifiedMeditationFocus>False</allowDignifiedMeditationFocus>

    <permitPointsAwarded>1</permitPointsAwarded>
  </RoyalTitleDef>

  <RoyalTitleDef ParentName="SWGCWTitle_ZsinjPrivateer_base">
    <defName>SWGCWTitle_ZsinjPrivateer_asset</defName>
    <label>asset</label>
    <description>The "asset" status within Zsinj's information network signifies an outside individual who has been deemed a reliable, trustworthy source of aid to Zsinj's military interests.\n\nThese individuals are typically given clearance to request planet-wide transportation via shuttlecraft, in the interests of further developing them as an agent of Zsinj's Dominion.</description>
    <seniority>15</seniority>
    <favorCost>20</favorCost>
    <changeHeirQuestPoints>1000</changeHeirQuestPoints>
    <commonality>1</commonality>

    <permitPointsAwarded>1</permitPointsAwarded>
    <replaceOnRecruited>SWGCWTitle_ZsinjPrivateer_contact</replaceOnRecruited>
    <permits>
      <li>TradeSettlement</li>
      <li>TradeCaravan</li>
    </permits>
  </RoyalTitleDef>

  <!-- ============== official Republic titles ============================= -->

  <RoyalTitleDef ParentName="SWGCWTitle_ZsinjPrivateer_base">
    <defName>SWGCWTitle_ZsinjPrivateer_operative</defName>
    <label>operative</label>
    <description>The "operative" status within Zsinj's information network signifies an outside individual who can be fully trusted to act in the interests of Zsinj's military and can be relied upon to carry out tasks that official personnel cannot be directly involved in.\n\nThese individuals are given clearance to request basic matériels from the local fleet's supply division, and can also request army trooper reinforcements.</description>
    <seniority>25</seniority>
    <favorCost>20</favorCost>
    <changeHeirQuestPoints>1200</changeHeirQuestPoints>
    <recruitmentResistanceOffset>10</recruitmentResistanceOffset>
    <commonality>1</commonality>

    <permitPointsAwarded>2</permitPointsAwarded>
    <replaceOnRecruited>SWGCWTitle_ZsinjPrivateer_contact</replaceOnRecruited>

    <permits>
      <li>TradeSettlement</li>
      <li>TradeCaravan</li>
      <li>TradeOrbital</li>
    </permits>
  </RoyalTitleDef>





