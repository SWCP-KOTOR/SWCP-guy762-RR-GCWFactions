<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Vertibirds __________-->

    <!--_____ Transport ship defs _____-->

    <!-- NCR Standard Vertibird -->

    <TransportShipDef Name="guy762_SWShuttleTransportShip_ST70AssaultShip">
        <defName>guy762_SWShuttleTransportShip_ST70AssaultShip</defName>
        <label>ST-70 assault ship</label>
        <shipThing>guy762_SWShuttleThing_ST70AssaultShip</shipThing>
        <arrivingSkyfaller>guy762_SWShuttleSkyfaller_ST70AssaultShipIncoming</arrivingSkyfaller>
        <leavingSkyfaller>guy762_SWShuttleSkyfaller_ST70AssaultShipLeaving</leavingSkyfaller>
        <worldObject>guy762_SWShuttleWorldObject_ST70AssaultShip</worldObject>
        <maxLaunchDistance>70</maxLaunchDistance>
    </TransportShipDef>
	
