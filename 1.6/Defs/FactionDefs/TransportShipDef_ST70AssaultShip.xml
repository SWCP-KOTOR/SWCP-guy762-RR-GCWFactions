    <!--_____ Building ThingDefs _____-->

    <!-- NCR Standard Vertibird -->

    <ThingDef ParentName="BuildingBase">
        <defName>guy762_SWShuttleThing_ST70AssaultShip</defName>
        <label>ST-70 assault ship</label>
        <description>.</description>
        <!-- <altitudeLayer>Building</altitudeLayer> -->
        <altitudeLayer>Skyfaller</altitudeLayer>
        <pathCost>50</pathCost>
        <blockWind>true</blockWind>
        <passability>Impassable</passability>
        <fillPercent>1.0</fillPercent>
		
        <!-- <size>(22,8)</size> for the purposes of not destroying your gravship's hangar bay when you use a royalty permit to drop resources/troops/whatever, the actual occupied size has to be shrunk to a reasonable amount -->
        <size>(7,1)</size>
		
        <drawHighlight>true</drawHighlight>
        <highlightColor>(0.56, 0.62, 0.9)</highlightColor>
        <graphicData>
            <texPath>Shuttles_MajesticMadman/RazorCrest_Worn</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(28,28)</drawSize>
            <shadowData>
                <volume>(4.1, 1.0, 1.8)</volume>
                <offset>(0, 0, -0.1)</offset>
            </shadowData>
        </graphicData>
        <statBases>
            <MaxHitPoints>10000</MaxHitPoints> <!-- XWMG stats: 6 hull 4 shield -->
            <Flammability>1</Flammability>
        </statBases>
        <tickerType>Normal</tickerType>
        <canOverlapZones>true</canOverlapZones>
        <killedLeavings>
            <Plasteel>50</Plasteel>
            <Uranium>50</Uranium>
            <ChunkSlagSteel>4</ChunkSlagSteel>
            <ComponentIndustrial>4</ComponentIndustrial>
        </killedLeavings>
        <rotatable>false</rotatable>
        <selectable>true</selectable>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
        <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
        <drawerType>RealtimeOnly</drawerType>
        <repairEffect>ConstructMetal</repairEffect>
        <forceDebugSpawnable>true</forceDebugSpawnable>
        <uiIconScale>1.4</uiIconScale>
        <building>
            <claimable>false</claimable>
            <destroySound>BuildingDestroyed_Metal_Big</destroySound>
        </building>
        <inspectorTabs>
            <li>ITab_ContentsTransporter</li>
        </inspectorTabs>
        <comps>
            <li Class="CompProperties_Shuttle" />
            <li Class="CompProperties_Transporter">
                <massCapacity>81284</massCapacity> <!-- 80 metric tons -->
                <max1PerGroup>true</max1PerGroup>
                <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
                <showOverallStats>false</showOverallStats>
                <pawnLoadedSound>kotorsound_select_shipgun</pawnLoadedSound>
                <pawnExitSound>kotorsound_select_shipgun</pawnExitSound>
            </li>
           
          <li Class="CompProperties_AmbientSound">
            <sound>ShuttleIdle_Ambience</sound>
          </li>
        </comps>
    </ThingDef>

    <!--_____ WorldObjectDefs _____-->

    <!-- NCR Standard Vertibird -->

    <WorldObjectDef>
        <defName>guy762_SWShuttleWorldObject_ST70AssaultShip</defName>
        <label>ST-70 assault ship</label>
        <description>.</description>
        <worldObjectClass>TravellingTransporters</worldObjectClass>
        <texture>World/WorldObjects/Caravan</texture>
        <useDynamicDrawer>true</useDynamicDrawer>
        <expandingIcon>true</expandingIcon>
        <expandingIconTexture>Shuttles_MajesticMadman/RazorCrest_Worn</expandingIconTexture>
        <expandingIconPriority>60</expandingIconPriority>
        <expandMore>true</expandMore>
        <expandingIconDrawSize>1.6</expandingIconDrawSize>
        <allowCaravanIncidentsWhichGenerateMap>true</allowCaravanIncidentsWhichGenerateMap>
        <rotateGraphicWhenTraveling>true</rotateGraphicWhenTraveling>
    </WorldObjectDef>

    <!--_____ Skyfaller Defs _____-->

    <!--___ Skyfaller Def Base ___-->

    <!-- NCR Standard Vertibird -->

    <ThingDef Name="guy762_SWShuttleSkyfaller_ST70AssaultShipBASE" ParentName="SkyfallerBase" Abstract="True">
        <!-- <size>(22,8)</size> for the purposes of not destroying your gravship's hangar bay when you use a royalty permit to drop resources/troops/whatever, the actual occupied size has to be shrunk to a reasonable amount -->
        <size>(7,1)</size>
        <graphicData>
            <texPath>Shuttles_MajesticMadman/RazorCrest_Worn</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutFlying</shaderType>
            <drawSize>(28,28)</drawSize>
        </graphicData>
        <skyfaller>
            <movementType>Decelerate</movementType>
            <shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
            <shadowSize>(5.5,3.5)</shadowSize>
            <motesPerCell>1</motesPerCell>
        </skyfaller>
        <comps>
        </comps>
    </ThingDef>

    <!--___ Skyfaller Def ___-->

    <!--__ NCR Standard Vertibird __-->

    <!-- NCR Standard Vertibird Incoming -->

    <ThingDef ParentName="guy762_SWShuttleSkyfaller_ST70AssaultShipBASE">
        <defName>guy762_SWShuttleSkyfaller_ST70AssaultShipIncoming</defName>
        <label>ST-70 assault ship (incoming)</label>
        <thingClass>ShuttleIncoming</thingClass>
        <skyfaller>
            <anticipationSound>Shuttle_Landing</anticipationSound>
            <anticipationSoundTicks>250</anticipationSoundTicks>
            <ticksToImpactRange>200~250</ticksToImpactRange>
            <angleCurve>
                <points>
                    <li>(0,-60)</li>
                    <li>(1,-90)</li>
                </points>
            </angleCurve>
            <rotationCurve>
                <points>
                    <li>(0,30)</li>
                    <li>(0.5,5)</li>
                    <li>(0.9,-5)</li>
                    <li>(0.95,0)</li>
                </points>
            </rotationCurve>
            <zPositionCurve>
                <points>
                    <li>(0.95,2.5)</li>
                    <li>(1,0)</li>
                </points>
            </zPositionCurve>
            <speedCurve>
                <points>
                    <li>(0.6,0.6)</li>
                    <li>(0.95,0.1)</li>
                </points>
            </speedCurve>
        </skyfaller>
    </ThingDef>

    <!--__ NCR Standard Vertibird __-->

    <!-- NCR Standard Vertibird Leaving -->

    <ThingDef ParentName="guy762_SWShuttleSkyfaller_ST70AssaultShipBASE">
        <defName>guy762_SWShuttleSkyfaller_ST70AssaultShipLeaving</defName>
        <label>ST-70 assault ship (leaving)</label>
        <thingClass>FlyShipLeaving</thingClass>
        <skyfaller>
            <reversed>true</reversed>
            <anticipationSound>Shuttle_Leaving</anticipationSound>
            <anticipationSoundTicks>-10</anticipationSoundTicks>
            <ticksToImpactRange>-40~-15</ticksToImpactRange>
            <moteSpawnTime>0.05</moteSpawnTime>
            <shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
            <shadowSize>(5.5,3.5)</shadowSize>
            <motesPerCell>1</motesPerCell>
            <angleCurve>
                <points>
                    <li>(0,90)</li>
                    <li>(1,70)</li>
                </points>
            </angleCurve>
            <rotationCurve>
                <points>
                    <li>(0,0)</li>
                    <li>(0.15,10)</li>
                    <li>(0.5,-5)</li>
                </points>
            </rotationCurve>
            <zPositionCurve>
                <points>
                    <li>(0,0)</li>
                    <li>(0.08,2)</li>
                </points>
            </zPositionCurve>
            <speedCurve>
                <points>
                    <li>(0,0.2)</li>
                    <li>(0.4,0.7)</li>
                </points>
            </speedCurve>
        </skyfaller>
    </ThingDef>

</Defs>