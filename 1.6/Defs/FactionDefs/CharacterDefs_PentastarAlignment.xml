<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!--
	ESCALATION RULES: since these are galaxy-wide factions, senority values are arranged in descending order so that the established faction leader is among the last leaders to appear in the succession order, 
	while generic nameless leaders are the ones you get initially. this is to provide a sense of "escalation" as you kill off an enemy faction's leadership - the more leaders you kill, the bigger the threat
	you become to this faction, meaning they'll send more and more qualified personnel to take you out.
	
	now, having the actual established faction leaders show up to your random rim world planet just to kill you probably won't make sense for *every* faction (there's no way someone like Isard would do that),
	but this way I at least have a chance to have their fancy PawnKinds actually appear somewhere in-game that's somewhat appropriate for the role in the setting they have.
	
	-->
	
	<SWCP.Core.CharacterDef>
        <defName>SWPentastarCharacter_TessalaCorvae</defName>
        <pawnKind>SWCharPawnPA_TessalaCorvae</pawnKind>
        <faction>guy762_SWWarlordsFaction_Pentastar</faction>
        <xenotype>Baseliner</xenotype>
        <roles>
            <li Class="SWCP.Core.CharacterRole_FactionLeader">
                <seniority>50</seniority> <!-- lower-ranking military commander that can assume control if everyone else is killed -->
            </li>
        </roles>
    </SWCP.Core.CharacterDef>
	
	
