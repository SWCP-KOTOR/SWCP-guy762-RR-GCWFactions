<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>SWCP_CommandPost_small</defName>
		<label>command post</label>
		<description>A command post. This can only be captured if it is factionless, or belongs to an enemy faction. It cannot be captured if it belongs to a neutral or allied faction.</description>
		<thingCategories>
		  <li>BuildingsJoy</li>
		</thingCategories>
		<graphicData>
		  <texPath>Buildings/CommandPosts/CommandPost_small</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(3,3)</drawSize>
		  <drawOffset>(0,0,1)</drawOffset>
		  
		  <shadowData>
			<volume>(0.58, 0.35, 0.25)</volume>
			<offset>(0,0,-0.1)</offset>
		  </shadowData>
		  <damageData>
			<rect>(0.2,0.2,0.6,0.6)</rect>
		  </damageData>
		</graphicData>
		
		<size>(1,1)</size>
		<uiIconScale>0.3</uiIconScale>
		
		<specialDisplayRadius>7.9</specialDisplayRadius>
		<drawerType>MapMeshAndRealTime</drawerType>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="SWCP_Misc.CompProperties_CommandPost">
				<captureRadius>7.9</captureRadius>
				<ticksToCapture>900</ticksToCapture>
				<nonCapturingFactions>
					<li>Mechanoid</li>
					<li>Insect</li>
					<li>guy762_KotORFaction_Civilians</li>
				</nonCapturingFactions>
				
				<soundHeld>kotorsound_CommandPost_ambient</soundHeld>
				<soundFactionless>kotorsound_CommandPost_ambient</soundFactionless>
				
				<soundCaptured>kotorsound_CommandPost_captured</soundCaptured>
				<soundCapturing>kotorsound_CommandPost_dispute</soundCapturing>
				<soundReverting>kotorsound_CommandPost_dispute</soundReverting>
				<soundBecameFactionless>kotorsound_CommandPost_lost</soundBecameFactionless>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>6</glowRadius>
				<glowColor>(255,255,255,0)</glowColor>
			</li>
		</comps>
		
		<placeWorkers>
			<li>PlaceWorker_NeverAdjacentSameDef</li>
		</placeWorkers>

		<!-- <specialDisplayRadius>3</specialDisplayRadius> -->
		
		
		<altitudeLayer>Building</altitudeLayer>
		
		<useHitPoints>False</useHitPoints>
		<statBases>
			<MarketValue>2000</MarketValue>
			<WorkToBuild>1500</WorkToBuild>
			<Mass>35</Mass>
		</statBases>
		
		<canOverlapZones>false</canOverlapZones>
		<building>
			<ai_chillDestination>true</ai_chillDestination>
			<allowAutoroof>false</allowAutoroof>
			<minDistanceToSameTypeOfBuilding>3</minDistanceToSameTypeOfBuilding>
			
			<claimable>false</claimable>
		</building>
		<costList>
			<Steel>75</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		
		<pathCost>1</pathCost>
		<passability>PassThroughOnly</passability>
		<!-- <designationCategory>KOTOR_BuildTab</designationCategory> -->
		<designationCategory>Joy</designationCategory>
		<rotatable>false</rotatable>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		
		<researchPrerequisites>
			<li>Electricity</li>
		</researchPrerequisites>
		
		<minifiedDef>MinifiedThing</minifiedDef>
		<!-- <tradeability>All</tradeability> -->
		<!-- <tradeTags> -->
		  <!-- <li>ExoticBuilding</li> -->
		  <!-- <li>guy762TT_SWMoistureVaporator</li> -->
		<!-- </tradeTags> -->
	</ThingDef>
	
	
	
	
	
	
	
	
	
	
