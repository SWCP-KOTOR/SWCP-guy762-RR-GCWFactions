<Defs>

	
	  
	<!-- military suit stat level -->	  
	  
	  
	<ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_ImpMidCombatArmor</defName>
		<label>combat armor</label>
		<description>.</description>
		<graphicData>
		  <texPath>SWApparel/ImperialTankTrooper/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(75,75,75)</colorTwo> -->
		</graphicData>
		<statBases>
			<Mass>6</Mass>
			<MarketValue>600</MarketValue>
			
			<MaxHitPoints>350</MaxHitPoints> <!-- mil suit stats -->
			<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<EquipDelay>15</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.1</MoveSpeed> <!-- +1 -->
			<MeleeDodgeChance>-0.1</MeleeDodgeChance>
			<IncomingDamageFactor>-0.1</IncomingDamageFactor>
		</equippedStatOffsets>
		<apparel>
			<tags Inherit="False">
				<li>RemnantEmpire_armycommando</li>
				<li>SWGCWSpecificApparelItem_EmpireTankTrooperArmor</li>
				<li>SWGCWRoyaltyTag_AnyEliteImpArmor</li>
			</tags>
			<wornGraphicPath>SWApparel/ImperialTankTrooper/Apparel</wornGraphicPath>
			<!-- <useWornGraphicMask>true</useWornGraphicMask> -->
			<layers Inherit="False">
				<li>Middle</li>
			</layers>
			<bodyPartGroups Inherit="False">
				<li>Shoulders</li>
				<li>Neck</li>
				<li>Arms</li>
				<li>Hands</li>
				<!-- <li>Legs</li> -->
				<li>Feet</li>
			</bodyPartGroups>
			<useDeflectMetalEffect>true</useDeflectMetalEffect>

			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelBody</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>22</baseLayer> <!-- MIDDLE -->
					<autoBodyTypePaths>true</autoBodyTypePaths>
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/ImperialTankTrooper/Apparel</li></texturePaths>
					  <colorA>
						<apparelColorA>true</apparelColorA> <!-- uses colorGenerator color, do not use colorOptions on colorOne -->
						<alts><li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li></alts>
					  </colorA>
					  <colorB>
						<color>75,75,75</color>	<!-- dark grey -->
						<alts><li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li></alts>
					  </colorB>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>22</layer> </dataNorth> </drawData>	<!-- MIDDLE -->
				</li>
			</renderNodeProperties>
		</apparel>
		<tradeTags>
			<li>guy762TT_GCWApparel</li>
			<li>guy762TT_GCWArmor_RareImpSurplus</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(250,250,250)</only>
				</li>
			</options>
		</colorGenerator>
		
		<!-- <randomStyleChance>0.5</randomStyleChance> -->
		<!-- <randomStyle> -->
		  <!-- <li> -->
			<!-- <styleDef>guy762_ImpCombatArmorStyle_blank</styleDef> -->
		  <!-- </li> -->
		  <!-- <li> -->
			<!-- <styleDef>guy762_ImpCombatArmorStyle_commando</styleDef> -->
		  <!-- </li> -->
		<!-- </randomStyle> -->
		<verbs>
            <li>
                <label>throw stun grenade</label>
                <verbClass>Verb_LaunchProjectileStatic</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <range>25</range>
                <forcedMissRadius>1.9</forcedMissRadius>
                <warmupTime>1.75</warmupTime>
                <noiseRadius>4</noiseRadius>
                <burstShotCount>1</burstShotCount>
                <soundCast>kotorsound_grenadethrow</soundCast>
                <onlyManualCast>true</onlyManualCast>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
                <defaultProjectile>guy762_ThrownGrenade_stormtrooper</defaultProjectile>
                <ai_AvoidFriendlyFireRadius>6.9</ai_AvoidFriendlyFireRadius>
				<ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
				<ai_IsWeapon>true</ai_IsWeapon>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
        <comps>
            <li Class="CompProperties_ApparelReloadable">
                <maxCharges>1</maxCharges>
                <destroyOnEmpty>false</destroyOnEmpty>
                <hotKey>Misc4</hotKey>
                <chargeNoun>grenades</chargeNoun>
                <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
				<ammoDef>ComponentIndustrial</ammoDef>
				<ammoCountToRefill>2</ammoCountToRefill>
				<baseReloadTicks>60</baseReloadTicks>
            </li>
			<li Class="CompProperties_Styleable"></li>
        </comps>
		<modExtensions>
		  <li Class="BigAndSmall.HasCustomizableGraphics">
			<!-- Tag is not needed for apparel. -->
			<colorA>true</colorA>
			<colorB>true</colorB>
			<!-- <colorC>true</colorC> -->
		  </li>
		</modExtensions>
	</ThingDef>
	
