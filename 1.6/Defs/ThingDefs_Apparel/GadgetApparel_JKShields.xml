				<count>1</count>
			</li>
		</ingredients>
		<products>
			<guy762_JKenergyshield>1</guy762_JKenergyshield>
		</products>
	</RecipeDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
