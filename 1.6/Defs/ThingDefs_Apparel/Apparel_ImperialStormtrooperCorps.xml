  <ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_StormieArmor</defName>
		<label>Stormtrooper armor</label>
		<techLevel>Spacer</techLevel>
		<description>.</description>
		<graphicData>
			<texPath>SWApparel/Stormtrooper/Apparel</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>6</Mass>
			<MarketValue>500</MarketValue>
			<MaxHitPoints>225</MaxHitPoints>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
			<ArmorRating_Heat>0.85</ArmorRating_Heat>
			<EquipDelay>10</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.2</MoveSpeed>
			<MeleeDodgeChance>-0.2</MeleeDodgeChance>
			<IncomingDamageFactor>-0.1</IncomingDamageFactor>
		</equippedStatOffsets>
		<apparel>
			<tags>
				<li>RemnantEmpire_stormiearmor</li>
				<li>SWGCWSpecificApparelItem_ImperialStormtrooperArmor</li>
			</tags>
			<wornGraphicPath>SWApparel/Stormtrooper/Apparel</wornGraphicPath>
			<useWornGraphicMask>false</useWornGraphicMask>
			<layers>
				<li>Middle</li>
			</layers>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Neck</li>
				<li>Arms</li>
				<li>Hands</li>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<useDeflectMetalEffect>false</useDeflectMetalEffect>
		</apparel>
		<tradeTags>
			<li>guy762TT_WarlordArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>10</weight>
					<only>(250,250,250)</only>  <!-- white -->
				</li>
			</options>
		</colorGenerator>
		
		<verbs>
            <li>
                <label>throw stun grenade</label>
                <verbClass>Verb_LaunchProjectileStatic</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <range>15</range>
                <forcedMissRadius>1.9</forcedMissRadius>
                <warmupTime>1.75</warmupTime>
                <noiseRadius>4</noiseRadius>
                <burstShotCount>1</burstShotCount>
                <soundCast>kotorsound_grenadethrow</soundCast>
                <onlyManualCast>true</onlyManualCast>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
                <defaultProjectile>guy762_ThrownGrenade_stormtrooper</defaultProjectile>
                <ai_AvoidFriendlyFireRadius>6.9</ai_AvoidFriendlyFireRadius>
				<ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
				<ai_IsWeapon>true</ai_IsWeapon>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
        <comps>
            <li Class="CompProperties_ApparelReloadable">
                <maxCharges>1</maxCharges>
                <destroyOnEmpty>false</destroyOnEmpty>
                <hotKey>Misc4</hotKey>
                <chargeNoun>grenades</chargeNoun>
                <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
				<ammoDef>ComponentIndustrial</ammoDef>
				<ammoCountToRefill>2</ammoCountToRefill>
				<baseReloadTicks>60</baseReloadTicks>
            </li>
        </comps>
	</ThingDef>	
	
	
	
	<ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_StormieHelmet</defName>
		<label>Stormtrooper helmet</label>
		<techLevel>Spacer</techLevel>
		<description>.</description>
		<graphicData>
			<texPath>SWApparel/Stormtrooper/helmet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<!-- <shaderType>CutoutComplex</shaderType> -->
			<!-- <colorTwo>(95,135,190)</colorTwo> -->
		</graphicData>
		<thingCategories>
		  <li>ArmorHeadgear</li>
		</thingCategories>
		<statBases>
			<Mass>4</Mass>
			<MarketValue>300</MarketValue>
			<MaxHitPoints>115</MaxHitPoints>
      		<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ShootingAccuracyPawn>-0.2</ShootingAccuracyPawn>
			<AimingDelayFactor>-0.2</AimingDelayFactor>
			
			<ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
			<HypoxiaResistance MayRequire="kentington.saveourship2">1</HypoxiaResistance>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.25</DecompressionResistance>
