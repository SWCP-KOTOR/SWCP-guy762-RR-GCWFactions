	<ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_PAGuardianProtectorArmor</defName>
		<label>Guardian Protector armor</label>
		<techLevel>Spacer</techLevel>
		<description>.</description>
		<graphicData>
			<texPath>SWApparel/PAGuardianProtector/Apparel</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<colorTwo>(65,70,190)</colorTwo> <!-- pentastar blue -->
		</graphicData>
		
		<statBases>
			<Mass>14</Mass> <!-- durasteel battle armor stats -->
			<MarketValue>13000</MarketValue>
			<MaxHitPoints>475</MaxHitPoints>
      		<ArmorRating_Sharp>1.05</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.9</ArmorRating_Blunt>
			<ArmorRating_Heat>1.15</ArmorRating_Heat>
			<EquipDelay>10</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.5</MoveSpeed>
			<MeleeDodgeChance>-0.5</MeleeDodgeChance>
			<IncomingDamageFactor>-0.15</IncomingDamageFactor>
		</equippedStatOffsets>
		
		<apparel Inherit="False">
			<tags>
				<li>PentastarAlignment_GuardianProtector</li>
				<li>SWGCWSpecificApparelItem_PentastarGuardianProtectorArmor</li>
			</tags>
			<wornGraphicPath>SWApparel/PAGuardianProtector/Apparel</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
				<li>Middle</li>
			</layers>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Neck</li>
				<li>Arms</li>
				<li>Hands</li>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<useDeflectMetalEffect>true</useDeflectMetalEffect>
		</apparel>
		<tradeTags>
			<li>guy762TT_WarlordArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>10</weight>
					<only>(250,250,250)</only>  <!-- white -->
				</li>
			</options>
		</colorGenerator>

		<verbs>
            <li>
                <label>throw stun grenade</label>
                <verbClass>Verb_LaunchProjectileStatic</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <range>15</range>
                <forcedMissRadius>1.9</forcedMissRadius>
                <warmupTime>1.75</warmupTime>
                <noiseRadius>4</noiseRadius>
                <burstShotCount>1</burstShotCount>
                <soundCast>kotorsound_grenadethrow</soundCast>
                <onlyManualCast>true</onlyManualCast>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
                <defaultProjectile>guy762_ThrownGrenade_stormtrooper</defaultProjectile>
                <ai_AvoidFriendlyFireRadius>6.9</ai_AvoidFriendlyFireRadius>
				<ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
				<ai_IsWeapon>true</ai_IsWeapon>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
            </li>
        </verbs>
        <comps>
            <li Class="CompProperties_ApparelReloadable">
                <maxCharges>1</maxCharges>
                <destroyOnEmpty>false</destroyOnEmpty>
                <hotKey>Misc4</hotKey>
                <chargeNoun>grenades</chargeNoun>
                <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
				<ammoDef>ComponentIndustrial</ammoDef>
				<ammoCountToRefill>2</ammoCountToRefill>
				<baseReloadTicks>60</baseReloadTicks>
            </li>
            <li Class="SWCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
	</ThingDef>
	  
	  
	  
	  
