<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	

	
	<ThingDef ParentName="KotORArmorModdable_hard">
		<defName>guy762_TIEpilotHelmet_PA</defName>
		<label>TIE pilot Helmet (Pentastar Alignment)</label>
		<techLevel>Spacer</techLevel>
		<description>.</description>
		<graphicData>
			<texPath>SWApparel/TIEPilot/helmet_pentastar/helmet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			
			<!-- <shaderType>CutoutComplex</shaderType> -->
			<!-- pentastar blue -->
			<!-- <colorTwo>(65,70,190)</colorTwo> -->
		</graphicData>
		<thingCategories>
		  <li>ArmorHeadgear</li>
		</thingCategories>
		<statBases>
			<Mass>4</Mass>
			<MarketValue>300</MarketValue>
			<MaxHitPoints>115</MaxHitPoints>
      		<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Heat>0.45</ArmorRating_Heat>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
			<HypoxiaResistance MayRequire="kentington.saveourship2">1</HypoxiaResistance>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.25</DecompressionResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.69</VacuumResistance>
			
			<PilotingAbility MayRequire="Ludeon.RimWorld.Odyssey">0.5</PilotingAbility>
		</equippedStatOffsets>
		
		<apparel Inherit="False">
			<tags>
				<li>PentastarAlignment_TIEpilot</li>
				<li>SWGCWSpecificApparelItem_PentastarTIEPilotHelmet</li>
			</tags>
			<wornGraphicPath>SWApparel/TIEPilot/helmet_pentastar/helmet</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
				<li>Overhead</li>
				<li>EyeCover</li>
			</layers>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<useDeflectMetalEffect>false</useDeflectMetalEffect>
			
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelHead</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>71</baseLayer>
					<!-- <autoBodyTypePaths>true</autoBodyTypePaths> -->
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/TIEPilot/helmet_pentastar/helmet</li></texturePaths>
					  <colorA>
						<color>40,40,45</color>		<!-- blue-tint black -->
						<alts>
							<li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li>
						</alts>
					  </colorA>
					  <colorB>
						<color>65,70,190</color>	<!-- pentastar blue -->
						<alts>
							<li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li>
						</alts>
					  </colorB>
					  <colorC>
						<color>130,130,130</color>
						<alts>
							<li><triggers><li>CustomColorCIsSet</li></triggers><customColorC>(1,1,1)</customColorC> </li>
						</alts>
					  </colorC>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>71</layer> </dataNorth> </drawData>
				</li>
			</renderNodeProperties>
			
		</apparel>
		
		<tradeTags>
			<li>guy762TT_WarlordArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(40,40,45)</only> <!-- blue-tint black -->
				</li>
			</options>
		</colorGenerator>
	</ThingDef>
	
	
	
	
	
	  
	  
	  
	  
	  
	<ThingDef ParentName="guy762_FullBodyClothingBase">
		<defName>guy762_Bodysuit_TIEace</defName>
		<label>bodysuit, ace pilot's</label>
		<description>These are simple garments that protect little more than the modesty of the wearer.</description>
		<graphicData>
		  <texPath>SWApparel/TIEPilot/bodysuit_ace/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- dark red -->
		  <!-- <colorTwo>(140,0,0)</colorTwo> -->
		</graphicData>
		<statBases>
			<Mass>4.5</Mass>
			<MarketValue>7500</MarketValue>
			<MaxHitPoints>150</MaxHitPoints>
			<ArmorRating_Sharp>0.05</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.05</ArmorRating_Blunt>
			<ArmorRating_Heat>0.05</ArmorRating_Heat>
			
			<Insulation_Cold>25</Insulation_Cold>
			<Insulation_Heat>10</Insulation_Heat>
			
			<EquipDelay>3</EquipDelay>
			<WorkToMake>4000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.75</DecompressionResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.32</VacuumResistance>

			<VEF_MassCarryCapacity>5</VEF_MassCarryCapacity>
			<SocialImpact>0.5</SocialImpact>
		</equippedStatOffsets>
		
		<costList>
		  <Synthread>75</Synthread>
		</costList>
		
		<apparel>
		  <tags Inherit="False">
			<li>RemnantEmpire_TIEpilotAce</li>
			<li>SWGCWSpecificApparelItem_AceImperialTIEPilotBodysuit</li>
		  </tags>
		  <wornGraphicPath>SWApparel/TIEPilot/bodysuit_ace/Apparel</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  <defaultOutfitTags Inherit="False">
			<li>Worker</li>
		  </defaultOutfitTags>
		  
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelBody</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>21</baseLayer>
					<autoBodyTypePaths>true</autoBodyTypePaths>
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/TIEPilot/bodysuit_ace/Apparel</li></texturePaths>
					  <colorA>
						<color>75,75,75</color> <!-- dark grey -->
						<alts>
							<!-- <li><triggers><li>IsRecolored</li></triggers><apparelColorA>true</apparelColorA></li> -->
							<li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li>
						</alts>
					  </colorA>
					  <colorB>
						<!-- dark red -->
						<color>(140,0,0)</color>
						<!-- mid yellow -->
						<!-- <color>220,190,0</color> -->
						<alts>
							<!-- <li><triggers><li>IsRecolored</li></triggers><apparelColorA>true</apparelColorA></li> -->
							<li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li>
						</alts>
					  </colorB>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>21</layer> </dataNorth> </drawData>
				</li>
			</renderNodeProperties>
		  
		</apparel>
		<tradeTags>
			<li>guy762TT_KotORClothes</li>
			<li>guy762TT_KotORUnderArmor</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(75,75,75)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>


	
	  
	  
	  
	  
	  
	
	
	
	
	
	
	
	
	
	
	
	
	
	
