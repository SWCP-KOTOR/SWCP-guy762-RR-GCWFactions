<Defs>

	
	
	<ThingDef ParentName="guy762_HatCraftableBase">
		<defName>guy762_PartisanFlakCap</defName>
		<label>flak hat (masked)</label>
		<description>A durable, padded armorweave head cover.</description>
		<graphicData>
		  <texPath>SWApparel/Rebel/PaoHat/PaoHat_Mask</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(235,210,180)</colorTwo> -->
		</graphicData>
		<statBases>
		  <MarketValue>100</MarketValue>
		  <MaxHitPoints>115</MaxHitPoints>
		  <Mass>0.5</Mass>
		  <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
		  <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
		  <ArmorRating_Heat>0.3</ArmorRating_Heat>
		  <EquipDelay>0.1</EquipDelay>
		  
		  
		  <WorkToMake>1000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>0.35</ToxicEnvironmentResistance>
		</equippedStatOffsets>
		
		<recipeMaker>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<KOTOR_FabricArmorweave>20</KOTOR_FabricArmorweave>
			<Cloth>10</Cloth>
		</costList>
		
		<apparel>
		  <wornGraphicPath>SWApparel/Rebel/PaoHat/PaoHat_Mask</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  <renderSkipFlags>
				<li>Hair</li>
				<li>Beard</li>
			</renderSkipFlags>
			<bodyPartGroups>
				<li>UpperHead</li>
				<li>Mouth</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
		  <tags>
			<li>PartisanAlliance_trooperheadwear</li>
			<li>SWCPSpecificApparelItem_PartisanFlakHat</li>
		  </tags>
		  <countsAsClothingForNudity>false</countsAsClothingForNudity>
		  <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
		  <!-- <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance> -->
		  
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelHead</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>71</baseLayer>	<!-- OVERHEAD -->
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/Rebel/PaoHat/PaoHat_Mask</li></texturePaths>
					  <colorA>
						<apparelColorA>true</apparelColorA> <!-- uses colorGenerator color, do not use colorOptions on colorOne -->
						<alts><li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li></alts>
					  </colorA>
					  <colorB>
						<color>(235,210,180)</color>	<!-- lighter tan -->
						<alts><li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li></alts>
					  </colorB>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>71</layer> </dataNorth> </drawData>	<!-- OVERHEAD -->
				</li>
			</renderNodeProperties>
		</apparel>
		<tradeTags>
			<li>guy762TT_GCWApparel</li>
			<li>guy762TT_GCWArmor_ScumAndRebelHats</li>
			<li>guy762TT_GCWArmor_PartisanSurplus</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>10</weight>
					<only>(90,85,65)</only> <!-- grease green -->
				</li>
				<li>
					<weight>10</weight>
					<only>(110,105,100)</only>  <!-- maldrood army grey -->
				</li>
				<li>
					<weight>10</weight>
					<only>(90,75,60)</only> <!-- patchleather -->
				</li>
			</options>
		</colorGenerator>
		<modExtensions>
		  <li Class="BigAndSmall.HasCustomizableGraphics">
			<!-- Tag is not needed for apparel. -->
			<colorA>true</colorA>
			<colorB>true</colorB>
			<!-- <colorC>true</colorC> -->
		  </li>
		</modExtensions>
	</ThingDef> 
	
	
	
