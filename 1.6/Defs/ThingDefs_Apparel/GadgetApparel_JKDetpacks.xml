	<AbilityDef>
        <defName>guy762_Ability_DetonateDetpack</defName>
        <label>detonate detpack</label>
        <description>Send a wireless detonation signal to any individual active detpack within 500 tiles. The detpack must be manually selected.</description>
        <iconPath>UI/JK_detpack_detonateIcon</iconPath>
		<uiOrder>999</uiOrder>
		
        <jobDef>CastAbilityOnThingWithoutWeapon</jobDef>
        <!--hotKey>Misc12</hotKey-->
		<writeCombatLog>True</writeCombatLog>
		<hostile>true</hostile>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>500</range>
            <drawAimPie>true</drawAimPie>
            <warmupTime>0.5</warmupTime>
            <requireLineOfSight>False</requireLineOfSight>
			<!-- <soundCast>kotorsound_static_off</soundCast> -->
			<soundCast>kotorsound_JKdetpack_warning</soundCast>
            <targetParams>
                <canTargetPawns>False</canTargetPawns>
                <canTargetSelf>False</canTargetSelf>
                <canTargetBuildings>True</canTargetBuildings>
                <canTargetLocations>True</canTargetLocations>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="EBSGFramework.CompProperties_EBSGBlast">
                <explosion>
					<radius>0.25</radius>
					<damageDef>guy762_Damage_DetpackDetonateSignal</damageDef>
					<!-- <injureSelf>false</injureSelf> -->
					<damageAmount>1</damageAmount>
				</explosion>
            </li>
        </comps>
    </AbilityDef>
	
	<DamageDef>
		<defName>guy762_Damage_DetpackDetonateSignal</defName>
		<label>detpack detonation signal</label>
		<hasForcefulImpact>false</hasForcefulImpact>
		<makesBlood>false</makesBlood>
		<canInterruptJobs>false</canInterruptJobs>
		
		<buildingDamageFactorImpassable>0</buildingDamageFactorImpassable>
		<buildingDamageFactorPassable>0</buildingDamageFactorPassable>
		<plantDamageFactor>0</plantDamageFactor>
		<corpseDamageFactor>0</corpseDamageFactor>
	</DamageDef>
	
	
	
	
	
	
	
	
	
	<ThingDef ParentName="ResourceBase">
		<defName>guy762_JKDetpack_item</defName> <!--this is the resource/ammo to reload the mine pocket-->
		<label>inactive detpack</label>
		<description>placeholder.</description>
		<possessionCount>0</possessionCount>
		<graphicData>
		  <texPath>Items/JK_detpack_item</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>0.75</drawSize>
		</graphicData>
		<stackLimit>15</stackLimit>
		<healthAffectsPrice>false</healthAffectsPrice>
		<statBases>
		  <MaxHitPoints>50</MaxHitPoints>
		  <MarketValue>3</MarketValue>
		  <Mass>2</Mass>
		  <Flammability>1</Flammability>
		  <DeteriorationRate>1.0</DeteriorationRate>
		</statBases>
		<thingCategories>
		  <li>Manufactured</li>
		</thingCategories>
		
		<tickerType>Normal</tickerType>
		<comps>
            <li Class="CompProperties_Explosive">                <!-- explosive properties-->
                <explosiveRadius>3.9</explosiveRadius>
                <explosiveDamageType>guy762_GrenadeDamage_detpack</explosiveDamageType>
				<!-- <damageAmountBase>40</damageAmountBase> -->
				
                <startWickHitPointsPercent>0.25</startWickHitPointsPercent>
                <wickTicks>15</wickTicks>
                <!-- <startWickOnDamageTaken> -->
                    <!-- <li>guy762_Damage_DetpackDetonateSignal</li> -->
                <!-- </startWickOnDamageTaken> -->
            </li>
        </comps>
	</ThingDef>
	
	
</Defs>