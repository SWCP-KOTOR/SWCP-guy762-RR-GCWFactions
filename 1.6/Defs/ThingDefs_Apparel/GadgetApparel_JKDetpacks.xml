<?xml version="1.0" encoding="utf-8"?>
<Defs>


    <ThingDef ParentName="ApparelNoQualityBase">
        <defName>guy762_JKDetpackCase</defName>
        <label>detpack case</label>
        <description>A case of remotely detonated explosive charges. The explosives used are designed specifically for destroying structures, and can breach most doors and walls with ease. The case contains a built in detonation switch which requires you to manually target a placed charge in order to detonate it.</description>
        <techLevel>Spacer</techLevel>
		<graphicData>
            <texPath>Items/JK_detpack_case</texPath>
            <graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.875</drawSize>
        </graphicData>
		<statBases>
            <MarketValue>1000</MarketValue>
            <Mass>8</Mass>
            <Flammability>1</Flammability>
            <EquipDelay>1</EquipDelay>
			
			<!-- <MarketValue>5080</MarketValue> -->
        </statBases>
		
		<soundInteract>kotorsound_select_JKdetpack</soundInteract>
		<soundDrop>kotorsound_select_JKdetpack</soundDrop>
        <comps>
            <li Class="CompProperties_ApparelReloadable">
                <maxCharges>3</maxCharges>
                <ammoDef>guy762_JKDetpack_item</ammoDef>                <!-- Change into any def you want-->
                <ammoCountPerCharge>1</ammoCountPerCharge>                <!-- Important for reloading -->
                <!-- <ammoCountToRefill>3</ammoCountToRefill> -->
                <baseReloadTicks>60</baseReloadTicks>
                <soundReload>Standard_Reload</soundReload>
                <hotKey>Misc4</hotKey>
                <chargeNoun>mines</chargeNoun>
                <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
            </li>
			<!-- <li Class="EBSGFramework.CompProperties_EquippableAbility"> -->
			<!-- <li Class="CompProperties_EquippableAbility"> -->
                <!-- <abilityDef>guy762_Ability_DetonateDetpack</abilityDef> -->
            <!-- </li> -->
        </comps>
        <verbs>
            <li>
                <label>place mine</label>
                <verbClass>MinePocket.Verb_ShootMine</verbClass>                <!-- Do not change-->
                <hasStandardCommand>true</hasStandardCommand>
                <onlyManualCast>True</onlyManualCast>
                <burstShotCount>1</burstShotCount>
                <range>3</range>
                <warmupTime>0.3</warmupTime>
                <noiseRadius>1</noiseRadius>
                <ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
                <soundCast>kotorsound_JKdetpack_throw</soundCast>                <!-- Sound when casting-->
                <drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
                <targetable>true</targetable>
                <targetParams>
                    <canTargetPawns>false</canTargetPawns>
                    <canTargetBuildings>false</canTargetBuildings>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
                <defaultProjectile>SWProj_Mine_JKdetpack</defaultProjectile>                <!-- Projectile to be used (not the actual mine) -->
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
            </li>
        </verbs>
		
        <recipeMaker>
            <unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<researchPrerequisite>SWCPResearch_PLACEHOLDER</researchPrerequisite>
            <recipeUsers>
                <li>CraftingSpot</li>                <!-- To be changed -->
            </recipeUsers>
            <useIngredientsForColor>false</useIngredientsForColor>
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <skillRequirements>
                <Crafting>6</Crafting>
            </skillRequirements>
        </recipeMaker>
        <costList>
            <Steel>50</Steel>
        </costList>
		
        <tickerType>Normal</tickerType>
        <thingCategories>
            <li>ApparelUtility</li>
        </thingCategories>
        <generateAllowChance>0.15</generateAllowChance>
        <apparel>            <!-- If it's going to use a visible apparel outfit, this part will need additional changes, 
    otherwise you can leave it as it is -->
            <developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
            <careIfWornByCorpse>false</careIfWornByCorpse>
            <careIfDamaged>false</careIfDamaged>
            <wearPerDay>0</wearPerDay>
            <bodyPartGroups>
                <!-- <li>Waist</li> -->
				<li>Legs</li>
            </bodyPartGroups>
            <layers>
                <li>Belt</li>
            </layers>
            <tags>
                <li>SWDetpackCase</li>
				<li>SWGCWSpecificGadgetItem_JKDetpackCase</li>
				<li>SWCPDroidApparelRestrictionTag_GrenadeDetpackBelts</li>
            </tags>
			<defaultOutfitTags>	
				<li>Soldier</li>
				<li>SWCPOutfitTag_AnyGadget</li>
			</defaultOutfitTags>
			
			<abilities>
				<li>guy762_Ability_DetonateDetpack</li>
			</abilities>
        </apparel>
		<tradeTags>
			<li>guy762TT_GCWGadgetEquipment_any</li>
			<li>guy762TT_GCWGadgetEquipment_Illegal</li>
		</tradeTags>
    </ThingDef>


    <ThingDef ParentName="BaseFragGrenadeProjectile">        <!-- just the projectile that spawns the mine-->
        <defName>SWProj_Mine_JKdetpack</defName>
        <label>flying detpack</label>
        <thingClass>MinePocket.Projectile_SpawnMine</thingClass>        <!-- important -->
		<graphicData>
			<texPath>Items/JK_detpack_item</texPath>
		</graphicData>
        <projectile>
            <speed>25</speed>
			<tryAdjacentFreeSpaces>true</tryAdjacentFreeSpaces>
            <explosionRadius>0.9</explosionRadius >
            <spawnsThingDef>guy762_OnGroundMine_JKdetpack</spawnsThingDef>            <!-- important -->
			<soundImpact>kotorsound_JKdetpack_stick</soundImpact>
			<soundImpactAnticipate>kotorsound_JKdetpack_stick</soundImpactAnticipate>
        </projectile>
    </ThingDef>

	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
