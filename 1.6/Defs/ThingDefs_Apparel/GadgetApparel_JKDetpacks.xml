    <ThingDef ParentName="TrapIEDBase">
        <defName>guy762_OnGroundMine_JKdetpack</defName>
        <label>active detpack</label>
		<description>placeholder.</description>
		<graphicData>
            <texPath>Items/JK_detpack_onground</texPath>
        </graphicData>
		
        <thingClass>Building_TrapExplosive</thingClass>
        <designationCategory Inherit="False"/>        <!-- important to not be able to be built normally-->
		<soundDrop>kotorsound_JKdetpack_stick</soundDrop>
        <!-- <designationHotKey>Misc7</designationHotKey> -->
        <comps>
            <li>
                <compClass>MinePocket.CompDefuse</compClass>
            </li>
			<li Class="CompProperties_Glower">
				<glowRadius>1</glowRadius>
				<glowColor>(255,52,21,0)</glowColor>
			</li>
            <li Class="CompProperties_Explosive">                <!-- explosive properties-->
                <explosiveRadius>3.9</explosiveRadius>
                <explosiveDamageType>guy762_GrenadeDamage_detpack</explosiveDamageType>
				<!-- <damageAmountBase>40</damageAmountBase> -->
				
                <startWickHitPointsPercent>0.5</startWickHitPointsPercent>
                <wickTicks>30</wickTicks>
                <startWickOnDamageTaken>
                    <li>guy762_Damage_DetpackDetonateSignal</li>
                </startWickOnDamageTaken>
            </li>
        </comps>
        <specialDisplayRadius>3.9</specialDisplayRadius>
        <modExtensions>
            <li Class="MinePocket.MinePocketDefExtension">                <!-- super important -->
                <defToSpawnAfterDefuse>guy762_JKDetpack_item</defToSpawnAfterDefuse>
                <countToSpawn>1</countToSpawn>
            </li>
        </modExtensions>
    </ThingDef>
	
