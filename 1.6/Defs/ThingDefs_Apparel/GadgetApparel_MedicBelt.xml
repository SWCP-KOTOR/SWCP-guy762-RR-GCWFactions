        <description>Use a medpac on a nearby wounded pawn.</description>
        <!-- <iconPath>UI/kolto_heal_icon</iconPath> -->
        <iconPath>UI/MedicBeltAbilities/MedicBeltHeal_AdvMedpac</iconPath>
		<uiOrder>999</uiOrder>
		
        <jobDef>CastAbilityOnThingWithoutWeapon</jobDef>
		
        <hotKey>Misc4</hotKey>
		<displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
