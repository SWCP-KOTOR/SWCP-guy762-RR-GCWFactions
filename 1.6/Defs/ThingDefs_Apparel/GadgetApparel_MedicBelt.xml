<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  
  <ThingDef ParentName="guy762_UtilityItemBase">
    <defName>guy762_MedicBelt</defName>
    <label>field medic belt</label>
    <description>A field medic belt contains all the necessary equipment for battlefield medical operations as well as several recovery stims, which can heal any downed pawn in a short radius.</description>
    <descriptionHyperlinks>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyMedpac</AbilityDef>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyAdvMedpac</AbilityDef>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyLifeSupportPack</AbilityDef>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyAntidoteKit</AbilityDef>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyKolto</AbilityDef>
		<AbilityDef>guy762_AbilityMedicBelt_ApplyBacta</AbilityDef>
	</descriptionHyperlinks>
	
	<graphicData>
      <texPath>Items/belt_medic</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Spacer</techLevel>
    <statBases>
		<Mass>4</Mass>
		<EquipDelay>2</EquipDelay>
		<!-- <MarketValue>47200</MarketValue> -->
		<MarketValue>4700</MarketValue>
		<MaxHitPoints>100</MaxHitPoints>
    </statBases>
	<equippedStatOffsets>
		<MedicalSurgerySuccessChance>0.4</MedicalSurgerySuccessChance>
		<MedicalTendQualityOffset>0.4</MedicalTendQualityOffset>
		<MedicalTendSpeed>0.4</MedicalTendSpeed>
	</equippedStatOffsets>
	
    <apparel>
		<countsAsClothingForNudity>false</countsAsClothingForNudity>
		<careIfWornByCorpse>false</careIfWornByCorpse>
		<careIfDamaged>false</careIfDamaged>
		<ignoredByNonViolent>true</ignoredByNonViolent>
		<wearPerDay>0</wearPerDay>
		<bodyPartGroups>
			<li>Waist</li>
		</bodyPartGroups>
		<layers>
			<li>Belt</li>
		</layers>
		<tags>
			<li>KotORBelt_medicbelt</li>
			<li>SWMedicBelt</li>
			<li>SWCPSpecificGadgetItem_MedicBelt</li>
		</tags>
		<defaultOutfitTags>	
			<li>Worker</li>
			<li>SWCPOutfitTag_Worker</li>
			<li>Soldier</li>
			<li>SWCPOutfitTag_AnyGadget</li>
		</defaultOutfitTags>
	  
		<abilities>
			<!-- <li>guy762_Ability_MedicBeltRevive</li> -->
			<!-- <li>guy762_Ability_MedicBeltHeal</li> -->
			<li>guy762_AbilityMedicBelt_ApplyMedpac</li>
			<li>guy762_AbilityMedicBelt_ApplyAdvMedpac</li>
			<li>guy762_AbilityMedicBelt_ApplyLifeSupportPack</li>
			<li>guy762_AbilityMedicBelt_ApplyAntidoteKit</li>
			<li>guy762_AbilityMedicBelt_ApplyKolto</li>
			<li>guy762_AbilityMedicBelt_ApplyBacta</li>
		</abilities>
    </apparel>
	<tradeTags>
		<li>guy762TT_KotORLegendary</li>
		<li>guy762TT_GCWGadgetEquipment_any</li>
		<li>guy762TT_GCWGadgetEquipment_ExoticLegal</li>
    </tradeTags>

  </ThingDef>
  
  
	<AbilityDef>
        <defName>guy762_Ability_MedicBeltRevive</defName>
        <label>apply recovery stim</label>
        <description>Use a recovery stim on a nearby downed pawn.</description>
        <!-- <iconPath>UI/kolto_heal_icon</iconPath> -->
        <iconPath>UI/MedicBeltAbilities/medicbelt_revive_icon</iconPath>
		<uiOrder>999</uiOrder>
		
        <jobDef>CastAbilityOnThingWithoutWeapon</jobDef>
		
        <hotKey>Misc4</hotKey>
		<displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
		<showWhenDrafted>true</showWhenDrafted>
		<disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
		
		<!-- <aiCanUse>true</aiCanUse> -->
		<ai_IsOffensive>false</ai_IsOffensive>
		<hostile>false</hostile>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
		<canUseAoeToGetTargets>true</canUseAoeToGetTargets>
		
		<writeCombatLog>True</writeCombatLog>
		<stunTargetWhileCasting>true</stunTargetWhileCasting>
		
		<statBases>
			<Ability_Duration>15</Ability_Duration> <!-- this is in seconds, not ticks -->
		</statBases>
		<warmupSound>kotorsound_medicbelt_longerloop</warmupSound>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>3</range>
            <drawAimPie>true</drawAimPie>
            <warmupTime>2.75</warmupTime>
            <requireLineOfSight>True</requireLineOfSight>
			<soundCast>kotorsound_medicbelt_smack</soundCast>
            <targetParams>
                <onlyTargetIncapacitatedPawns>true</onlyTargetIncapacitatedPawns>
				<canTargetSelf>false</canTargetSelf>
				
				<canTargetBuildings>false</canTargetBuildings>
				<canTargetItems>false</canTargetItems>
				
				<canTargetPawns>true</canTargetPawns>
				<canTargetAnimals>true</canTargetAnimals>
				<canTargetHumans>true</canTargetHumans>
				<canTargetMechs>false</canTargetMechs>
            </targetParams>
        </verbProperties>
		
		<!-- <charges>3</charges> -->
		<!-- <cooldownTicksRange>60</cooldownTicksRange> -->
		<!-- <cooldownPerCharge>true</cooldownPerCharge> -->
        <comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>guy762_medpacHeal_life</hediffDef>
				<!-- <hediffDef>guy762_hediff_kolto</hediffDef> -->
				<!-- <applyToSelf>false</applyToSelf> -->
				<applyToTarget>true</applyToTarget>
				<applicableToMechs>False</applicableToMechs>
				
				<goodwillImpact>15</goodwillImpact>
			</li>
			<!-- <li Class="EBSGFramework.CompProperties_AbilityReloadable"> -->
                <!-- <maxCharges>3</maxCharges> -->
                <!-- <ammoPerCharge>1</ammoPerCharge> -->
                <!-- <ammoDef>guy762_medpac_life</ammoDef> -->
				<!-- <reloadSound>Standard_Reload</reloadSound> -->
            <!-- </li> -->
        </comps>
    </AbilityDef>
	
	
	
	
	
	<AbilityDef>
