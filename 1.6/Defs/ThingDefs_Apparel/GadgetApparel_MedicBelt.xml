	<AbilityDef ParentName="guy762_AbilityMedicBeltBASE">
		<defName>guy762_AbilityMedicBelt_ApplyMedpac</defName>
		<label>apply medpac</label>
		<description>Use a medpac on a nearby wounded pawn. The caster must have medpacs in their inventory for this ability to work.</description>
		<iconPath>UI/MedicBeltAbilities/MedicBeltHeal_Medpac</iconPath>

        <comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>guy762_medpacHeal</hediffDef>
				<applyToTarget>true</applyToTarget>
				<applicableToMechs>False</applicableToMechs>
				
				<goodwillImpact>5</goodwillImpact>
			</li>
			<li Class="EBSGFramework.CompProperties_RemoveItemFromInventory">
				<casterThing>guy762_medpac</casterThing>
				<casterCount>1</casterCount>
				<casterBestEffort>False</casterBestEffort>
				<disableGizmoIfCasterInvalid>True</disableGizmoIfCasterInvalid>
            </li>
        </comps>
    </AbilityDef>
	
	
	
