		</apparel>
		<tradeTags>
			<li>guy762TT_KotORCharacterItem</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>10</weight>
					<only>(80,30,40)</only>
				</li>
			</options>
		</colorGenerator>
