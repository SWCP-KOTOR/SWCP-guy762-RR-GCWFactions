<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="guy762_clothingbase">
		<defName>guy762_NewRepUniform_bigbelt</defName>
		<label>New Republic armored uniform, guard's</label>
		<description>These are simple garments that protect little more than the modesty of the wearer.</description>
		<graphicData>
		  <texPath>SWApparel/NewRepublicOfficer/bigbelt/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(250,250,250)</colorTwo> -->
		</graphicData>
		<statBases>
			<Mass>4</Mass>
			<MarketValue>170</MarketValue>
			<MaxHitPoints>175</MaxHitPoints>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
			<ArmorRating_Heat>0.3</ArmorRating_Heat>
			<Insulation_Cold>15</Insulation_Cold>
			<EquipDelay>3</EquipDelay>
			
			<WorkToMake>5000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
			<VEF_MassCarryCapacity>5</VEF_MassCarryCapacity>
		</equippedStatOffsets>
		
		<recipeMaker>
			<researchPrerequisite>SWCPResearch_PLACEHOLDER</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
		  <Synthread>75</Synthread>
		  <Plasteel>15</Plasteel>
		</costList>
		
		<apparel>
		  <layers Inherit="False">
			<li>Middle</li>
			<li>OnSkin</li>
		  </layers>
		  
		  <wornGraphicPath>SWApparel/NewRepublicOfficer/bigbelt/Apparel</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  <!-- <defaultOutfitTags> -->
			<!-- <li>Worker</li> -->
		  <!-- </defaultOutfitTags> -->
		  
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelBody</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>21</baseLayer>	<!-- ONSKIN -->
					<autoBodyTypePaths>true</autoBodyTypePaths>
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/NewRepublicOfficer/bigbelt/Apparel</li></texturePaths>
					  <colorA>
						<apparelColorA>true</apparelColorA> <!-- uses colorGenerator color, do not use colorOptions on colorOne -->
						<alts><li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li></alts>
					  </colorA>
					  <colorB>
						<color>250,250,250</color> <!-- white -->
						<alts><li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li></alts>
					  </colorB>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>21</layer> </dataNorth> </drawData>	<!-- ONSKIN -->
				</li>
			</renderNodeProperties>
			
			<tags Inherit="False">
				<li>NewRepublic_guard</li>
				<li>SWGCWSpecificApparelItem_BigBeltNewRepublicOfficerUniform</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
				<li>SWCPOutfitTagGCW_RebelUniform</li>
			</defaultOutfitTags>
		</apparel>
		<tradeTags>
			<li>guy762TT_GCWApparel</li>
			<li>guy762TT_GCWArmor_NewRepublicSurplus</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(70,90,125)</only>       <!--K1 blue-->
				</li>
			</options>
		</colorGenerator>
		<modExtensions>
		  <li Class="BigAndSmall.HasCustomizableGraphics">
			<!-- Tag is not needed for apparel. -->
			<colorA>true</colorA>
			<colorB>true</colorB>
			<!-- <colorC>true</colorC> -->
		  </li>
		</modExtensions>
	</ThingDef>
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  

	  
	  
