<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	  
	  
	  
	  
	<ThingDef ParentName="guy762_clothingbase">
		<defName>guy762_RebelUniform_lowrank</defName>
		<label>Rebel Alliance uniform, officer's</label>
		<description>These are simple garments that protect little more than the modesty of the wearer.</description>
		<graphicData>
		  <texPath>SWApparel/RebelOfficer/navylieutenant/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(145,175,195)</colorTwo> -->
		</graphicData>
		<statBases>
			<Mass>3</Mass>
			<MarketValue>1000</MarketValue>
			<MaxHitPoints>100</MaxHitPoints>
			<ArmorRating_Sharp>0.01</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.01</ArmorRating_Blunt>
			<ArmorRating_Heat>0.01</ArmorRating_Heat>
			<Insulation_Cold>10</Insulation_Cold>
			<Insulation_Heat>5</Insulation_Heat>
			<EquipDelay>3</EquipDelay>
			
			<WorkToMake>4000</WorkToMake>
		</statBases>
		<equippedStatOffsets>
		  <SocialImpact>0.1</SocialImpact>
		</equippedStatOffsets>
		
		<recipeMaker>
			<researchPrerequisite>guy762_ResearchKotOR_sith</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
		  <Cloth>75</Cloth>
		</costList>
		
		<apparel>
		  <tags Inherit="False">
			<li>RebelAlliance_lowrankofficer</li>
			<li>SWGCWSpecificApparelItem_LowRankRebelOfficerUniform</li>
			<li>SWGCWRoyaltyTag_AnyRebelOfficerUniform</li>
		  </tags>
		  <wornGraphicPath>SWApparel/RebelOfficer/navylieutenant/Apparel</wornGraphicPath>
		  <useWornGraphicMask>true</useWornGraphicMask>
		  <defaultOutfitTags>
			<li>Worker</li>
		  </defaultOutfitTags>
		  
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelBody</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>21</baseLayer>	<!-- ONSKIN -->
					<autoBodyTypePaths>true</autoBodyTypePaths>
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/RebelOfficer/navylieutenant/Apparel</li></texturePaths>
					  <colorA>
						<apparelColorA>true</apparelColorA> <!-- uses colorGenerator color, do not use colorOptions on colorOne -->
						<alts><li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li></alts>
					  </colorA>
					  <colorB>
						<color>(145,175,195)</color> <!-- sand blue -->
						<alts><li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li></alts>
					  </colorB>
					  
					  <altDefs><li>guy762_RebelUniformRankCustomization_navylt</li><li>guy762_RebelUniformRankCustomization_navycap</li></altDefs>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>21</layer> </dataNorth> </drawData>	<!-- ONSKIN -->
				</li>
			</renderNodeProperties>
		</apparel>
		
		<!-- <randomStyleChance>1</randomStyleChance> -->
		<!-- <randomStyle> -->
		  <!-- <li> -->
			<!-- <styleDef>guy762_RankStyleRebOfficer_navylt</styleDef> -->
		  <!-- </li> -->
		  <!-- <li> -->
			<!-- <styleDef>guy762_RankStyleRebOfficer_navycap</styleDef> -->
		  <!-- </li> -->
		<!-- </randomStyle> -->
		
		<tradeTags>
			<li>guy762TT_GCWApparel</li>
			<li>guy762TT_GCWArmor_RebelOfficer</li>
		</tradeTags>
		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(170,135,100)</only> <!-- darker beige -->
				</li>
			</options>
		</colorGenerator>
		<modExtensions>
		  <li Class="BigAndSmall.HasCustomizableGraphics">
			<!-- Tag is not needed for apparel. -->
			<colorA>true</colorA>
			<colorB>true</colorB>
			<!-- <colorC>true</colorC> -->
		  </li>
		</modExtensions>
	</ThingDef>
	  
