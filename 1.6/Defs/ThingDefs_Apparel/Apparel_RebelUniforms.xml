	<BigAndSmall.GraphicSetDef>
		<defName>guy762_RebelUniformRankCustomization_navylt</defName>
		<conditionalGraphics>
		  <triggerFlags><whitelist><guy762AltTag_RebelNavyLieutenant/></whitelist></triggerFlags>
		  <texturePaths><li>SWApparel/RebelOfficer/navylieutenant/Apparel</li></texturePaths>
