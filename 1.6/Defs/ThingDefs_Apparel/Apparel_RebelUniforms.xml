			  <!-- <li>guy762_slot_underlay</li> -->
			<!-- </partKinds> -->
			<!-- <randomizeParts>true</randomizeParts> -->
		  <!-- </li> -->
		<!-- </comps> -->
	</ThingDef>
	  
	<ThingStyleDef>
		<defName>guy762_RankStyleRebOvercoat_armygen</defName>
		<overrideLabel>rebel overcoat, general's</overrideLabel>
		<wornGraphicPath>SWApparel/RebelArmyDuster/general/Apparel</wornGraphicPath>
		<graphicData>
		  <texPath>SWApparel/RebelArmyDuster/general/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <shaderType>CutoutComplex</shaderType>
		</graphicData>
	  </ThingStyleDef>
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	  
	
	  

</Defs>