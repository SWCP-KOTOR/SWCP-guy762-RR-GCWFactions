	<ThingDef ParentName="KotORArmorModdable_soft">
		<defName>guy762_RebelOfficerDuster</defName>
		<label>rebel overcoat, top brass</label>
		<description>This long overcoat is typically worn by ranking officers of the Rebel Alliance and New Republic.</description>
		<graphicData>
		  <texPath>SWApparel/RebelArmyDuster/general/Apparel</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <!-- <shaderType>CutoutComplex</shaderType> -->
		  <!-- <colorTwo>(175,120,55)</colorTwo> -->
		</graphicData>
		<statBases>
			<Mass>6</Mass>
			<MarketValue>2500</MarketValue>
			<MaxHitPoints>250</MaxHitPoints>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Heat>0.2</ArmorRating_Heat>
			<Insulation_Cold>10</Insulation_Cold>
			<Insulation_Heat>15</Insulation_Heat>
			<EquipDelay>3</EquipDelay>
		</statBases>
		<equippedStatOffsets>
		  <SocialImpact>0.8</SocialImpact>
		  <VEF_MassCarryCapacity MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">5</VEF_MassCarryCapacity>
		</equippedStatOffsets>
		<apparel>
			<drawData>
			  <dataNorth>
				<!-- FOR USE WITH SHELL LAYER ONLY!!! -->
				<layer>65</layer>
			  </dataNorth>
			</drawData>
			<layers>
				<!-- <li>Middle</li> -->
				<li>Shell</li>
			</layers>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<tags Inherit="False">
				<li>NewRepublic_ArmyOfficer</li>
				<li>SWGCWSpecificApparelItem_HighRankRebelArmyOfficerDuster</li>
				<li>SWGCWRoyaltyTag_AnyHighRankingRebelOfficerUniform</li>
			</tags>
			<wornGraphicPath>SWApparel/RebelArmyDuster/general/Apparel</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			
			<renderNodeProperties>
				<li Class="BigAndSmall.PawnRenderingProps_Ultimate">
					<nodeClass>BigAndSmall.PawnRenderNode_UltimateApparel</nodeClass>
					<workerClass>BigAndSmall.URenderWorker_Apparel</workerClass>
					<parentTagDef>ApparelBody</parentTagDef>
					<shader>BS_CutoutThreeColor</shader>
					<baseLayer>23</baseLayer>	<!-- SHELL? -->
					<autoBodyTypePaths>true</autoBodyTypePaths>
					<conditionalGraphics>
					  <texturePaths><li>SWApparel/RebelArmyDuster/general/Apparel</li></texturePaths>
					  <colorA>
						<apparelColorA>true</apparelColorA> <!-- uses colorGenerator color, do not use colorOptions on colorOne -->
						<alts><li><triggers><li>CustomColorAIsSet</li></triggers><customColorA>(1,1,1)</customColorA> </li></alts>
					  </colorA>
					  <colorB>
						<color>(175,120,55)</color> <!-- burnt orange -->
						<alts><li><triggers><li>CustomColorBIsSet</li></triggers><customColorB>(1,1,1)</customColorB> </li></alts>
					  </colorB>
					  
					  <altDefs><li>guy762_RebelOvercoatRankCustomization_armygen</li></altDefs>
					</conditionalGraphics>
					<drawData> <dataNorth> <layer>66</layer> </dataNorth> </drawData>
				</li>
			</renderNodeProperties>
		</apparel>
		
		<!-- <randomStyleChance>1</randomStyleChance> -->
		<!-- <randomStyle> -->
		  <!-- <li> -->
			<!-- <styleDef>guy762_RankStyleRebOvercoat_armygen</styleDef> -->
		  <!-- </li> -->
		<!-- </randomStyle> -->
		
		<tradeTags>
			<li>guy762TT_GCWApparel</li>
			<li>guy762TT_GCWArmor_RebelOfficer</li>
		</tradeTags>
		
		<comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>

		<colorGenerator Class="ColorGenerator_Options" Inherit="False">
			<options>
				<li>
					<weight>15</weight>
					<only>(175,150,120)</only>       <!-- bespin beige -->
				</li>
			</options>
		</colorGenerator>
		<modExtensions>
		  <li Class="BigAndSmall.HasCustomizableGraphics">
			<!-- Tag is not needed for apparel. -->
			<colorA>true</colorA>
			<colorB>true</colorB>
			<!-- <colorC>true</colorC> -->
		  </li>
		</modExtensions>
	</ThingDef>
	  
