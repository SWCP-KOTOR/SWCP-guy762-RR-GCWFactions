<?xml version="1.0" encoding="utf-8" ?>

<Patch>
			
	<!-- this spawns the pawns -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/BiomeDef[defName="Scarlands"]/extraGenSteps</xpath>
		<order>Append</order>
		<value>
			<li>SWCPGenStep_HostileAncientsAtCommandPosts</li>
		</value>
	</Operation>
	
	<!-- this spawns the command posts -->
	
	<Operation Class="PatchOperationAdd">
	  <xpath>Defs/StructureLayoutDef[defName="AncientRuins_Scarlands"]</xpath>
	  <order>Append</order>
	  <value>
		<scatteredPrefabs>
			<li>
			  <countPer10kCellsRange>2~4</countPer10kCellsRange>
			  <minSpacing>60</minSpacing>
			  <maxDistFromStructure>250</maxDistFromStructure>
			  <prefabs>
				<SWCPPrefabSmallCommandPost_HostileAncients>
					<weight>100</weight>
					<indoorRuin>false</indoorRuin>
					<max>1</max>
				</SWCPPrefabSmallCommandPost_HostileAncients>
			  </prefabs>
			</li>
		</scatteredPrefabs>
	  </value>
	</Operation>
	
	
</Patch>